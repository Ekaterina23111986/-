function getBalanceForBatchM(drug, serial, expiry) {
  var stock = getSheet_(SHEET_STOCK_M);
  var data = stock.getDataRange().getValues();
  var drugNorm = normalizeStr(drug);
  var serialNorm = normalizeStr(serial);
  var expiryNorm = normalizeDate(expiry);
  var totalBalance = 0;

  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][COL_M.NAME-1]);
    if (name !== drugNorm) continue;
    var s = normalizeStr(data[i][COL_M.SERIAL-1]);
    if (s !== serialNorm) continue;
    var e = normalizeDate(data[i][COL_M.EXPIRY-1]);
    if (e !== expiryNorm) continue;
    totalBalance += num_(data[i][COL_M.BALANCE-1]);
  }
  return totalBalance;
}

function getBalanceForBatchN(drug, arrivalDate) {
  var stock = getSheet_(SHEET_STOCK_N);
