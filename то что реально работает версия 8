function showInfoOnSheetM(sheet, row) {
  if (!sheet || !row) return;
  var infoStartCol = COL_JM.INFO;
  var maxRows = 15;
  var infoCols = 3;

  var clearRange = sheet.getRange(row, infoStartCol, maxRows, infoCols);
  clearRange.clearContent();
  clearRange.clearFormat();
  var clearM = sheet.getRange(row, infoStartCol+3, maxRows, 1);
  clearM.clearContent();
  clearM.clearFormat();

  var drug = sheet.getRange(row, COL_JM.NAME).getValue();
  if (!drug) return;

  var stock = getSheet_(SHEET_STOCK_M);
  var data = stock.getDataRange().getValues();

  var batches = {};
  var totalBalance = 0;
  for (var i = 1; i < data.length; i++) {
    var r = data[i];
    if (r[COL_M.NAME-1].toString().trim() !== drug) continue;
    var balance = num_(r[COL_M.BALANCE-1]);
    if (balance <= 0) continue;
    var serial = r[COL_M.SERIAL-1] ? r[COL_M.SERIAL-1].toString().trim() : '(без серии)';
    var expiry = r[COL_M.EXPIRY-1] ? formatDate_(r[COL_M.EXPIRY-1]) : '—';
    var key = serial + '|' + expiry;
    if (!batches[key]) batches[key] = { serial: serial, expiry: expiry, balance: 0 };
    batches[key].balance += balance;
    totalBalance += balance;
  }

  var offset = 0;
  var headerCell = sheet.getRange(row + offset, infoStartCol);
  headerCell.setValue(drug);
  headerCell.setFontWeight('bold').setFontSize(10).setBackground('#0066CC').setFontColor('#FFFFFF');
  sheet.getRange(row + offset, infoStartCol, 1, infoCols).merge().setHorizontalAlignment('center');
  offset += 1;

  sheet.getRange(row + offset, infoStartCol).setValue("Серия");
  sheet.getRange(row + offset, infoStartCol+1).setValue("Срок");
  sheet.getRange(row + offset, infoStartCol+2).setValue("Остаток");
  sheet.getRange(row + offset, infoStartCol, 1, infoCols).setFontWeight('bold').setBackground('#E0E0E0');
  offset += 1;

  var keys = Object.keys(batches);
  if (keys.length === 0) {
    sheet.getRange(row + offset, infoStartCol).setValue("Нет остатков").setFontColor('#FF0000');
    offset += 1;
  } else {
    for (var k = 0; k < keys.length && offset < maxRows-2; k++) {
      var b = batches[keys[k]];
      sheet.getRange(row + offset, infoStartCol).setValue(b.serial);
      sheet.getRange(row + offset, infoStartCol+1).setValue(b.expiry);
      sheet.getRange(row + offset, infoStartCol+2).setValue(b.balance);
      offset += 1;
    }
  }

  sheet.getRange(row + offset, infoStartCol).setValue("ИТОГО:").setFontWeight('bold');
  sheet.getRange(row + offset, infoStartCol+1).setValue(totalBalance).setFontWeight('bold').setFontColor('#008000');
  sheet.getRange(row + offset, infoStartCol, 1, infoCols).setBackground('#DCFFDC');

  var lastRow = row + offset + 1;
  var borderRange = sheet.getRange(row, infoStartCol, lastRow - row + 1, infoCols);
  borderRange.setBorder(true, true, true, true, true, true);
  sheet.setColumnWidth(infoStartCol, 150);
  sheet.setColumnWidth(infoStartCol+1, 100);
  sheet.setColumnWidth(infoStartCol+2, 80);
}

function showInfoOnSheetN(sheet, row) {
  if (!sheet || !row) return;
  var infoStartCol = COL_JN.INFO;
  var maxRows = 15;
  var infoCols = 3;

  var clearRange = sheet.getRange(row, infoStartCol, maxRows, infoCols);
  clearRange.clearContent();
  clearRange.clearFormat();
  var clearK = sheet.getRange(row, infoStartCol+3, maxRows, 1);
  clearK.clearContent();
  clearK.clearFormat();

  var drug = sheet.getRange(row, COL_JN.NAME).getValue();
  if (!drug) return;

  var stock = getSheet_(SHEET_STOCK_N);
  var data = stock.getDataRange().getValues();

  var batches = [];
  var totalRest = 0;
  for (var i = 1; i < data.length; i++) {
    var r = data[i];
    if (r[COL_N.NAME-1].toString().trim() !== drug) continue;
    var rest = num_(r[COL_N.BALANCE-1]);
    if (rest <= 0.0001) continue;
    var date = r[COL_N.DATE-1] ? formatDate_(r[COL_N.DATE-1]) : '—';
    batches.push({ date: date, rest: rest });
    totalRest += rest;
  }

  if (batches.length === 0) {
    sheet.getRange(row, infoStartCol).setValue("Нет остатков").setFontColor('#FF0000');
    return;
  }

  var offset = 0;
  var headerCell = sheet.getRange(row + offset, infoStartCol);
  headerCell.setValue(drug).setFontWeight('bold').setFontSize(11)
    .setBackground('#0066CC').setFontColor('#FFFFFF');
  sheet.getRange(row + offset, infoStartCol, 1, infoCols).merge().setHorizontalAlignment('center');
  offset += 1;

  sheet.getRange(row + offset, infoStartCol).setValue("Дата прихода");
  sheet.getRange(row + offset, infoStartCol+1).setValue("Остаток");
  sheet.getRange(row + offset, infoStartCol, 1, infoCols).setFontWeight('bold').setBackground('#E0E0E0');
  offset += 1;

  for (var b = 0; b < batches.length && offset < maxRows-1; b++) {
    var batch = batches[b];
    sheet.getRange(row + offset, infoStartCol).setValue(batch.date);
    sheet.getRange(row + offset, infoStartCol+1).setValue(batch.rest);
    offset += 1;
  }

  if (offset < maxRows) {
    sheet.getRange(row + offset, infoStartCol).setValue("ИТОГО:").setFontWeight('bold');
    sheet.getRange(row + offset, infoStartCol+1).setValue(totalRest).setFontWeight('bold').setFontColor('#008000');
    sheet.getRange(row + offset, infoStartCol, 1, infoCols).setBackground('#DCFFDC');
  }

  var lastRow = row + offset + 1;
  var borderRange = sheet.getRange(row, infoStartCol, lastRow - row + 1, infoCols);
  borderRange.setBorder(true, true, true, true, true, true);
  sheet.autoResizeColumns(infoStartCol, infoCols);
}

