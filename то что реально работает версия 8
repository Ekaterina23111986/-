/**
 * Расход по кабинетам — выдачи в каждый кабинет за период.
 * Столбцы: Кабинет | Наименование | Кол-во | Сумма
 */
function reportByCabinet_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var R = FIRST_ROW;

  sh.getRange(R, 1, 1, 4).setValues([
    ['Кабинет', 'Наименование', 'Кол-во', 'Сумма']
  ]).setFontWeight('bold').setBackground('#D9EAD3');

  var byCabinet = {};

  // Журнал М
  var jm = getSheet_(SHEET_JOURNAL_M).getDataRange().getValues();
  for (var i = 1; i < jm.length; i++) {
    if (!inPeriod_(jm[i][COL_JM.DATE-1], d1, d2)) continue;
    var name = txt_(jm[i][COL_JM.NAME-1]);
    var cabinet = txt_(jm[i][COL_JM.CABINET-1]);
    var qty = num_(jm[i][COL_JM.QUANTITY-1]);
    if (!name || !cabinet || qty <= 0) continue;
    var price = getIssuePriceM_(name, jm[i][COL_JM.SERIAL-1], jm[i][COL_JM.EXPIRY-1]);
    if (!byCabinet[cabinet]) byCabinet[cabinet] = [];
    var found = false;
    for (var j = 0; j < byCabinet[cabinet].length; j++) {
      if (byCabinet[cabinet][j].name === name) {
        byCabinet[cabinet][j].qty += qty;
        byCabinet[cabinet][j].sum += qty * price;
        found = true;
        break;
      }
    }
    if (!found) byCabinet[cabinet].push({ name: name, qty: qty, sum: qty * price });
  }

  // Журнал Н
  var jn = getSheet_(SHEET_JOURNAL_N).getDataRange().getValues();
  for (var i = 1; i < jn.length; i++) {
    if (!inPeriod_(jn[i][COL_JN.DATE-1], d1, d2)) continue;
    var name = txt_(jn[i][COL_JN.NAME-1]);
    var cabinet = txt_(jn[i][COL_JN.CABINET-1]);
    var qty = num_(jn[i][COL_JN.QUANTITY-1]);
    if (!name || !cabinet || qty <= 0) continue;
    var price = num_(jn[i][COL_JN.PRICE-1]);
    if (!byCabinet[cabinet]) byCabinet[cabinet] = [];
    var found = false;
    for (var j = 0; j < byCabinet[cabinet].length; j++) {
      if (byCabinet[cabinet][j].name === name) {
        byCabinet[cabinet][j].qty += qty;
        byCabinet[cabinet][j].sum += qty * price;
        found = true;
        break;
      }
    }
    if (!found) byCabinet[cabinet].push({ name: name, qty: qty, sum: qty * price });
  }

  var cabList = Object.keys(byCabinet).sort(function(a,b) { return a.localeCompare(b, 'ru'); });
  var rows = [];
  var tQty = 0, tSum = 0;

  for (var c = 0; c < cabList.length; c++) {
    var cab = cabList[c];
    var items = byCabinet[cab];
    items.sort(function(a,b) { return b.sum - a.sum; });
    for (var j = 0; j < items.length; j++) {
      rows.push([cab, items[j].name, items[j].qty, items[j].sum]);
      tQty += items[j].qty;
      tSum += items[j].sum;
    }
  }

  rows.push(['ИТОГО', '', tQty, tSum]);
  var end = writeBlock_(sh, R + 1, rows);
  sh.getRange(end - 1, 1, 1, 4).setFontWeight('bold');

  // График: сравнение кабинетов по сумме расхода
  if (cabList.length > 0) {
    var cabSums = {};
    for (var i = 0; i < rows.length - 1; i++) {
      var cab = rows[i][0];
      if (cab === 'ИТОГО') continue;
      if (!cabSums[cab]) cabSums[cab] = 0;
      cabSums[cab] += rows[i][3];
    }
    var cabChart = Object.keys(cabSums).sort(function(a,b) { return cabSums[b] - cabSums[a]; });
    for (var i = 0; i < cabChart.length; i++) {
      sh.getRange(R + 1 + i, 6).setValue(cabChart[i]);
      sh.getRange(R + 1 + i, 7).setValue(cabSums[cabChart[i]]);
    }
    var gL = sh.getRange(R + 1, 6, cabChart.length, 1);
    var gV = sh.getRange(R + 1, 7, cabChart.length, 1);
    buildChart_(sh, gL, [gV], 'Расход по кабинетам', {type: 'bar', position: {row: 2, col: 6}});
  }

  SpreadsheetApp.getActiveSpreadsheet().toast('Расход по кабинетам: ' + cabList.length + ' кабинетов.', 'Отчёт', 3);
}

/**
 * Расход на просроченные — позиции с истёкшим сроком годности за период.
 * Столбцы: Наименование | Серия | Срок годности | Кол-во | Сумма потерь
 */
function expiredExpenses_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var R = FIRST_ROW;

  sh.getRange(R, 1, 1, 5).setValues([
    ['Наименование', 'Серия', 'Срок годности', 'Кол-во', 'Сумма потерь']
  ]).setFontWeight('bold').setBackground('#FFD9D9');

  var rows = [];

  // Из архива
  var arch = getSheet_(SHEET_ARCHIVE).getDataRange().getValues();
  for (var i = 1; i < arch.length; i++) {
    var source = txt_(arch[i][COL_ARCH.SOURCE-1]);
    var status = txt_(arch[i][COL_ARCH.STATUS-1]);
    var reason = txt_(arch[i][COL_ARCH.REASON-1]);
    var archDate = arch[i][COL_ARCH.DATE-1];

    if (source !== 'Склад М') continue;
    if (status !== 'Обычный') continue;
    if (reason.indexOf('просрочен') === -1 && reason.indexOf('Просрочен') === -1) continue;
    if (archDate instanceof Date && !inPeriod_(archDate, d1, d2)) continue;

    var name = txt_(arch[i][COL_ARCH.NAME-1]);
    var serial = txt_(arch[i][COL_ARCH.SERIAL-1]);
    var expiry = arch[i][COL_ARCH.EXPIRY-1];
    var qty = num_(arch[i][COL_ARCH.QTY-1]);
    var price = num_(arch[i][COL_ARCH.PRICE-1]);
    if (!name || qty <= 0) continue;
    rows.push([name, serial || '-', expiry instanceof Date ? formatDate_(expiry) : '-', qty, qty * price]);
  }

  // Из Склада М — ещё не архивированные
  var stockM = getSheet_(SHEET_STOCK_M).getDataRange().getValues();
  var today = new Date(); today.setHours(0,0,0,0);
  for (var i = 1; i < stockM.length; i++) {
    var exp = stockM[i][COL_M.EXPIRY-1];
    if (!(exp instanceof Date)) continue;
    if (exp >= today) continue;
    if (!inPeriod_(exp, d1, d2)) continue;
    var name = txt_(stockM[i][COL_M.NAME-1]);
    var serial = txt_(stockM[i][COL_M.SERIAL-1]);
    var qty = num_(stockM[i][COL_M.BALANCE-1]);
    var price = num_(stockM[i][COL_M.PRICE-1]);
    if (!name || qty <= 0) continue;
    rows.push([name, serial || '-', formatDate_(exp), qty, qty * price]);
  }

  // Убираем дубли
  var unique = {};
  var deduped = [];
  for (var i = 0; i < rows.length; i++) {
    var key = rows[i][0] + '|' + rows[i][1] + '|' + rows[i][2];
    if (!unique[key]) { unique[key] = true; deduped.push(rows[i]); }
  }
  rows = deduped;

  var tQty = 0, tSum = 0;
  for (var i = 0; i < rows.length; i++) { tQty += rows[i][3]; tSum += rows[i][4]; }

  if (rows.length === 0) {
    sh.getRange(R + 1, 1).setValue('Просроченных позиций за период не найдено.').setFontStyle('italic');
    SpreadsheetApp.getActiveSpreadsheet().toast('Просроченных нет.', 'Отчёт', 3);
    return;
  }

  rows.push(['ИТОГО', '', '', tQty, tSum]);
  var end = writeBlock_(sh, R + 1, rows);
  sh.getRange(end - 1, 1, 1, 5).setFontWeight('bold');
  sh.getRange(end - 1, 5).setBackground('#FF6B6B').setFontColor('#FFFFFF');

  // График: потери по наименованиям
  if (rows.length > 2) {
    var topData = rows.slice(0, Math.min(10, rows.length - 1));
    topData.sort(function(a,b) { return b[4] - a[4]; });
    for (var i = 0; i < topData.length; i++) {
      sh.getRange(R + 1 + i, 7).setValue(topData[i][0]);
      sh.getRange(R + 1 + i, 8).setValue(topData[i][4]);
    }
    var gL = sh.getRange(R + 1, 7, topData.length, 1);
    var gV = sh.getRange(R + 1, 8, topData.length, 1);
    buildChart_(sh, gL, [gV], 'Потери от просроченных', {type: 'bar', position: {row: 2, col: 7}});
  }

  SpreadsheetApp.getActiveSpreadsheet().toast('Просроченных: ' + rows.length + ' позиций, потери: ' + tSum.toFixed(2), 'Отчёт', 5);
}

/**
 * Изменение цен за период — сравнение цен поступлений.
 * Столбцы: Наименование | Группа | Мин. цена | Макс. цена | Средняя | Кол-во поступлений
 */
function priceChangesReport_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var R = FIRST_ROW;

  sh.getRange(R, 1, 1, 14).setValues([
    ['Наименование', 'Группа', 'Закупок', 'Первая цена', 'Последняя', 'Дельта ₽', 'Дельта %',
     'Мин. цена', 'Макс. цена', 'Средняя', 'Поставщик (мин)', 'Цена (мин)', 'Поставщик (макс)', 'Цена (макс)']
  ]).setFontWeight('bold').setBackground('#1a237e').setFontColor('#FFFFFF');

  // Собираем все закупки: name => [{date, price, supplier, qty}]
  var purchases = {};

  var stockM = getSheet_(SHEET_STOCK_M).getDataRange().getValues();
  for (var i = 1; i < stockM.length; i++) {
    if (!inPeriod_(stockM[i][COL_M.DATE-1], d1, d2)) continue;
    var name = txt_(stockM[i][COL_M.NAME-1]);
    var price = num_(stockM[i][COL_M.PRICE-1]);
    var supplier = txt_(stockM[i][COL_M.SUPPLIER-1]) || 'Неизвестен';
    var date = stockM[i][COL_M.DATE-1];
    var qty = num_(stockM[i][COL_M.QTY-1]);
    if (!name || price <= 0) continue;
    if (!purchases[name]) purchases[name] = [];
    purchases[name].push({date: date, price: price, supplier: supplier, qty: qty});
  }

  var stockN = getSheet_(SHEET_STOCK_N).getDataRange().getValues();
  for (var i = 1; i < stockN.length; i++) {
    if (!inPeriod_(stockN[i][COL_N.DATE-1], d1, d2)) continue;
    var name = txt_(stockN[i][COL_N.NAME-1]);
    var price = num_(stockN[i][COL_N.PRICE-1]);
    var supplier = txt_(stockN[i][COL_N.SUPPLIER-1]) || 'Неизвестен';
    var date = stockN[i][COL_N.DATE-1];
    var qty = num_(stockN[i][COL_N.QTY-1]);
    if (!name || price <= 0) continue;
    if (!purchases[name]) purchases[name] = [];
    purchases[name].push({date: date, price: price, supplier: supplier, qty: qty});
  }

  var list = Object.keys(purchases).sort(function(a,b) { return a.localeCompare(b, 'ru'); });

  if (list.length === 0) {
    sh.getRange(R + 1, 1).setValue('Поступлений за период не найдено.').setFontStyle('italic');
    return;
  }

  var rows = [];
  for (var i = 0; i < list.length; i++) {
    var name = list[i];
    var plist = purchases[name];
    var grp = groupFor_(name) || 'Без группы';

    // Сортируем по дате
    plist.sort(function(a,b) {
      var da = a.date instanceof Date ? a.date.getTime() : 0;
      var db = b.date instanceof Date ? b.date.getTime() : 0;
      return da - db;
    });

    var firstPrice = plist[0].price;
    var lastPrice = plist[plist.length - 1].price;
    var delta = lastPrice - firstPrice;
    var deltaPct = firstPrice > 0 ? ((delta / firstPrice) * 100) : 0;

    var min = Infinity, max = 0, sum = 0;
    var minSupplier = '', maxSupplier = '', minPrice = 0, maxPrice = 0;

    for (var j = 0; j < plist.length; j++) {
      sum += plist[j].price;
      if (plist[j].price < min) {
        min = plist[j].price;
        minSupplier = plist[j].supplier;
        minPrice = plist[j].price;
      }
      if (plist[j].price > max) {
        max = plist[j].price;
        maxSupplier = plist[j].supplier;
        maxPrice = plist[j].price;
      }
    }
    var avg = sum / plist.length;

    rows.push([
      name, grp, plist.length,
      firstPrice, lastPrice, delta, deltaPct,
      min, max, avg,
      minSupplier, minPrice, maxSupplier, maxPrice
    ]);
  }

  var end = writeBlock_(sh, R + 1, rows);

  // Подсветка: дельта % — зелёный (подешевело), красный (подорожало)
  for (var r = R + 1; r < end; r++) {
    var deltaPctVal = sh.getRange(r, 7).getValue();
    if (deltaPctVal > 5) {
      sh.getRange(r, 5, 1, 3).setBackground('#FFCDD2').setFontColor('#C62828'); // подорожало
    } else if (deltaPctVal < -5) {
      sh.getRange(r, 5, 1, 3).setBackground('#C8E6C9').setFontColor('#2E7D32'); // подешевело
    }
  }

  // График: дельта % топ-10 по абсолютному изменению
  var chartRows = rows.slice();
  chartRows.sort(function(a,b) { return Math.abs(b[6]) - Math.abs(a[6]); });
  var topChart = chartRows.slice(0, Math.min(10, chartRows.length));

  if (topChart.length > 0) {
    for (var i = 0; i < topChart.length; i++) {
      sh.getRange(R + 1 + i, 16).setValue(topChart[i][0]);
      sh.getRange(R + 1 + i, 17).setValue(topChart[i][6]);
    }
    var gL = sh.getRange(R + 1, 16, topChart.length, 1);
    var gV = sh.getRange(R + 1, 17, topChart.length, 1);
    buildChart_(sh, gL, [gV], 'Изменение цен (%): топ-10 по колебанию', {type: 'bar', position: {row: 2, col: 16}});
  }

  SpreadsheetApp.getActiveSpreadsheet().toast('Изменение цен: ' + list.length + ' наименований.', 'Отчёт', 3);
}

/**
 * Изменение цен по группам — сводка колебаний цен в разрезе групп.
 * Столбцы: Группа | Кол-во наименований | Мин. цена | Макс. цена | Средняя | Кол-во поступлений
 */
function groupPriceChangesReport_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var R = FIRST_ROW;

  sh.getRange(R, 1, 1, 10).setValues([
    ['Группа', 'Наименований', 'Закупок', 'Общая сумма', 'Средняя цена',
     'Мин. средняя', 'Макс. средняя', 'Доля %', 'Тренд', 'Изм. средней %']
  ]).setFontWeight('bold').setBackground('#1a237e').setFontColor('#FFFFFF');

  // Собираем данные: name => {prices: [], supplier: {min: {price, name}, max: {price, name}}}
  var items = {};

  var stockM = getSheet_(SHEET_STOCK_M).getDataRange().getValues();
  for (var i = 1; i < stockM.length; i++) {
    if (!inPeriod_(stockM[i][COL_M.DATE-1], d1, d2)) continue;
    var name = txt_(stockM[i][COL_M.NAME-1]);
    var price = num_(stockM[i][COL_M.PRICE-1]);
    var date = stockM[i][COL_M.DATE-1];
    if (!name || price <= 0) continue;
    if (!items[name]) items[name] = { prices: [], dates: [] };
    items[name].prices.push(price);
    items[name].dates.push(date);
  }

  var stockN = getSheet_(SHEET_STOCK_N).getDataRange().getValues();
  for (var i = 1; i < stockN.length; i++) {
    if (!inPeriod_(stockN[i][COL_N.DATE-1], d1, d2)) continue;
    var name = txt_(stockN[i][COL_N.NAME-1]);
    var price = num_(stockN[i][COL_N.PRICE-1]);
    var date = stockN[i][COL_N.DATE-1];
    if (!name || price <= 0) continue;
    if (!items[name]) items[name] = { prices: [], dates: [] };
    items[name].prices.push(price);
    items[name].dates.push(date);
  }

  // Группируем по группам
  var byGroup = {};
  var nameList = Object.keys(items);
  for (var i = 0; i < nameList.length; i++) {
    var name = nameList[i];
    var grp = groupFor_(name) || 'Без группы';
    var it = items[name];

    if (!byGroup[grp]) byGroup[grp] = { names: {}, totalSpend: 0, totalCount: 0, avgPrices: [] };

    byGroup[grp].names[name] = true;
    byGroup[grp].totalCount += it.prices.length;

    // Средняя цена для этого наименования
    var nameSum = 0;
    for (var j = 0; j < it.prices.length; j++) nameSum += it.prices[j];
    var nameAvg = nameSum / it.prices.length;
    byGroup[grp].avgPrices.push(nameAvg);
    byGroup[grp].totalSpend += nameSum;
  }

  var grpList = Object.keys(byGroup).sort(function(a,b) { return a.localeCompare(b, 'ru'); });

  if (grpList.length === 0) {
    sh.getRange(R + 1, 1).setValue('Поступлений за период не найдено.').setFontStyle('italic');
    return;
  }

  // Общая сумма всех закупок
  var grandTotal = 0;
  for (var i = 0; i < grpList.length; i++) {
    grandTotal += byGroup[grpList[i]].totalSpend;
  }

  var rows = [];
  for (var i = 0; i < grpList.length; i++) {
    var grp = grpList[i];
    var gd = byGroup[grp];
    var namesCount = Object.keys(gd.names).length;

    // Средняя цена по группе (среднее от средних)
    var groupAvg = 0;
    for (var j = 0; j < gd.avgPrices.length; j++) groupAvg += gd.avgPrices[j];
    groupAvg = gd.avgPrices.length > 0 ? groupAvg / gd.avgPrices.length : 0;

    // Мин и макс средняя цена в группе
    var minAvg = Infinity, maxAvg = 0;
    for (var j = 0; j < gd.avgPrices.length; j++) {
      if (gd.avgPrices[j] < minAvg) minAvg = gd.avgPrices[j];
      if (gd.avgPrices[j] > maxAvg) maxAvg = gd.avgPrices[j];
    }
    if (minAvg === Infinity) minAvg = 0;

    // Доля от общих затрат
    var sharePct = grandTotal > 0 ? (gd.totalSpend / grandTotal * 100) : 0;

    // Тренд: сравниваем первую и вторую половину цен
    var allPrices = gd.avgPrices;
    var trend = '—';
    var trendChange = 0;
    if (allPrices.length >= 2) {
      var mid = Math.floor(allPrices.length / 2);
      var firstHalf = 0, secondHalf = 0;
      for (var j = 0; j < mid; j++) firstHalf += allPrices[j];
      for (var j = mid; j < allPrices.length; j++) secondHalf += allPrices[j];
      firstHalf = mid > 0 ? firstHalf / mid : 0;
      secondHalf = (allPrices.length - mid) > 0 ? secondHalf / (allPrices.length - mid) : 0;
      trendChange = firstHalf > 0 ? ((secondHalf - firstHalf) / firstHalf * 100) : 0;
      if (trendChange > 5) trend = 'Рост';
      else if (trendChange < -5) trend = 'Снижение';
      else trend = 'Стабильно';
    }

    rows.push([
      grp, namesCount, gd.totalCount, gd.totalSpend, groupAvg,
      minAvg, maxAvg, sharePct, trend, trendChange
    ]);
  }

  // Сортируем по общей сумме (самые дорогие сверху)
  rows.sort(function(a,b) { return b[3] - a[3]; });

  var end = writeBlock_(sh, R + 1, rows);

  // Подсветка тренда
  for (var r = R + 1; r < end; r++) {
    var trendVal = sh.getRange(r, 9).getValue();
    var trendChangeVal = sh.getRange(r, 10).getValue();
    if (trendVal === 'Рост') {
      sh.getRange(r, 9).setBackground('#FFCDD2').setFontColor('#C62828');
      sh.getRange(r, 10).setBackground('#FFCDD2').setFontColor('#C62828');
    } else if (trendVal === 'Снижение') {
      sh.getRange(r, 9).setBackground('#C8E6C9').setFontColor('#2E7D32');
      sh.getRange(r, 10).setBackground('#C8E6C9').setFontColor('#2E7D32');
    } else {
      sh.getRange(r, 9).setBackground('#E3F2FD').setFontColor('#1565C0');
    }
  }

  // График: общая сумма по группам (столбчатый)
  if (rows.length > 0) {
    for (var i = 0; i < rows.length; i++) {
      sh.getRange(R + 1 + i, 12).setValue(rows[i][0]);
      sh.getRange(R + 1 + i, 13).setValue(rows[i][3]);
    }
    var gL = sh.getRange(R + 1, 12, rows.length, 1);
    var gV = sh.getRange(R + 1, 13, rows.length, 1);
    buildChart_(sh, gL, [gV], 'Затраты по группам (общая сумма)', {type: 'bar', position: {row: 2, col: 12}});
  }

  SpreadsheetApp.getActiveSpreadsheet().toast('Изменение цен по группам: ' + grpList.length + ' групп.', 'Отчёт', 3);
}

