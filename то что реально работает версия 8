function acquireLock_() {
  var lock = LockService.getScriptLock();
  try {
    if (lock.tryLock(LOCK_TIMEOUT)) {
      return lock;
    }
    console.warn('Не удалось получить блокировку за ' + LOCK_TIMEOUT + 'мс');
    return null;
  } catch(e) {
    console.error('Ошибка блокировки: ' + e.message);
    return null;
  }
}

function releaseLock_(lock) {
  try {
    if (lock) lock.releaseLock();
  } catch(e) {
    console.warn('Ошибка освобождения блокировки: ' + e.message);
  }
}

