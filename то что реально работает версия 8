function getSheet_(name) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName(name);
  if (!sh) throw new Error('Лист "' + name + '" не найден!');
  return sh;
}

function getSheetOrNull_(name) {
  try { return getSheet_(name); } catch(e) { return null; }
}

function readSheet_(name) {
  return getSheet_(name).getDataRange().getValues();
}

function safeUi_() {
  try { return SpreadsheetApp.getUi(); } catch(e) { return null; }
}

function safeAlert_(msg) {
  const ui = safeUi_();
  if (ui) ui.alert(msg);
  else console.log('Alert: ' + msg);
}

function num_(v) {
  return (typeof v === 'number' && !isNaN(v)) ? v : 0;
}

function txt_(v) {
  return (v === null || v === undefined) ? '' : String(v).trim();
}

function normalizeStr(s) {
  if (s === undefined || s === null) return '';
  return String(s).replace(/\s+/g, ' ').trim().toLowerCase();
}

function normalizeDate(d) {
  if (!d) return '';
  var dateObj = toDateSafe_(d);
  return dateObj ? formatDate_(dateObj) : '';
}

function inPeriod_(d, d1, d2) {
  if (!(d instanceof Date)) return false;
  var t = d.getTime();
  return t >= d1.getTime() && t <= d2.getTime();
}

function formatDate_(date) {
  if (!date) return '—';
  if (date instanceof Date) {
    return Utilities.formatDate(date, Session.getScriptTimeZone(), 'dd.MM.yyyy');
  }
  return String(date);
}

function toDateSafe_(value) {
  if (!value) return null;
  if (value instanceof Date && !isNaN(value.getTime())) return value;
  if (typeof value === 'string') {
    var trimmed = value.trim();
    if (!trimmed) return null;
    var d = new Date(trimmed);
    if (!isNaN(d.getTime()) && d.getFullYear() >= 1900 && d.getFullYear() <= 2100) return d;
    var parts = trimmed.split('.');
    if (parts.length === 3) {
      var day = parseInt(parts[0], 10);
      var month = parseInt(parts[1], 10) - 1;
      var year = parseInt(parts[2], 10);
      if (!isNaN(day) && !isNaN(month) && !isNaN(year)) {
        if (year < 100) year += 2000;
        if (year >= 1900 && year <= 2100) {
          return new Date(Date.UTC(year, month, day));
        }
      }
    }
    var num = parseFloat(trimmed.replace(',', '.'));
    if (!isNaN(num) && num > 0 && num < 100000) {
      return new Date((num - EXCEL_EPOCH) * 86400 * 1000);
    }
    return null;
  }
  if (typeof value === 'number' && value > 0 && value < 100000) {
    return new Date((value - EXCEL_EPOCH) * 86400 * 1000);
  }
  return null;
}

function uniqueArray_(arr) {
  var seen = {}, out = [];
  arr.forEach(function(v) {
    if (v && !seen[v]) { seen[v] = true; out.push(v); }
  });
  return out.sort(function(a,b){ return a.localeCompare(b, 'ru'); });
}

function getLastRowInColumn_(sheet, col) {
  if (!sheet || !col) return sheet.getLastRow();
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return 1;
  var range = sheet.getRange(2, col, Math.max(1, lastRow - 1), 1);
  var values = range.getValues();
  for (var i = values.length - 1; i >= 0; i--) {
    var val = values[i][0];
    if (val !== '' && val !== null && val !== undefined) {
      return i + 2;
    }
  }
  return 1;
}

function isCabinetSheet_(name) {
  if (!name) return false;
  var reserved = [SHEET_STOCK_M, SHEET_STOCK_N, SHEET_JOURNAL_M, SHEET_JOURNAL_N,
                  SHEET_DOK, SHEET_ARCHIVE, SHEET_ORDERS, SHEET_FINANCE, SHEET_AUDIT, SHEET_BACKUP];
  if (reserved.indexOf(name) !== -1) return false;
  if (name.indexOf("Расход ") === 0) return false;
  return true;
}

function isKitSheet_(name) { return KIT_LIST.indexOf(name) >= 0; }

