function setDataValidationList(sheet, row, col, list) {
  if (!sheet || !row || !col) return;
  var cell = sheet.getRange(row, col);
  try { cell.setDataValidation(null); } catch(e) {}
  if (list && list.length > 0) {
    var unique = [];
    var seen = {};
    list.forEach(function(item) {
      var key = item.toString().trim();
      if (key && !seen[key]) { seen[key] = true; unique.push(key); }
    });
    if (unique.length) {
      var rule = SpreadsheetApp.newDataValidation()
        .requireValueInList(unique, true)
        .setAllowInvalid(true)
        .build();
      cell.setDataValidation(rule);
    }
  }
}

function clearDataValidation(sheet, row, col) {
  if (!sheet || !row || !col) return;
  try { sheet.getRange(row, col).setDataValidation(null); } catch(e) {}
}

function removeStockValidations() {
  try {
    var stockM = getSheet_(SHEET_STOCK_M);
    if (stockM) {
      var colsM = [COL_M.NAME, COL_M.FORM, COL_M.GROUP, COL_M.SUPPLIER];
      colsM.forEach(function(c) {
        var range = stockM.getRange(2, c, Math.max(1, stockM.getLastRow()-1), 1);
        range.setDataValidation(null);
      });
    }
    var stockN = getSheet_(SHEET_STOCK_N);
    if (stockN) {
      var colsN = [COL_N.NAME, COL_N.FORM, COL_N.GROUP, COL_N.SUPPLIER];
      colsN.forEach(function(c) {
        var range = stockN.getRange(2, c, Math.max(1, stockN.getLastRow()-1), 1);
        range.setDataValidation(null);
      });
    }
  } catch(e) { console.warn('Ошибка при удалении проверок: ' + e.message); }
}

