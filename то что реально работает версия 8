function archiveStockRow_(sheet, row, stockType) {
  if (row <= 0 || (stockType !== 'M' && stockType !== 'N')) {
    console.error('archiveStockRow_: неверные параметры');
    return;
  }

  var cols = (stockType === 'M') ? COL_M : COL_N;
  var name = sheet.getRange(row, cols.NAME).getValue();
  var serial = (stockType === 'M') ? (sheet.getRange(row, COL_M.SERIAL).getValue() || '') : '-';
  if (!name) return;

  var arch = getSheet_(SHEET_ARCHIVE);
  var now = new Date();
  var todayStr = formatDate_(now);

  // Проверка дубля
  var aData = arch.getDataRange().getValues();
  for (var i = 1; i < aData.length; i++) {
    var archDate = aData[i][COL_ARCH.DATE-1] instanceof Date ? formatDate_(aData[i][COL_ARCH.DATE-1]) : '';
    var archName = txt_(aData[i][COL_ARCH.NAME-1]);
    var archSerial = txt_(aData[i][COL_ARCH.SERIAL-1]);
    var archStatus = txt_(aData[i][COL_ARCH.STATUS-1]);

    if (archName === txt_(name) && archSerial === serial &&
        archStatus === 'Обычный' && archDate === todayStr) {
      console.log('archiveStockRow_: дубль для "' + name + '", пропускаем');
      return;
    }
  }

  var last = arch.getLastRow() + 1;
  var rowData = [
    now,
    stockType === 'M' ? 'Склад М' : 'Склад Н',
    sheet.getRange(row, cols.DATE).getValue(),
    name,
    sheet.getRange(row, cols.FORM).getValue(),
    sheet.getRange(row, cols.QTY).getValue(),
    serial,
    stockType === 'M' ? (sheet.getRange(row, COL_M.EXPIRY).getValue() || '-') : '-',
    sheet.getRange(row, cols.PRICE).getValue() || 0,
    sheet.getRange(row, cols.GROUP).getValue(),
    'Обычный',
    'Остаток = 0 или просрочен',
    '-',
    '-',
    '-',
    '-'
  ];

  arch.getRange(last, 1, 1, rowData.length).setValues([rowData]);
  arch.getRange(last, 1, 1, rowData.length).setBackground('#DCFFDC');

  auditLog_('ARCHIVE', stockType === 'M' ? SHEET_STOCK_M : SHEET_STOCK_N, row, 0, '', '',
    'Архивировано: ' + name + ', серия: ' + serial);
}

function archiveRow_(data) {
  var arch = getSheet_(SHEET_ARCHIVE);
  var last = arch.getLastRow() + 1;
  var rowData = [
    new Date(),
    data.source || 'Кабинет',
    data.date || '',
    data.drug || '',
    data.form || '',
    data.qty || 0,
    data.serial || '',
    data.exp || '',
    data.price || 0,
    data.group || '',
    data.status || 'списано',
    data.reason || '',
    data.cabinet || '',
    '-',
    '-',
    '-'
  ];
  arch.getRange(last, 1, 1, rowData.length).setValues([rowData]);
}

function archiveZeroBalances() {
  var lock = acquireLock_();
  if (!lock) {
    safeAlert_('Не удалось получить блокировку. Попробуйте позже.');
    return;
  }

  try {
    var sheets = [SHEET_STOCK_M, SHEET_STOCK_N];
    sheets.forEach(function(sheetName) {
      var sh = getSheet_(sheetName);
      var isM = (sheetName === SHEET_STOCK_M);
      var cols = isM ? COL_M : COL_N;
      var data = sh.getDataRange().getValues();
      var rowsToDelete = [];

      for (var i = 1; i < data.length; i++) {
        var bal = num_(data[i][cols.BALANCE-1]);
        if (bal === 0) {
          archiveStockRow_(sh, i+1, isM ? 'M' : 'N');
          rowsToDelete.push(i+1);
        }
      }

      // Удаление реверсом — O(n) вместо O(n^2)
      rowsToDelete.sort(function(a,b){return b-a;});
      for (var j = 0; j < rowsToDelete.length; j++) {
        sh.deleteRow(rowsToDelete[j]);
      }
    });

    recalculateStockM();
    recalculateStockN();
    safeAlert_('Архивация нулевых остатков завершена.');
  } catch(e) {
    console.error('Ошибка archiveZeroBalances: ' + e.message);
    auditLog_('ERROR', 'ARCHIVE', 0, 0, '', '', e.message);
  } finally {
    releaseLock_(lock);
  }
}

function archiveExpiredItems() {
  var lock = acquireLock_();
  if (!lock) {
    safeAlert_('Не удалось получить блокировку. Попробуйте позже.');
    return;
  }

  try {
    var stock = getSheet_(SHEET_STOCK_M);
    var data = stock.getDataRange().getValues();
    var today = new Date(); today.setHours(0,0,0,0);
    var rowsToDelete = [];

    for (var i = 1; i < data.length; i++) {
      var exp = data[i][COL_M.EXPIRY-1];
      if (!(exp instanceof Date)) continue;
      if (exp < today) {
        archiveStockRow_(stock, i+1, 'M');
        rowsToDelete.push(i+1);
      }
    }

    rowsToDelete.sort(function(a,b){return b-a;});
    for (var j = 0; j < rowsToDelete.length; j++) {
      stock.deleteRow(rowsToDelete[j]);
    }

    safeAlert_('Архивировано ' + rowsToDelete.length + ' просроченных позиций.');
  } catch(e) {
    console.error('Ошибка archiveExpiredItems: ' + e.message);
    auditLog_('ERROR', SHEET_STOCK_M, 0, 0, '', '', e.message);
  } finally {
    releaseLock_(lock);
  }
}

function archiveZeroCabinetRows() {
  var lock = acquireLock_();
  if (!lock) {
    safeAlert_('Не удалось получить блокировку. Попробуйте позже.');
    return;
  }

  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var sheets = ss.getSheets();

    for (var i = 0; i < sheets.length; i++) {
      var name = sheets[i].getName();
      if (isCabinetSheet_(name) || isKitSheet_(name)) {
        var sh = sheets[i];
        var cols = getCabinetColumns(sh);
        if (!cols || !cols.NAME || !cols.FINAL_BALANCE) continue;
        var data = sh.getDataRange().getValues();
        var rowsToDelete = [];

        for (var r = 1; r < data.length; r++) {
          var bal = num_(data[r][cols.FINAL_BALANCE-1]);
          if (bal === 0) {
            var drug = data[r][cols.NAME-1];
            var serial = data[r][cols.SERIAL-1] || '';
            var expiry = data[r][cols.EXPIRY-1] || '';
            var arrivalDate = data[r][cols.DATE-1] || '';
            archiveRow_({
              source: name,
              date: data[r][cols.DATE-1] || '',
              drug: drug,
              form: '',
              qty: num_(data[r][cols.QTY-1]),
              serial: serial,
              exp: expiry,
              price: num_(data[r][cols.PRICE-1]),
              group: '',
              status: 'списано',
              reason: 'Обнуление остатка в кабинете',
              cabinet: name
            });
            rowsToDelete.push(r+1);
          }
        }

        rowsToDelete.sort(function(a,b){return b-a;});
        for (var j = 0; j < rowsToDelete.length; j++) {
          sh.deleteRow(rowsToDelete[j]);
        }
      }
    }

    recalculateAllCabinets();
    safeAlert_('Архивация нулевых остатков в кабинетах завершена.');
  } catch(e) {
    console.error('Ошибка archiveZeroCabinetRows: ' + e.message);
    auditLog_('ERROR', 'CABINETS', 0, 0, '', '', e.message);
  } finally {
    releaseLock_(lock);
  }
}

function cleanArchiveMemory() {
  var lock = acquireLock_();
  if (!lock) {
    safeAlert_('Не удалось получить блокировку. Попробуйте позже.');
    return;
  }

  try {
    var arch = getSheet_(SHEET_ARCHIVE);
    var data = arch.getDataRange().getValues();
    var rowsToDelete = [];
    var seen = {};

    for (var i = 1; i < data.length; i++) {
      var name = txt_(data[i][COL_ARCH.NAME-1]);
      var serial = txt_(data[i][COL_ARCH.SERIAL-1]);
      var date = data[i][COL_ARCH.DATE-1] instanceof Date ? formatDate_(data[i][COL_ARCH.DATE-1]) : '';
      var status = txt_(data[i][COL_ARCH.STATUS-1]);
      var key = name + '|' + serial + '|' + date + '|' + status;

      if (seen[key]) {
        rowsToDelete.push(i+1);
      } else {
        seen[key] = true;
      }
    }

    rowsToDelete.sort(function(a,b){return b-a;});
    for (var j = 0; j < rowsToDelete.length; j++) {
      arch.deleteRow(rowsToDelete[j]);
    }

    safeAlert_('Архив очищен. Удалено дублей: ' + rowsToDelete.length);
  } catch(e) {
    console.error('Ошибка cleanArchiveMemory: ' + e.message);
    auditLog_('ERROR', SHEET_ARCHIVE, 0, 0, '', '', e.message);
  } finally {
    releaseLock_(lock);
  }
}

