function createTriggers() {
  try {
    var triggers = ScriptApp.getProjectTriggers();
  } catch(e) {
    console.warn('Нет прав на управление триггерами.');
    return;
  }

  var hasEdit = false, hasSelect = false, hasDaily = false;
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === 'onEdit') hasEdit = true;
    if (triggers[i].getHandlerFunction() === 'onSelectionChange') hasSelect = true;
    if (triggers[i].getHandlerFunction() === 'dailyArchive' && triggers[i].getEventType() === ScriptApp.EventType.CLOCK) hasDaily = true;
  }

  if (!hasEdit) {
    try {
      ScriptApp.newTrigger('onEdit')
        .forSpreadsheet(SpreadsheetApp.getActiveSpreadsheet())
        .onEdit()
        .create();
      console.log('Триггер onEdit создан.');
    } catch(e) {
      console.warn('Не удалось создать триггер onEdit: ' + e.message);
    }
  }

  if (!hasSelect) {
    try {
      ScriptApp.newTrigger('onSelectionChange')
        .forSpreadsheet(SpreadsheetApp.getActiveSpreadsheet())
        .onSelectionChange()
        .create();
      console.log('Триггер onSelectionChange создан.');
    } catch(e) {
      console.warn('Не удалось создать триггер onSelectionChange: ' + e.message);
    }
  }

  if (!hasDaily) {
    try {
      ScriptApp.newTrigger('dailyArchive')
        .timeBased()
        .everyDays(1)
        .atHour(2)
        .create();
      console.log('Триггер dailyArchive создан (ежедневно в 2:00).');
    } catch(e) {
      console.warn('Не удалось создать триггер dailyArchive: ' + e.message);
    }
  }
}

function dailyArchive() {
  var props = PropertiesService.getScriptProperties();
  var lastRun = props.getProperty('lastArchiveDate');
  var today = formatDate_(new Date());
  if (lastRun === today) {
    console.log('dailyArchive: уже выполнялся сегодня, пропускаем');
    return;
  }

  archiveExpiredItems();
  archiveZeroBalances();
  archiveZeroCabinetRows();
  recalculateAllCabinets();

  var day = new Date().getDay();
  if (day === 1) {
    cleanArchiveMemory();
  }

  props.setProperty('lastArchiveDate', today);
  console.log('dailyArchive: выполнен ' + today);
}

/**
 * ИСПРАВЛЕНО: onSelectionChange обновляет Info-панель только при смене наименования.
 * Раньше обновлялось при каждом выделении ячейки — лишние записи.
 */
function onSelectionChange(e) {
  if (!e) return;
  var range = e.range;
  var sheet = range.getSheet();
  var sheetName = sheet.getName();
  var row = range.getRow();
  var col = range.getColumn();

  if ((sheetName === SHEET_JOURNAL_M || sheetName === SHEET_JOURNAL_N) && col === 2 && row >= 2) {
    var drug = sheet.getRange(row, col).getValue();
    if (!drug) return;

    // Проверяем: обновлять Info-панель только если наименование изменилось
    if (!_lastInfoDrug) _lastInfoDrug = {};
    var cacheKey = sheetName + '|' + row;
    if (_lastInfoDrug[cacheKey] === drug) return; // то же самое наименование — пропускаем
    _lastInfoDrug[cacheKey] = drug;

    if (sheetName === SHEET_JOURNAL_M) showInfoOnSheetM(sheet, row);
    else showInfoOnSheetN(sheet, row);
  }
}

