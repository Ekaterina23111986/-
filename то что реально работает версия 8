// ============================================================

function createBackup() {
  var lock = acquireLock_();
  if (!lock) {
    console.warn('createBackup: не удалось получить блокировку');
    return;
  }

  try {
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    var backupName = ss.getName() + '_Backup_' + formatDate_(new Date()).replace(/\./g, '-');
    var backup = DriveApp.getFileById(ss.getId()).makeCopy(backupName);
    console.log('Бэкап создан: ' + backup.getUrl());
    auditLog_('BACKUP', 'DRIVE', 0, 0, '', '', 'Бэкап: ' + backup.getUrl());
  } catch(e) {
    console.error('Ошибка создания бэкапа: ' + e.message);
  } finally {
    releaseLock_(lock);
  }
}
