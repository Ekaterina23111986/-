  var drugNorm = normalizeStr(drug);
  var dateNorm = normalizeDate(arrivalDate);
  var totalBalance = 0;

  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][COL_N.NAME-1]);
    if (name !== drugNorm) continue;
    var d = normalizeDate(data[i][COL_N.DATE-1]);
    if (d !== dateNorm) continue;
    totalBalance += num_(data[i][COL_N.BALANCE-1]);
  }
  return totalBalance;
}

