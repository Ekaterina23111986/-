function buildIndex_(sheetName, colObj, nameCol) {
  var cacheKey = 'idx_' + sheetName;
  var now = Date.now();

  if (_cache[cacheKey] && (now - _cacheTimestamp) < CACHE_TTL * 1000) {
    return _cache[cacheKey];
  }

  try {
    var props = PropertiesService.getScriptProperties();
    var cached = props.getProperty(cacheKey);
    if (cached) {
      var parsed = JSON.parse(cached);
      if (parsed.timestamp && (now - parsed.timestamp) < CACHE_TTL * 1000) {
        _cache[cacheKey] = parsed.index;
        _cacheTimestamp = now;
        return parsed.index;
      }
    }
  } catch(e) {
    console.warn('Ошибка чтения кэша: ' + e.message);
  }

  var sheet = getSheet_(sheetName);
  var data = sheet.getDataRange().getValues();
  var index = {};

  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][nameCol - 1]);
    if (!name) continue;
    if (!index[name]) index[name] = [];
    index[name].push(i + 1);
  }

  _cache[cacheKey] = index;
  _cacheTimestamp = now;

  try {
    var props2 = PropertiesService.getScriptProperties();
    props2.setProperty(cacheKey, JSON.stringify({timestamp: now, index: index}));
  } catch(e) {
    console.warn('Ошибка сохранения кэша: ' + e.message);
  }

  return index;
}

function invalidateCache_(sheetName) {
  var cacheKey = 'idx_' + sheetName;
  delete _cache[cacheKey];
  try {
    var props = PropertiesService.getScriptProperties();
    props.deleteProperty(cacheKey);
  } catch(e) {
    console.warn('Ошибка удаления кэша: ' + e.message);
  }
}

function invalidateAllCaches_() {
  _cache = {};
  _cacheTimestamp = 0;
  try {
    var props = PropertiesService.getScriptProperties();
    var keys = props.getKeys();
    keys.forEach(function(k) {
      if (k.indexOf('idx_') === 0) props.deleteProperty(k);
    });
  } catch(e) {
    console.warn('Ошибка очистки кэша: ' + e.message);
  }
}

