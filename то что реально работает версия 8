function runReportFromDialog(params) {
  if (!params) { safeAlert_('Ошибка: параметры не переданы.'); return; }

  var type = params.reportType;

  // Тип "Текущие остатки" не требует дат
  if (type === 'Текущие остатки') {
    clearReportArea_();
    currentStockValues_();
    return;
  }

  // Все остальные типы требуют дат
  var dStart = params.dateStart ? new Date(params.dateStart) : null;
  var dEnd = params.dateEnd ? new Date(params.dateEnd) : null;

  if (!dStart || !dEnd || isNaN(dStart.getTime()) || isNaN(dEnd.getTime())) {
    safeAlert_('Укажите корректные даты периода (A3, B3)!');
    return;
  }
  if (dStart > dEnd) {
    safeAlert_('Дата начала позже окончания!');
    return;
  }

  clearReportArea_();

  switch (type) {
    case 'Полный расход по наименованиям':
      fullReportByName_(dStart, dEnd);
      break;
    case 'Полный расход по группам':
      fullReportByGroup_(dStart, dEnd);
      break;
    case 'Расход по кабинетам':
      reportByCabinet_(dStart, dEnd);
      break;
    case 'Расход на просроченные':
      expiredExpenses_(dStart, dEnd);
      break;
    case 'Прогноз расхода':
      var horizon = params.horizon || 3;
      forecast_(dStart, dEnd, horizon);
      break;
    case 'Изменение цен за период':
      priceChangesReport_(dStart, dEnd);
      break;
    case 'Изменение цен по группам':
      groupPriceChangesReport_(dStart, dEnd);
      break;
    default:
      safeAlert_('Неизвестный тип отчёта: ' + type);
  }

  auditLog_('REPORT', SHEET_FINANCE, 0, 0, '', '',
    'Отчёт: ' + type + ', ' + formatDate_(dStart) + ' - ' + formatDate_(dEnd));
}

