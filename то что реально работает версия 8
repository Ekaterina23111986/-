function undoIssue_(type) {
  var sheetName = (type === 'M') ? SHEET_JOURNAL_M : SHEET_JOURNAL_N;
  var sheet = SpreadsheetApp.getActiveSheet();
  if (sheet.getName() !== sheetName) {
    SpreadsheetApp.getUi().alert('Выберите строку на листе "' + sheetName + '"!');
    return;
  }
  var row = sheet.getActiveCell().getRow();
  if (row < 2) {
    SpreadsheetApp.getUi().alert('Выберите строку с данными (не заголовок)!');
    return;
  }

  var ui = SpreadsheetApp.getUi();
  var response = ui.alert('Отменить выдачу', 'Отменить выдачу в строке ' + row + '?', ui.ButtonSet.YES_NO);
  if (response !== ui.Button.YES) return;

  auditLog_('UNDO_ISSUE', sheetName, row, 0, '', '', 'Отмена выдачи');
  sheet.deleteRow(row);

  if (type === 'M') recalculateStockM();
  else recalculateStockN();

  ui.alert('Выдача отменена. Остаток на складе пересчитан.');
}

