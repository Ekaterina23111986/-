/**
 * Текущие остатки — сводка по всем складам и кабинетам.
 * Столбцы: Наименование | Источник | Остаток | Цена | Сумма
 */
function currentStockValues_() {
  var sh = getSheet_(SHEET_FINANCE);
  var R = FIRST_ROW;

  sh.getRange(R, 1, 1, 5).setValues([
    ['Наименование', 'Источник', 'Остаток', 'Цена', 'Сумма']
  ]).setFontWeight('bold').setBackground('#D9EAD3');

  var items = {};

  // Склад М
  var stockM = getSheet_(SHEET_STOCK_M).getDataRange().getValues();
  for (var i = 1; i < stockM.length; i++) {
    var name = txt_(stockM[i][COL_M.NAME-1]);
    var bal = num_(stockM[i][COL_M.BALANCE-1]);
    var price = num_(stockM[i][COL_M.PRICE-1]);
    if (!name || bal <= 0) continue;
    var key = normalizeStr(name) + '|Склад М';
    if (!items[key]) items[key] = { name: name, source: 'Склад М', qty: 0, price: price };
    items[key].qty += bal;
    if (price > items[key].price) items[key].price = price;
  }

  // Склад Н
  var stockN = getSheet_(SHEET_STOCK_N).getDataRange().getValues();
  for (var i = 1; i < stockN.length; i++) {
    var name = txt_(stockN[i][COL_N.NAME-1]);
    var bal = num_(stockN[i][COL_N.BALANCE-1]);
    var price = num_(stockN[i][COL_N.PRICE-1]);
    if (!name || bal <= 0) continue;
    var key = normalizeStr(name) + '|Склад Н';
    if (!items[key]) items[key] = { name: name, source: 'Склад Н', qty: 0, price: price };
    items[key].qty += bal;
    if (price > items[key].price) items[key].price = price;
  }

  // Кабинеты
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  for (var s = 0; s < sheets.length; s++) {
    var sName = sheets[s].getName();
    if (!isCabinetSheet_(sName) && !isKitSheet_(sName)) continue;
    var cols = getCabinetColumns(sheets[s]);
    if (!cols || !cols.NAME || !cols.FINAL_BALANCE) continue;
    var data = sheets[s].getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      var name = txt_(data[i][cols.NAME-1]);
      var bal = num_(data[i][cols.FINAL_BALANCE-1]);
      var price = cols.PRICE ? num_(data[i][cols.PRICE-1]) : priceFor_(name);
      if (!name || bal <= 0) continue;
      var key = normalizeStr(name) + '|' + sName;
      if (!items[key]) items[key] = { name: name, source: sName, qty: 0, price: price };
      items[key].qty += bal;
      if (price > items[key].price) items[key].price = price;
    }
  }

  var list = Object.keys(items).sort(function(a,b) {
    return items[a].name.localeCompare(items[b].name, 'ru');
  });

  var rows = [];
  var tQty = 0, tSum = 0;
  for (var i = 0; i < list.length; i++) {
    var it = items[list[i]];
    var sum = it.qty * it.price;
    rows.push([it.name, it.source, it.qty, it.price, sum]);
    tQty += it.qty;
    tSum += sum;
  }

  rows.push(['ИТОГО', '', tQty, '', tSum]);
  var end = writeBlock_(sh, R + 1, rows);
  sh.getRange(end - 1, 1, 1, 5).setFontWeight('bold');

  // График: топ-10 наименований по сумме
  if (rows.length > 2) {
    var topRows = rows.slice(0, Math.min(10, rows.length - 1));
    var chartData = [];
    for (var i = 0; i < topRows.length; i++) {
      chartData.push([topRows[i][0], topRows[i][4]]);
    }
    chartData.sort(function(a,b) { return b[1] - a[1]; });
    var chartLabels = chartData.map(function(r) { return [r[0]]; });
    var chartValues = chartData.map(function(r) { return [r[1]]; });

    var labelR = sh.getRange(R + 1, 1, chartLabels.length, 1);
    var valR = sh.getRange(R + 1, 5, chartValues.length, 1);
    // Временно записываем данные для графика
    for (var i = 0; i < chartLabels.length; i++) {
      sh.getRange(R + 1 + i, 7).setValue(chartLabels[i][0]);
      sh.getRange(R + 1 + i, 8).setValue(chartValues[i][0]);
    }
    var gLabels = sh.getRange(R + 1, 7, chartLabels.length, 1);
    var gValues = sh.getRange(R + 1, 8, chartValues.length, 1);
    buildChart_(sh, gLabels, [gValues], 'Топ-10 остатков по сумме', {type: 'bar', position: {row: 2, col: 7}});
  }

  SpreadsheetApp.getActiveSpreadsheet().toast('Текущие остатки: ' + list.length + ' позиций.', 'Отчёт', 3);
}

