/**
 * ИСПРАВЛЕНО: handleWriteOff_
 * - Сохраняет дату прихода в лист "Расход" (6-й столбец)
 * - Лист "Расход" теперь имеет 6 столбцов: Дата, Наименование, Серия, Срок, Количество, Дата прихода
 * - Явная валидация: qty > 0, qty <= finalBalance, arrivalDate существует
 */
function handleWriteOff_(sheet, row, value, cabinetName, col) {
  if (!cabinetName || !cabinetName.trim()) {
    cabinetName = sheet.getName();
  }

  var qty;
  if (typeof value === 'number') {
    qty = value;
  } else {
    var strVal = String(value).replace(',', '.').replace(/\s/g, '');
    qty = parseFloat(strVal);
  }

  if (isNaN(qty) || qty <= 0) {
    safeAlert_('Введите положительное число.');
    if (col) sheet.getRange(row, col).clearContent();
    return;
  }

  var cols = getCabinetColumns(sheet);
  if (!cols || !cols.NAME || !cols.QTY || !cols.FINAL_BALANCE) {
    safeAlert_('Не удалось определить структуру кабинета.');
    if (col) sheet.getRange(row, col).clearContent();
    return;
  }

  var name = sheet.getRange(row, cols.NAME).getValue();
  if (!name) {
    safeAlert_('Нет наименования.');
    if (col) sheet.getRange(row, col).clearContent();
    return;
  }

  var finalBalance = num_(sheet.getRange(row, cols.FINAL_BALANCE).getValue());
  if (qty > finalBalance) {
    safeAlert_('Недостаточно остатка! Доступно: ' + finalBalance);
    if (col) sheet.getRange(row, col).clearContent();
    return;
  }

  var serial = cols.SERIAL ? String(sheet.getRange(row, cols.SERIAL).getValue() || '').trim() : '';
  var expiry = cols.EXPIRY ? sheet.getRange(row, cols.EXPIRY).getValue() : '';
  if (typeof expiry === 'string') expiry = expiry.trim();
  var dateVal = cols.DATE ? sheet.getRange(row, cols.DATE).getValue() : new Date();
  // Дата прихода — ключевой столбец для списания
  var arrivalDate = cols.DATE ? sheet.getRange(row, cols.DATE).getValue() : new Date();
  if (!(dateVal instanceof Date)) dateVal = new Date();

  // Создаём/получаем лист истории
  var historyName = "Расход " + cabinetName;
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var historySheet = ss.getSheetByName(historyName);

  if (!historySheet) {
    historySheet = ss.insertSheet(historyName);
    // ИСПРАВЛЕНО: 6 столбцов — добавлен "Дата прихода"
    historySheet.getRange(1,1,1,EXPENSE_COLS_COUNT).setValues(
      [['Дата','Наименование','Серия','Срок','Количество','Дата прихода']]
    );
    historySheet.getRange(1,1,1,EXPENSE_COLS_COUNT).setFontWeight('bold');
    historySheet.hideSheet();
  }

  // Миграция: если лист старого формата (5 столбцов), расширяем до 6
  if (historySheet.getLastColumn() < EXPENSE_COLS_COUNT) {
    historySheet.getRange(1, EXPENSE_COLS_COUNT).setValue('Дата прихода').setFontWeight('bold');
  }

  auditLog_('WRITE_OFF', cabinetName, row, col, finalBalance, finalBalance - qty,
    'Списано ' + qty + ' ед. "' + name + '", серия: ' + serial);

  // ИСПРАВЛЕНО: сохраняем дату прихода в 6-й столбец
  historySheet.appendRow([dateVal, name.trim(), serial, expiry, qty, arrivalDate]);

  if (col) sheet.getRange(row, col).clearContent();

  recalculateCabinet(cabinetName);

  if (finalBalance - qty === 0) {
    addToOrders_(cabinetName, txt_(name), 0);
  }

  SpreadsheetApp.getActiveSpreadsheet().toast('Списано ' + qty + ' ед. "' + name + '"', 'Готово', 3);
}

