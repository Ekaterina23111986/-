function batchUpdateStockM_(sheet, issueMap) {
  var data = sheet.getDataRange().getValues();
  var balanceCol = COL_M.BALANCE;
  var updates = [];

  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][COL_M.NAME-1]);
    var serial = normalizeStr(data[i][COL_M.SERIAL-1]);
    var expiry = normalizeDate(data[i][COL_M.EXPIRY-1]);
    var initialQty = num_(data[i][COL_M.QTY-1]);
    var key = name + '|' + serial + '|' + expiry;
    var issued = issueMap[key] || 0;
    var balance = Math.max(0, initialQty - issued);
    updates.push([balance]);
  }

  if (updates.length > 0) {
    sheet.getRange(2, balanceCol, updates.length, 1).setValues(updates);
  }
}

function batchUpdateStockN_(sheet, issueMap) {
  var data = sheet.getDataRange().getValues();
  var balanceCol = COL_N.BALANCE;
  var updates = [];

  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][COL_N.NAME-1]);
    var arrivalDate = normalizeDate(data[i][COL_N.DATE-1]);
    var initialQty = num_(data[i][COL_N.QTY-1]);
    var key = name + '|' + arrivalDate;
    var issued = issueMap[key] || 0;
    var balance = Math.max(0, initialQty - issued);
    updates.push([balance]);
  }

  if (updates.length > 0) {
    sheet.getRange(2, balanceCol, updates.length, 1).setValues(updates);
  }
}

/**
 * ИСПРАВЛЕНО: ключ списания = Наименование + Дата прихода.
 * Раньше было: Наименование + Серия + Срок → для Склада Н (нет серии/срока)
 * все строки с одним именем получали одинаковый ключ и списание применялось ко всем.
 */
function batchUpdateCabinet_(sheet, writeOffMap, cols) {
  var data = sheet.getDataRange().getValues();
  var updates = [];

  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][cols.NAME - 1]);
    // Ключ = Наименование + Дата прихода (столбец DATE в кабинете = "Дата прихода")
    var arrivalDate = normalizeDate(data[i][cols.DATE - 1]);
    var initialQty = num_(data[i][cols.QTY - 1]);
    var key = name + '|' + arrivalDate;
    var writtenOff = writeOffMap[key] || 0;
    var balance = Math.max(0, initialQty - writtenOff);
    updates.push([balance]);
  }

  if (updates.length > 0 && cols.FINAL_BALANCE) {
    sheet.getRange(2, cols.FINAL_BALANCE, updates.length, 1).setValues(updates);
  }
}

