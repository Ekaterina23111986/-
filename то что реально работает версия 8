}

/**
 * Отчёт: Прогноз расхода
 * Учитывает: поступления → выдачи → списания, текущий остаток, дефицит
 */
function forecast_(d1, d2, horizon, filterGroup) {
  var sh = getSheet_(SHEET_FINANCE);
  if (!horizon || horizon < 1) horizon = 1;
  if (horizon > 12) horizon = 12;
  filterGroup = filterGroup ? txt_(filterGroup).toLowerCase() : '';

  var months = Math.max(1,
    (d2.getFullYear() - d1.getFullYear()) * 12 + (d2.getMonth() - d1.getMonth()) + 1);

  var received = {};
  var issued = {};
  var spent = {};
  var currentStock = {};

  // 1. Поступления на склад М и Н
  var stockM = readSheet_(SHEET_STOCK_M);
  for (var i = 1; i < stockM.length; i++) {
    var r = stockM[i];
    if (!inPeriod_(r[COL_M.DATE-1], d1, d2)) continue;
    var nm = txt_(r[COL_M.NAME-1]); if (!nm) continue;
    var q = num_(r[COL_M.QTY-1]), p = num_(r[COL_M.PRICE-1]);
    if (q <= 0) continue;
    if (!received[nm]) received[nm] = [0, 0, 0];
    received[nm][0] += q;
    received[nm][1] += q * p;
    if (p > received[nm][2]) received[nm][2] = p;
  }

  var stockN = readSheet_(SHEET_STOCK_N);
  for (var i = 1; i < stockN.length; i++) {
    var r = stockN[i];
    if (!inPeriod_(r[COL_N.DATE-1], d1, d2)) continue;
    var nm = txt_(r[COL_N.NAME-1]); if (!nm) continue;
    var q = num_(r[COL_N.QTY-1]), p = num_(r[COL_N.PRICE-1]);
    if (q <= 0) continue;
    if (!received[nm]) received[nm] = [0, 0, 0];
    received[nm][0] += q;
    received[nm][1] += q * p;
    if (p > received[nm][2]) received[nm][2] = p;
  }

  // 2. Выдачи из журналов М и Н
  var addIssue = function(data, C, type) {
    for (var i = 1; i < data.length; i++) {
      var r = data[i];
      if (!inPeriod_(r[C.DATE-1], d1, d2)) continue;
      var nm = txt_(r[C.NAME-1]); if (!nm) continue;
      var q = num_(r[C.QUANTITY-1]);
      if (q <= 0) continue;
      var p = 0;
      if (type === 'M') {
        p = getIssuePriceM_(nm, r[C.SERIAL-1], r[C.EXPIRY-1]);
      } else {
        p = num_(r[C.PRICE-1]);
      }
      if (!issued[nm]) issued[nm] = [0, 0];
      issued[nm][0] += q;
      issued[nm][1] += q * p;
    }
  };
  addIssue(readSheet_(SHEET_JOURNAL_M), COL_JM, 'M');
  addIssue(readSheet_(SHEET_JOURNAL_N), COL_JN, 'N');

  // 3. Списания из кабинетов (листы «Расход XXX»)
  var sheets = SpreadsheetApp.getActiveSpreadsheet().getSheets();
  for (var s = 0; s < sheets.length; s++) {
    var ws = sheets[s];
    var nm = ws.getName();
    if (nm.indexOf('Расход ') !== 0) continue;
    var data = ws.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      var name = txt_(data[i][1]); if (!name) continue;
      var q = num_(data[i][4]); if (q <= 0) continue;
      var pr = (received[name] && received[name][2] > 0) ? received[name][2] : (avgIssuePrice_(name, d1, d2) || priceFor_(name));
      if (!pr) continue;
      if (!spent[name]) spent[name] = [0, 0];
      spent[name][0] += q;
      spent[name][1] += q * pr;
    }
  }

  // 4. Текущие остатки
  for (var i = 1; i < stockM.length; i++) {
    var nm = txt_(stockM[i][COL_M.NAME-1]);
    var bal = num_(stockM[i][COL_M.BALANCE-1]);
    var p = num_(stockM[i][COL_M.PRICE-1]);
    if (!nm || bal <= 0) continue;
    if (!currentStock[nm]) currentStock[nm] = [0, 0];
    currentStock[nm][0] += bal;
    currentStock[nm][1] += bal * p;
  }
  for (var i = 1; i < stockN.length; i++) {
    var nm = txt_(stockN[i][COL_N.NAME-1]);
    var bal = num_(stockN[i][COL_N.BALANCE-1]);
    var p = num_(stockN[i][COL_N.PRICE-1]);
    if (!nm || bal <= 0) continue;
    if (!currentStock[nm]) currentStock[nm] = [0, 0];
    currentStock[nm][0] += bal;
    currentStock[nm][1] += bal * p;
  }
  for (var s = 0; s < sheets.length; s++) {
    var ws = sheets[s];
    var cabName = ws.getName();
    if (!isCabinetSheet_(cabName) && !isKitSheet_(cabName)) continue;
    var cols = getCabinetColumns(ws);
    if (!cols || !cols.NAME || !cols.FINAL_BALANCE) continue;
    var data = ws.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      var nm = txt_(data[i][cols.NAME-1]);
      var bal = num_(data[i][cols.FINAL_BALANCE-1]);
      if (!nm || bal <= 0) continue;
      if (!currentStock[nm]) currentStock[nm] = [0, 0];
      currentStock[nm][0] += bal;
      var pr = priceFor_(nm) || 0;
      currentStock[nm][1] += bal * pr;
    }
  }

  // Собираем все наименования
  var namesSet = {};
  Object.keys(received).forEach(function(k){ namesSet[k]=1; });
  Object.keys(issued).forEach(function(k){ namesSet[k]=1; });
  Object.keys(spent).forEach(function(k){ namesSet[k]=1; });
  Object.keys(currentStock).forEach(function(k){ namesSet[k]=1; });

  var list = Object.keys(namesSet).sort(function(a,b){ return a.localeCompare(b, 'ru'); });

  if (filterGroup) {
    list = list.filter(function(nm) {
      var grp = txt_(groupFor_(nm)).toLowerCase();
      return grp === filterGroup;
    });
  }

  if (!list.length) {
    SpreadsheetApp.getUi().alert('Нет данных для прогноза' + (filterGroup ? ' по группе "' + filterGroup + '"' : '') + '!');
    return;
  }

  var R = FIRST_ROW;
  sh.getRange(R,1,1,10).setValues([
    ['Наименование','Группа','Поступление/мес','Выдача/мес','Списание/мес',
     'Тек. остаток','Прогноз кол-во','Прогноз сумма (макс. цена)','Дефицит','Макс. цена закупки']
  ]).setFontWeight('bold').setHorizontalAlignment('center');

  var rows = [];
  var tRecQ=0, tIssQ=0, tSpQ=0, tStock=0, tFQty=0, tFSum=0, tDef=0;

  for (var i = 0; i < list.length; i++) {
    var nm = list[i];
    var grp = groupFor_(nm) || 'Без группы';

    var rec = received[nm] || [0, 0, 0];
    var iss = issued[nm] || [0, 0];
    var sp = spent[nm] || [0, 0];
    var stk = currentStock[nm] || [0, 0];

    var recPerMonth = rec[0] / months;
    var issPerMonth = iss[0] / months;
    var spPerMonth = sp[0] / months;

    var fQty = spPerMonth * horizon;
    var maxPrice = rec[2] || priceFor_(nm) || 0;
    var fSum = fQty * maxPrice;
    var deficit = Math.max(0, fQty - stk[0]);

    rows.push([nm, grp, recPerMonth, issPerMonth, spPerMonth, stk[0], fQty, fSum, deficit, maxPrice]);

    tRecQ += recPerMonth;
    tIssQ += issPerMonth;
    tSpQ += spPerMonth;
    tStock += stk[0];
    tFQty += fQty;
    tFSum += fSum;
    tDef += deficit;
  }

  rows.push(['ИТОГО','', tRecQ, tIssQ, tSpQ, tStock, tFQty, tFSum, tDef, '']);

  var end = writeBlock_(sh, R+1, rows);
  sh.getRange(end-1,1,1,10).setFontWeight('bold');

  // Цветовая подсветка дефицита
  var deficitCol = 9;
  var stockCol = 6;
  var forecastQtyCol = 7;
  var dataStartRow = R + 1;
  var dataEndRow = end - 2;

  for (var r = dataStartRow; r <= dataEndRow; r++) {
    var deficitVal = sh.getRange(r, deficitCol).getValue();
    if (deficitVal > 0) {
      sh.getRange(r, deficitCol).setBackground('#FF6B6B').setFontColor('#FFFFFF').setFontWeight('bold');
      sh.getRange(r, 1, 1, 2).setBackground('#FFE0E0');
    } else if (deficitVal === 0) {
      sh.getRange(r, deficitCol).setBackground('#C8E6C9').setFontColor('#2E7D32');
    }

    var stockVal = sh.getRange(r, stockCol).getValue();
    var fQtyVal = sh.getRange(r, forecastQtyCol).getValue();
    if (stockVal < fQtyVal && stockVal > 0) {
      sh.getRange(r, stockCol).setBackground('#FFF3CD').setFontColor('#856404');
    } else if (stockVal === 0 && fQtyVal > 0) {
      sh.getRange(r, stockCol).setBackground('#FFDAB9').setFontColor('#D84315');
    }
  }

  if (tDef > 0) {
    sh.getRange(end-1, deficitCol).setBackground('#FF6B6B').setFontColor('#FFFFFF').setFontWeight('bold');
  } else {
    sh.getRange(end-1, deficitCol).setBackground('#C8E6C9').setFontColor('#2E7D32');
  }

  if (rows.length > 1) {
    buildChart_(sh,
      sh.getRange(R+1,1,rows.length-1,1),
      [sh.getRange(R+1,8,rows.length-1,1)],
      'Прогноз расхода на ' + horizon + ' мес. (по макс. цене закупки)' +
      (filterGroup ? ' — Группа: ' + filterGroup : ''));
  }

  auditLog_('REPORT', SHEET_FINANCE, 0, 0, '', '',
    'Прогноз: ' + formatDate_(d1) + ' - ' + formatDate_(d2) + ', горизонт: ' + horizon + ' мес.');
}

function getGroupsForForecastFilter_() {
  var groups = {};
  var dok = readSheet_(SHEET_DOK);
  for (var i = 1; i < dok.length; i++) {
    var grp = txt_(dok[i][4]);
    if (grp) groups[grp] = true;
  }
  var stockM = readSheet_(SHEET_STOCK_M);
  for (var i = 1; i < stockM.length; i++) {
    var grp = txt_(stockM[i][COL_M.GROUP-1]);
    if (grp) groups[grp] = true;
  }
  var stockN = readSheet_(SHEET_STOCK_N);
  for (var i = 1; i < stockN.length; i++) {
    var grp = txt_(stockN[i][COL_N.GROUP-1]);
    if (grp) groups[grp] = true;
  }
  return Object.keys(groups).sort(function(a,b){ return a.localeCompare(b, 'ru'); });
}

function runForecastWithGroupFilter() {
  var ui = SpreadsheetApp.getUi();
  var groups = getGroupsForForecastFilter_();

  if (!groups.length) {
    ui.alert('Группы не найдены. Справочник «Док» пуст?');
    return;
  }

  var groupList = groups.join('\n');
  var response = ui.prompt(
    'Фильтр по группе',
    'Доступные группы:\n\n' + groupList + '\n\nВведите название группы (или оставьте пустым для всех):',
    ui.ButtonSet.OK_CANCEL
  );
  if (response.getSelectedButton() !== ui.Button.OK) return;

  var filterGroup = txt_(response.getResponseText());
  var sh = getSheet_(SHEET_FINANCE);
  var d1 = toDateSafe_(sh.getRange(CELL_DATE_START).getValue());
  var d2 = toDateSafe_(sh.getRange(CELL_DATE_END).getValue());
  var horizon = parseInt(sh.getRange(CELL_HORIZON).getValue()) || 3;

  if (!d1 || !d2) {
    ui.alert('Укажите даты начала и окончания периода (A3, B3) на листе «Финансовый отчёт»!');
    return;
  }

  clearReportArea_();
  forecast_(d1, d2, horizon, filterGroup);
}

