function returnFromArchive() {
  var sheet = SpreadsheetApp.getActiveSheet();
  if (sheet.getName() !== SHEET_ARCHIVE) {
    SpreadsheetApp.getUi().alert('Выберите строку на листе "Архив"!');
    return;
  }
  var row = sheet.getActiveCell().getRow();
  if (row < 2) {
    SpreadsheetApp.getUi().alert('Выберите строку с данными!');
    return;
  }

  var ui = SpreadsheetApp.getUi();
  var response = ui.alert('Вернуть из архива', 'Восстановить выбранную запись?', ui.ButtonSet.YES_NO);
  if (response !== ui.Button.YES) return;

  var data = sheet.getRange(row, 1, 1, sheet.getLastColumn()).getValues()[0];
  var source = txt_(data[COL_ARCH.SOURCE-1]);
  var name = txt_(data[COL_ARCH.NAME-1]);
  var form = txt_(data[COL_ARCH.FORM-1]);
  var qty = num_(data[COL_ARCH.QTY-1]);
  var serial = txt_(data[COL_ARCH.SERIAL-1]);
  var expiry = data[COL_ARCH.EXPIRY-1];
  var price = num_(data[COL_ARCH.PRICE-1]);
  var group = txt_(data[COL_ARCH.GROUP-1]);
  var arriveDate = data[COL_ARCH.ARRIVE-1];
  var cabinetName = txt_(data[COL_ARCH.CABINET-1]);

  if (!name || qty <= 0) {
    ui.alert('Ошибка: недостаточно данных для восстановления.');
    return;
  }

  var ss = SpreadsheetApp.getActiveSpreadsheet();

  if (source === 'Склад М' || source === 'Склад Н') {
    var stockSheetName = (source === 'Склад М') ? SHEET_STOCK_M : SHEET_STOCK_N;
    var stockSheet = ss.getSheetByName(stockSheetName);
    if (!stockSheet) {
      ui.alert('Лист "' + stockSheetName + '" не найден!');
      return;
    }

    var cols = (source === 'Склад М') ? COL_M : COL_N;
    var rowData = [];
    var lastCol = stockSheet.getLastColumn();
    for (var i = 0; i < lastCol; i++) rowData.push('');
    rowData[cols.DATE - 1] = arriveDate || new Date();
    rowData[cols.NAME - 1] = name;
    if (cols.FORM) rowData[cols.FORM - 1] = form;
    rowData[cols.QTY - 1] = qty;
    if (cols.SERIAL) rowData[cols.SERIAL - 1] = serial;
    if (cols.EXPIRY) rowData[cols.EXPIRY - 1] = expiry;
    rowData[cols.PRICE - 1] = price;
    if (cols.GROUP) rowData[cols.GROUP - 1] = group;

    stockSheet.appendRow(rowData);
    ui.alert('Препарат "' + name + '" восстановлен на склад "' + source + '".');

    if (source === 'Склад М') recalculateStockM();
    else recalculateStockN();

  } else if (source === 'Кабинет' && cabinetName) {
    var targetSheet = ss.getSheetByName(cabinetName);
    if (!targetSheet) {
      ui.alert('Кабинет "' + cabinetName + '" не найден!');
      return;
    }

    var cabCols = getCabinetColumns(targetSheet);
    if (!cabCols || !cabCols.NAME || !cabCols.QTY) {
      ui.alert('Не удалось определить структуру кабинета.');
      return;
    }

    var cabRowData = [];
    var cabLastCol = targetSheet.getLastColumn();
    for (var k = 0; k < cabLastCol; k++) cabRowData.push('');
    cabRowData[cabCols.DATE - 1] = arriveDate || new Date();
    cabRowData[cabCols.NAME - 1] = name;
    cabRowData[cabCols.QTY - 1] = qty;
    if (cabCols.SERIAL) cabRowData[cabCols.SERIAL - 1] = serial;
    if (cabCols.EXPIRY) cabRowData[cabCols.EXPIRY - 1] = expiry;
    if (cabCols.PRICE) cabRowData[cabCols.PRICE - 1] = price;

    targetSheet.appendRow(cabRowData);
    ui.alert('Препарат "' + name + '" восстановлен в кабинет "' + cabinetName + '".');
    recalculateCabinet(cabinetName);
  } else {
    ui.alert('Неизвестный источник или кабинет не указан.');
    return;
  }

  var deleteResponse = ui.alert('Удалить запись из архива?', 'После восстановления удалить из архива?', ui.ButtonSet.YES_NO);
  if (deleteResponse === ui.Button.YES) {
    auditLog_('RESTORE_AND_DELETE', SHEET_ARCHIVE, row, 0, '', '', 'Восстановление и удаление из архива');
    sheet.deleteRow(row);
    ui.alert('Запись удалена из архива.');
  } else {
    auditLog_('RESTORE', SHEET_ARCHIVE, row, 0, '', '', 'Восстановление из архива');
    sheet.getRange(row, COL_ARCH.STATUS).setValue('Восстановлено');
    sheet.getRange(row, COL_ARCH.REASON).setValue('Восстановлено ' + formatDate_(new Date()));
  }
}

