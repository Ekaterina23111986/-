function priceFor_(name) {
  var sum=0, cnt=0;
  var m = getSheet_(SHEET_STOCK_M).getDataRange().getValues();
  for (var i=1; i<m.length; i++) {
    if (txt_(m[i][COL_M.NAME-1]) === name) {
      var p = num_(m[i][COL_M.PRICE-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  var n = getSheet_(SHEET_STOCK_N).getDataRange().getValues();
  for (var i=1; i<n.length; i++) {
    if (txt_(n[i][COL_N.NAME-1]) === name) {
      var p = num_(n[i][COL_N.PRICE-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  return cnt ? sum/cnt : 0;
}

function groupFor_(name) {
  var doc = getSheet_(SHEET_DOK).getDataRange().getValues();
  for (var i=1; i<doc.length; i++) {
    if (txt_(doc[i][0]) === name) return txt_(doc[i][4]);
  }
  return '';
}

function formFor_(name) {
  var doc = getSheet_(SHEET_DOK).getDataRange().getValues();
  for (var i=1; i<doc.length; i++) {
    if (txt_(doc[i][0]) === name) return txt_(doc[i][5]);
  }
  return '';
}

function getIssuePriceM_(name, serial, expiry) {
  if (!name) return 0;
  var stock = getSheet_(SHEET_STOCK_M);
  var data = stock.getDataRange().getValues();
  var nameNorm = normalizeStr(name);
  var serialNorm = normalizeStr(serial);
  var expiryNorm = normalizeDate(expiry);
  for (var i = 1; i < data.length; i++) {
    if (normalizeStr(data[i][COL_M.NAME-1]) === nameNorm &&
        normalizeStr(data[i][COL_M.SERIAL-1]) === serialNorm &&
        normalizeDate(data[i][COL_M.EXPIRY-1]) === expiryNorm) {
      return num_(data[i][COL_M.PRICE-1]);
    }
  }
  return 0;
}

function getIssuePriceN_(name, arrivalDate) {
  if (!name || !arrivalDate) return 0;
  var stock = getSheet_(SHEET_STOCK_N);
  var data = stock.getDataRange().getValues();
  var nameNorm = normalizeStr(name);
  var dateNorm = normalizeDate(arrivalDate);
  for (var i = 1; i < data.length; i++) {
    if (normalizeStr(data[i][COL_N.NAME-1]) === nameNorm &&
        normalizeDate(data[i][COL_N.DATE-1]) === dateNorm) {
      return num_(data[i][COL_N.PRICE-1]);
    }
  }
  return 0;
}

function avgIssuePrice_(name, d1, d2) {
  var sum=0, cnt=0;
  var jm = getSheet_(SHEET_JOURNAL_M).getDataRange().getValues();
  for (var i=1; i<jm.length; i++) {
    if (inPeriod_(jm[i][COL_JM.DATE-1], d1, d2) && txt_(jm[i][COL_JM.NAME-1]) === name) {
      var p = getIssuePriceM_(name, jm[i][COL_JM.SERIAL-1], jm[i][COL_JM.EXPIRY-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  var jn = getSheet_(SHEET_JOURNAL_N).getDataRange().getValues();
  for (var i=1; i<jn.length; i++) {
    if (inPeriod_(jn[i][COL_JN.DATE-1], d1, d2) && txt_(jn[i][COL_JN.NAME-1]) === name) {
      var p = num_(jn[i][COL_JN.PRICE-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  return cnt ? sum/cnt : 0;
}

function writeBlock_(sheet, startRow, matrix) {
  if (!matrix || !matrix.length) return startRow;
  var rng = sheet.getRange(startRow, 1, matrix.length, matrix[0].length);
  rng.setValues(matrix);
  rng.setBorder(true, true, true, true, true, true);
  return startRow + matrix.length;
}

function buildChart_(sheet, labelRange, valueRanges, title, opts) {
  opts = opts || {};
  var chartType = opts.type || 'column';
  var pos = opts.position || {row: 2, col: 10};
  var width = opts.width || 700;
  var height = opts.height || 400;

  var builder = sheet.newChart();
  if (chartType === 'pie') builder = builder.asPieChart();
  else if (chartType === 'bar') builder = builder.asBarChart();
  else if (chartType === 'line') builder = builder.asLineChart();
  else builder = builder.asColumnChart();

  builder.addRange(labelRange);
  valueRanges.forEach(function(r) { builder.addRange(r); });

  var chart = builder
    .setPosition(pos.row, pos.col, 0, 0)
    .setOption('title', title)
    .setOption('width', width)
    .setOption('height', height)
    .setOption('legend', {position: valueRanges.length > 1 ? 'top' : 'none'})
    .setOption('pieSliceText', 'percentage')
    .setOption('sliceVisibilityThreshold', 0.02)
    .build();
  sheet.insertChart(chart);
}

function clearReportArea_() {
  var sh = getSheet_(SHEET_FINANCE);
