function auditLog_(action, sheet, row, col, oldVal, newVal, details) {
  try {
    ensureAuditSheet_();
    var auditSheet = getSheet_(SHEET_AUDIT);
    var lastRow = auditSheet.getLastRow() + 1;
    var user = Session.getActiveUser().getEmail() || 'unknown';
    var timestamp = new Date();
    auditSheet.getRange(lastRow, COL_AUDIT.TIMESTAMP).setValue(timestamp);
    auditSheet.getRange(lastRow, COL_AUDIT.USER).setValue(user);
    auditSheet.getRange(lastRow, COL_AUDIT.ACTION).setValue(action);
    auditSheet.getRange(lastRow, COL_AUDIT.SHEET).setValue(sheet);
    auditSheet.getRange(lastRow, COL_AUDIT.ROW).setValue(row);
    auditSheet.getRange(lastRow, COL_AUDIT.COLUMN).setValue(col);
    auditSheet.getRange(lastRow, COL_AUDIT.OLD_VALUE).setValue(String(oldVal || ''));
    auditSheet.getRange(lastRow, COL_AUDIT.NEW_VALUE).setValue(String(newVal || ''));
    auditSheet.getRange(lastRow, COL_AUDIT.DETAILS).setValue(details || '');
  } catch(e) {
    console.error('Ошибка audit log: ' + e.message);
  }
}

function ensureAuditSheet_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(SHEET_AUDIT);
  if (!sheet) {
    sheet = ss.insertSheet(SHEET_AUDIT);
    var headers = ['Timestamp','User','Action','Sheet','Row','Column','Old Value','New Value','Details'];
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.getRange(1, 1, 1, headers.length).setFontWeight('bold').setBackground('#D9EAD3');
    sheet.hideSheet();
  }
  return sheet;
}

