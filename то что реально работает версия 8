function addToOrders_(cabinet, name, qty) {
  if (!cabinet || !name) {
    console.warn('addToOrders_: пропущен вызов');
    return false;
  }

  var orders = getSheet_(SHEET_ORDERS);
  var data = orders.getDataRange().getValues();
  var cabinetNorm = txt_(cabinet);
  var nameNorm = txt_(name);

  for (var i = 1; i < data.length; i++) {
    var ordCabinet = txt_(data[i][COL_ORD.CABINET - 1]);
    var ordName = txt_(data[i][COL_ORD.NAME - 1]);
    var ordStatus = txt_(data[i][COL_ORD.STATUS - 1]).toLowerCase();

    if (ordCabinet === cabinetNorm && ordName === nameNorm) {
      if (ordStatus !== 'выполнен' && ordStatus !== 'отменен' && ordStatus !== 'закрыт') {
        console.log('addToOrders_: активная заявка уже существует');
        return false;
      }
    }
  }

  orders.appendRow([new Date(), cabinetNorm, nameNorm, qty || 0, 'Требуется заказ']);
  auditLog_('ORDER_CREATED', SHEET_ORDERS, 0, 0, '', '',
    'Заявка: ' + nameNorm + ' в ' + cabinetNorm);
  return true;
}

function generateOrders() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  var count = 0;

  for (var i = 0; i < sheets.length; i++) {
    var sheet = sheets[i];
    var name = sheet.getName();
    if (!isCabinetSheet_(name) && !isKitSheet_(name)) continue;

    var cols = getCabinetColumns(sheet);
    if (!cols || !cols.NAME || !cols.FINAL_BALANCE) continue;

    var data = sheet.getDataRange().getValues();
    for (var r = 1; r < data.length; r++) {
      var drug = txt_(data[r][cols.NAME - 1]);
      if (!drug) continue;
      var balance = num_(data[r][cols.FINAL_BALANCE - 1]);
      if (balance === 0) {
        if (addToOrders_(name, drug, 0)) {
          count++;
        }
      }
    }
  }

  SpreadsheetApp.getActiveSpreadsheet().toast('Сформировано ' + count + ' заявок.', 'Заказы', 3);
  safeAlert_('Сформировано ' + count + ' заявок на закупку.');
}

function createOrderSheet_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName(SHEET_ORDERS);
  if (!sheet) {
    sheet = ss.insertSheet(SHEET_ORDERS);
    var headers = ["Дата", "Кабинет", "Наименование", "Количество", "Статус"];
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.getRange(1, 1, 1, headers.length).setFontWeight('bold').setBackground('#D9EAD3');
    sheet.autoResizeColumns(1, headers.length);
  }
  return sheet;
}

