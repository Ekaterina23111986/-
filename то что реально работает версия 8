function clearAllData() {
  var ui = SpreadsheetApp.getUi();
  var response = ui.alert('Очистка данных', 'Будут удалены ВСЕ данные. Продолжить?', ui.ButtonSet.YES_NO);
  if (response !== ui.Button.YES) return;

  // Двойное подтверждение
  var response2 = ui.alert('ВНИМАНИЕ', 'Вы уверены? Это действие необратимо!', ui.ButtonSet.YES_NO);
  if (response2 !== ui.Button.YES) return;

  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheetsToClean = [SHEET_STOCK_M, SHEET_STOCK_N, SHEET_JOURNAL_M, SHEET_JOURNAL_N, SHEET_ARCHIVE, SHEET_ORDERS];

  sheetsToClean.forEach(function(sheetName) {
    var sheet = ss.getSheetByName(sheetName);
    if (!sheet) return;
    var lastRow = sheet.getLastRow();
    if (lastRow >= 2) {
      sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn()).clear({contentsOnly: true});
    }
  });

  var allSheets = ss.getSheets();
  allSheets.forEach(function(sheet) {
    var name = sheet.getName();
    if (isCabinetSheet_(name) || isKitSheet_(name) || name.indexOf('Расход ') === 0) {
      var lastRow = sheet.getLastRow();
      if (lastRow >= 2) {
        sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn()).clear({contentsOnly: true});
      }
    }
  });

  var finSheet = ss.getSheetByName(SHEET_FINANCE);
  if (finSheet) {
    var lastRow = finSheet.getLastRow();
    if (lastRow >= FIRST_ROW) {
      finSheet.getRange(FIRST_ROW, 1, lastRow - FIRST_ROW + 1, 50).clear({contentsOnly: true, formatOnly: true});
    }
  }

  recalculateStockM();
  recalculateStockN();
  recalculateAllCabinets();
  invalidateAllCaches_();

  auditLog_('CLEAR_ALL', 'ALL', 0, 0, '', '', 'Полная очистка данных');
  ui.alert('Очистка завершена. Все данные удалены, структура сохранена.');
}

function checkAllExpiryDates() {
  var stock = getSheet_(SHEET_STOCK_M);
  var data = stock.getDataRange().getValues();
  var expired = [], soon = [];
  var today = new Date(); today.setHours(0,0,0,0);

  for (var i = 1; i < data.length; i++) {
    var exp = data[i][COL_M.EXPIRY-1];
    if (!(exp instanceof Date)) continue;
    var days = Math.floor((exp - today) / (1000*60*60*24));
    if (days < 0) {
      expired.push({name: data[i][COL_M.NAME-1], serial: data[i][COL_M.SERIAL-1], exp: exp});
    } else if (days < 90) {
      soon.push({name: data[i][COL_M.NAME-1], serial: data[i][COL_M.SERIAL-1], exp: exp});
    }
  }

  var msg = '';
  if (expired.length) msg += 'Просрочено: ' + expired.length + ' позиций.\n';
  if (soon.length) msg += 'Осталось <90 дней: ' + soon.length + ' позиций.\n';
  if (!msg) msg = 'Все сроки в порядке.';
  safeAlert_(msg);
}

