function recalculateStockM() {
  var lock = acquireLock_();
  if (!lock) {
    console.warn('recalculateStockM: не удалось получить блокировку');
    return;
  }

  try {
    var stockSheet = getSheet_(SHEET_STOCK_M);
    var journalSheet = getSheet_(SHEET_JOURNAL_M);
    var journalData = journalSheet.getDataRange().getValues();
    var issueMap = {};

    for (var i = 1; i < journalData.length; i++) {
      var name = normalizeStr(journalData[i][COL_JM.NAME-1]);
      var serial = normalizeStr(journalData[i][COL_JM.SERIAL-1]);
      var expiry = normalizeDate(journalData[i][COL_JM.EXPIRY-1]);
      var qty = num_(journalData[i][COL_JM.QUANTITY-1]);
      if (qty <= 0) continue;
      var key = name + '|' + serial + '|' + expiry;
      issueMap[key] = (issueMap[key] || 0) + qty;
    }

    batchUpdateStockM_(stockSheet, issueMap);
    invalidateCache_(SHEET_STOCK_M);
    console.log('recalculateStockM: пересчёт завершён');
  } catch(e) {
    console.error('Ошибка recalculateStockM: ' + e.message);
    auditLog_('ERROR', SHEET_STOCK_M, 0, 0, '', '', e.message);
  } finally {
    releaseLock_(lock);
  }
}

