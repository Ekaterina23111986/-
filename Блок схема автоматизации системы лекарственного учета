def draw_box(ax, x, y, w, h, text, facecolor, edgecolor, fontsize=9, bold=False, italic=False, textcolor='black', align='center'):
    box = FancyBboxPatch((x, y), w, h, boxstyle="round,pad=0.03,rounding_size=0.2",
                         facecolor=facecolor, edgecolor=edgecolor, linewidth=2)
    ax.add_patch(box)
    weight = 'bold' if bold else 'normal'
    style = 'italic' if italic else 'normal'
    ax.text(x + w/2, y + h/2, text, ha=align, va='center', fontsize=fontsize,
            fontweight=weight, fontstyle=style, color=textcolor, wrap=True, linespacing=1.15)
    return box

def draw_oval(ax, x, y, w, h, text, fc, ec, fs=11):
    el = mpatches.Ellipse((x+w/2, y+h/2), w, h, facecolor=fc, edgecolor=ec, linewidth=2.5)
    ax.add_patch(el)
    ax.text(x+w/2, y+h/2, text, ha='center', va='center', fontsize=fs, fontweight='bold', color=ec)
    return el

def draw_diamond(ax, x, y, size, text, fc, ec, fs=9):
    d = plt.Polygon([(x, y+size/2), (x+size/2, y+size), (x+size, y+size/2), (x+size/2, y)],
                    facecolor=fc, edgecolor=ec, linewidth=2)
    ax.add_patch(d)
    ax.text(x+size/2, y+size/2, text, ha='center', va='center', fontsize=fs, fontweight='bold', wrap=True, linespacing=1.1)
    return d

def draw_data(ax, x, y, w, h, text, fc, ec, fs=9):
    pts = [(x+0.6, y), (x+w-0.6, y), (x+w, y+h), (x, y+h)]
    p = plt.Polygon(pts, facecolor=fc, edgecolor=ec, linewidth=2)
    ax.add_patch(p)
    ax.text(x+w/2, y+h/2, text, ha='center', va='center', fontsize=fs, fontstyle='italic', color='#5D4037', linespacing=1.1)
    return p

def arrow(ax, x1, y1, x2, y2, c='black', lw=1.5, ls='-'):
    ax.annotate('', xy=(x2, y2), xytext=(x1, y1),
