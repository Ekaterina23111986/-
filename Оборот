/** Получить информацию о препарате (список партий) */
function getDrugInfo(drug, type) {
  if (!drug) {
    console.warn('getDrugInfo: drug не указан');
    return { drug: '', type: type, batches: [], total: 0 };
  }
  var result = { drug: drug, type: type, batches: [], total: 0 };
  if (type === 'M') {
    var stock = getSheet_(SHEET_STOCK_M);
    if (!stock) return result;
    var data = stock.getDataRange().getValues();
    var total = 0;
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][COL_M.NAME-1]).trim() !== drug) continue;
      var rest = parseFloat(data[i][COL_M.BALANCE-1]) || 0;
      if (rest <= 0.0001) continue;
      total += rest;
      var serial = data[i][COL_M.SERIAL-1] || '(без серии)';
      var expiry = data[i][COL_M.EXPIRY-1] ? formatDate_(data[i][COL_M.EXPIRY-1]) : '—';
      var price = data[i][COL_M.PRICE-1] || 0;
      result.batches.push({ serial: serial, expiry: expiry, rest: rest, price: price });
    }
    result.total = total;
  } else {
    var stock = getSheet_(SHEET_STOCK_N);
    if (!stock) return result;
    var data = stock.getDataRange().getValues();
    var total = 0;
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][COL_N.NAME-1]).trim() !== drug) continue;
      var rest = parseFloat(data[i][COL_N.BALANCE-1]) || 0;
      if (rest <= 0.0001) continue;
      total += rest;
      var date = data[i][COL_N.DATE-1] ? formatDate_(data[i][COL_N.DATE-1]) : '—';
      var price = data[i][COL_N.PRICE-1] || 0;
      result.batches.push({ date: date, rest: rest, price: price });
    }
    result.total = total;
  }
  return result;
}
