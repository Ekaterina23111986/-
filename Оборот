function normalizeStr(s) {
  if (s === undefined || s === null) return '';
  return String(s).replace(/\s+/g, ' ').trim().toLowerCase();
}

function normalizeDate(d) {
  if (!d) return '';
  var dateObj = toDateSafe_(d);
  return dateObj ? formatDate_(dateObj) : '';
}
function fixArrivalDates() {
  var sheet = getSheet_(SHEET_JOURNAL_N);
  if (!sheet) return;
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return;
  var range = sheet.getRange(2, COL_JN.ARRIVAL_DATE, lastRow - 1, 1);
  var values = range.getValues();
  var newValues = [];
  for (var i = 0; i < values.length; i++) {
    var val = values[i][0];
    var fixed = val;
    if (typeof val === 'string' && val.indexOf('|') !== -1) {
      var parts = val.split('|');
      var dateStr = parts[0].trim();
      var parsed = toDateSafe_(dateStr);
      fixed = parsed || val;
    }
    newValues.push([fixed]);
  }
  range.setValues(newValues);
  safeAlert_('Даты прихода исправлены.');
}
function fixJournalMData() {
  var sheet = getSheet_(SHEET_JOURNAL_M);
  if (!sheet) return;
  var lastRow = sheet.getLastRow();
  if (lastRow < 2) return;
  // Приводим серию к строке без пробелов
  var serialRange = sheet.getRange(2, COL_JM.SERIAL, lastRow - 1, 1);
  var serialValues = serialRange.getValues();
  for (var i = 0; i < serialValues.length; i++) {
    if (serialValues[i][0]) {
      serialValues[i][0] = String(serialValues[i][0]).trim();
    } else {
      serialValues[i][0] = '';
    }
  }
  serialRange.setValues(serialValues);
  // Приводим срок к строке dd.MM.yyyy (если Date)
  var expiryRange = sheet.getRange(2, COL_JM.EXPIRY, lastRow - 1, 1);
  var expiryValues = expiryRange.getValues();
  for (var i = 0; i < expiryValues.length; i++) {
    var val = expiryValues[i][0];
    if (val) {
      var dateObj = toDateSafe_(val);
      expiryValues[i][0] = dateObj ? formatDate_(dateObj) : String(val).trim();
    } else {
      expiryValues[i][0] = '';
    }
  }
  expiryRange.setValues(expiryValues);
  safeAlert_('Данные в журнале выдачи М приведены к единому формату.');
}
function recalculateStockM() {
  var stockSheet = getSheet_(SHEET_STOCK_M);
  var journalSheet = getSheet_(SHEET_JOURNAL_M);
  if (!stockSheet || !journalSheet) return;
  
  var stockData = stockSheet.getDataRange().getValues();
  var journalData = journalSheet.getDataRange().getValues();
  
  // Строим карту выдач: ключ = нормализованное_наименование + '|' + серия + '|' + срок
  var issueMap = {};
  for (var i = 1; i < journalData.length; i++) {
    var name = normalizeStr(journalData[i][COL_JM.NAME-1]);
    var serial = normalizeStr(journalData[i][COL_JM.SERIAL-1]); // пустая строка, если нет
    var expiry = normalizeDate(journalData[i][COL_JM.EXPIRY-1]);
    var qty = parseFloat(journalData[i][COL_JM.QUANTITY-1]) || 0;
    if (qty <= 0) continue;
    var key = name + '|' + serial + '|' + expiry;
    issueMap[key] = (issueMap[key] || 0) + qty;
  }
  
  // Обновляем остатки на складе
  var lastRow = stockData.length;
  var balanceCol = COL_M.BALANCE; // номер столбца остатка (7)
  for (var i = 1; i < stockData.length; i++) {
    var name = normalizeStr(stockData[i][COL_M.NAME-1]);
    var serial = normalizeStr(stockData[i][COL_M.SERIAL-1]);
    var expiry = normalizeDate(stockData[i][COL_M.EXPIRY-1]);
    var initialQty = parseFloat(stockData[i][COL_M.QTY-1]) || 0;
    var key = name + '|' + serial + '|' + expiry;
    var issued = issueMap[key] || 0;
    var balance = Math.max(0, initialQty - issued);
    stockSheet.getRange(i+1, balanceCol).setValue(balance);
  }
  
  console.log('recalculateStockM: пересчёт завершён');
}
function recalculateStockN() {
  var stockSheet = getSheet_(SHEET_STOCK_N);
  var journalSheet = getSheet_(SHEET_JOURNAL_N);
  if (!stockSheet || !journalSheet) return;
  
  var stockData = stockSheet.getDataRange().getValues();
  var journalData = journalSheet.getDataRange().getValues();
  
  // Карта выдач: ключ = наименование + '|' + дата прихода
  var issueMap = {};
  for (var i = 1; i < journalData.length; i++) {
    var name = normalizeStr(journalData[i][COL_JN.NAME-1]);
    var arrivalDate = normalizeDate(journalData[i][COL_JN.ARRIVAL_DATE-1]);
    var qty = parseFloat(journalData[i][COL_JN.QUANTITY-1]) || 0;
    if (qty <= 0) continue;
    var key = name + '|' + arrivalDate;
    issueMap[key] = (issueMap[key] || 0) + qty;
  }
  
  var balanceCol = COL_N.BALANCE; // столбец 5
  for (var i = 1; i < stockData.length; i++) {
    var name = normalizeStr(stockData[i][COL_N.NAME-1]);
    var arrivalDate = normalizeDate(stockData[i][COL_N.DATE-1]);
    var initialQty = parseFloat(stockData[i][COL_N.QTY-1]) || 0;
    var key = name + '|' + arrivalDate;
    var issued = issueMap[key] || 0;
    var balance = Math.max(0, initialQty - issued);
