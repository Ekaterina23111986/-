/** Заполнить данные для журнала М при выборе наименования: список серий */
/** Заполнить данные для журнала М при выборе наименования: список серий */
function fillJournalMData_(sheet, row, drug) {
  if (!sheet || !row || !drug) return;
  var batches = getBatchesM_(drug);
  console.log('fillJournalMData_ вызвана, найдено партий: ' + batches.length);
  if (batches.length === 0) {
    sheet.getRange(row, COL_JM.SERIAL).clearContent();
    sheet.getRange(row, COL_JM.EXPIRY).clearContent();
    sheet.getRange(row, COL_JM.QUANTITY).clearContent();
    return;
  }
  var serials = [];
  var hasNoSerial = false;
  batches.forEach(function(b) {
    if (b.serial) { 
      if (serials.indexOf(b.serial) === -1) serials.push(b.serial); 
    } else {
      hasNoSerial = true;
    }
  });
  var list = serials.slice();
  if (hasNoSerial) list.push('без серии');
  clearDataValidation(sheet, row, COL_JM.SERIAL);
  if (list.length) setDataValidationList(sheet, row, COL_JM.SERIAL, list);
  sheet.getRange(row, COL_JM.EXPIRY).clearContent();
  sheet.getRange(row, COL_JM.QUANTITY).clearContent();
}
function validateJournalMQty_(sheet, row) {
  SpreadsheetApp.flush();
  
  var rawQty = sheet.getRange(row, COL_JM.QUANTITY).getValue();
  var qty = parseFloat(String(rawQty).replace(',', '.'));
  if (isNaN(qty) || qty <= 0) {
    showInfoOnSheetM(sheet, row);
    return false;
  }
  
  var drug = sheet.getRange(row, COL_JM.NAME).getValue();
  if (!drug) {
    showInfoOnSheetM(sheet, row);
    return false;
  }
  
  var serial = sheet.getRange(row, COL_JM.SERIAL).getValue();
  var expiry = sheet.getRange(row, COL_JM.EXPIRY).getValue();
  
  var avail = getBalanceForBatchM(drug, serial, expiry);
  
  console.log('validateJournalMQty_: avail=' + avail + ' для серии "' + normalizeStr(serial) + '"');
  
  var eps = 0.001;
  if (qty - avail > eps) {
    safeAlert_('Недостаточно остатка! Доступно: ' + avail);
    showInfoOnSheetM(sheet, row);
    return false;
  }
  
  return true;
}
/** Получить все партии с остатком >0 для препарата на складе М */
function getBatchesM_(drug) {
  if (!drug) return [];
  var batches = [];
  var stock = getSheet_(SHEET_STOCK_M);
  if (!stock) return batches;
  SpreadsheetApp.flush(); // принудительный пересчёт формул
  var data = stock.getDataRange().getValues();
  var drugNorm = normalizeStr(drug);
  for (var i = 1; i < data.length; i++) {
    var nameStock = normalizeStr(data[i][COL_M.NAME-1]);
    if (nameStock !== drugNorm) continue;
    var rest = parseFloat(data[i][COL_M.BALANCE-1]) || 0;
    if (rest <= 0) continue;
    var serial = normalizeStr(data[i][COL_M.SERIAL-1]); // всегда строка, пустая если нет серии
    var expiry = normalizeDate(data[i][COL_M.EXPIRY-1]);
    batches.push({
      serial: serial,
      expiry: expiry,
      date: data[i][COL_M.DATE-1],
      price: data[i][COL_M.PRICE-1] || 0,
      rest: rest
    });
  }
  console.log('getBatchesM_: найдено партий для ' + drugNorm + ': ' + batches.length);
  return batches;
}


function getBatchesN_(drug, dateStr) {
  if (!drug) return [];
  var batches = [];
  var stock = getSheet_(SHEET_STOCK_N);
  if (!stock) return batches;
  SpreadsheetApp.flush();
  var data = stock.getDataRange().getValues();
  var drugNorm = normalizeStr(drug);
  var dateNorm = dateStr ? normalizeDate(dateStr) : '';
  for (var i = 1; i < data.length; i++) {
    var nameStock = normalizeStr(data[i][COL_N.NAME-1]);
    if (nameStock !== drugNorm) continue;
    var rest = parseFloat(data[i][COL_N.BALANCE-1]) || 0;
    if (rest <= 0) continue;
    var d = normalizeDate(data[i][COL_N.DATE-1]);
    if (dateNorm && d !== dateNorm) continue;
    batches.push({
      date: d,
      price: data[i][COL_N.PRICE-1] || 0,
      rest: rest
    });
  }
  return batches;
}

/** Обработка выбора серии в журнале М */
function processSerialChoice_(sheet, row, choice, batches) {
  sheet.getRange(row, COL_JM.EXPIRY).clearContent();
  sheet.getRange(row, COL_JM.QUANTITY).clearContent();

  if (choice === 'без серии') {
    // Записываем пустую строку, а не "без серии"
    sheet.getRange(row, COL_JM.SERIAL).setValue('');
    var noSerial = batches.filter(function(b) { return b.serial === ''; });
    if (noSerial.length === 0) return;
    var expirySet = {};
    noSerial.forEach(function(b) {
      var key = b.expiry || 'без срока';
      expirySet[key] = true;
    });
    var list = Object.keys(expirySet);
    clearDataValidation(sheet, row, COL_JM.EXPIRY);
    if (list.length) setDataValidationList(sheet, row, COL_JM.EXPIRY, list);
  } else {
    var serialStr = String(choice).trim();
    sheet.getRange(row, COL_JM.SERIAL).setValue(serialStr);
    var matched = batches.find(function(b) { return b.serial === normalizeStr(choice); });
    if (matched) {
      sheet.getRange(row, COL_JM.EXPIRY).setValue(matched.expiry || '');
    } else {
      sheet.getRange(row, COL_JM.EXPIRY).clearContent();
    }
    clearDataValidation(sheet, row, COL_JM.EXPIRY);
  }
}
/** Обработка выбора срока для "без серии" */
function processExpiryChoice_(sheet, row, choice, batches) {
  sheet.getRange(row, COL_JM.QUANTITY).clearContent();
  var noSerial = batches.filter(function(b) { return b.serial === ''; });
  var matched = null;
  if (choice === 'без срока') {
    var emptyExpiry = noSerial.filter(function(b) { return b.expiry === ''; });
    if (emptyExpiry.length) {
      emptyExpiry.sort(function(a,b) { return a.date.getTime() - b.date.getTime(); });
      matched = emptyExpiry[0];
    }
  } else {
    matched = noSerial.find(function(b) {
      return b.expiry && formatDate_(b.expiry) === choice;
    });
  }
  if (matched) {
    sheet.getRange(row, COL_JM.EXPIRY).setValue(choice === 'без срока' ? '' : choice);
  }
}

/** Заполнить данные для журнала Н: список дат прихода */
function fillJournalNData_(sheet, row, drug) {
  if (!drug) return;
  var batches = [];
  var stock = getSheet_(SHEET_STOCK_N);
  if (!stock) return;
  var data = stock.getDataRange().getValues();
  for (var i = 1; i < data.length; i++) {
    if (String(data[i][COL_N.NAME-1]).trim() === drug) {
      var rest = parseFloat(data[i][COL_N.BALANCE-1]) || 0;
      if (rest > 0) {
        batches.push({
          date: data[i][COL_N.DATE-1],
          price: data[i][COL_N.PRICE-1] || 0,
          rest: rest
        });
      }
    }
  }
  if (batches.length === 0) {
    sheet.getRange(row, COL_JN.PRICE).clearContent();
    sheet.getRange(row, COL_JN.ARRIVAL_DATE).clearContent();
    sheet.getRange(row, COL_JN.AVAILABLE).clearContent();
    return;
  }
  // Только даты (без склейки)
  var list = batches.map(function(b) { return formatDate_(b.date); });
  var uniqueDates = [];
  var seen = {};
  list.forEach(function(d) {
    if (!seen[d]) { seen[d] = true; uniqueDates.push(d); }
  });
  clearDataValidation(sheet, row, COL_JN.ARRIVAL_DATE);
  if (uniqueDates.length) setDataValidationList(sheet, row, COL_JN.ARRIVAL_DATE, uniqueDates);
  var first = batches[0];
  sheet.getRange(row, COL_JN.ARRIVAL_DATE).setValue(first.date);
  sheet.getRange(row, COL_JN.PRICE).setValue(first.price);
  updateAvailableN_(sheet, row);
}

/** Обновить столбец доступного остатка (G) в журнале Н */
function updateAvailableN_(sheet, row) {
  var drug = sheet.getRange(row, COL_JN.NAME).getValue();
  var date = sheet.getRange(row, COL_JN.ARRIVAL_DATE).getValue();
  if (!drug) { sheet.getRange(row, COL_JN.AVAILABLE).clearContent(); return; }
  var dateStr = date ? normalizeDate(date) : '';
  var batches = getBatchesN_(drug, dateStr);
  var avail = 0;
  for (var i = 0; i < batches.length; i++) {
    avail += batches[i].rest;
  }
  sheet.getRange(row, COL_JN.AVAILABLE).setValue(avail);
}
