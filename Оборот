/** Архивировать все строки с нулевым остатком на складах */
function archiveZeroBalances() {
  var sheets = [SHEET_STOCK_M, SHEET_STOCK_N];
  sheets.forEach(function(sheetName) {
    var sh = getSheet_(sheetName);
    if (!sh) return;
    var isM = (sheetName === SHEET_STOCK_M);
    var cols = isM ? COL_M : COL_N;
    var data = sh.getDataRange().getValues();
    var rowsToDelete = [];
    for (var i = 1; i < data.length; i++) {
      var bal = parseFloat(data[i][cols.BALANCE-1]) || 0;
      if (bal === 0) {
        archiveStockRow_(sh, i+1, isM ? 'M' : 'N');
        rowsToDelete.push(i+1);
      }
    }
    rowsToDelete.sort(function(a,b){return b-a;});
    for (var j = 0; j < rowsToDelete.length; j++) {
      sh.deleteRow(rowsToDelete[j]);
    }
  });
  recalculateStockM();
  recalculateStockN();
  safeAlert_('Архивация нулевых остатков завершена.');
}

/** Архивировать просроченные позиции (на следующий день после просрочки) */
function archiveExpiredItems() {
  var stock = getSheet_(SHEET_STOCK_M);
  if (!stock) return;
  var data = stock.getDataRange().getValues();
  var today = new Date(); today.setHours(0,0,0,0);
  var rowsToDelete = [];
  for (var i = 1; i < data.length; i++) {
    var exp = data[i][COL_M.EXPIRY-1];
    if (!(exp instanceof Date)) continue;
    // Просрочено, если срок < сегодня
    if (exp < today) {
      archiveStockRow_(stock, i+1, 'M');
      rowsToDelete.push(i+1);
    }
  }
  rowsToDelete.sort(function(a,b){return b-a;});
  for (var j = 0; j < rowsToDelete.length; j++) {
    stock.deleteRow(rowsToDelete[j]);
  }
  safeAlert_('Архивировано ' + rowsToDelete.length + ' просроченных позиций.');
}

/** Архивировать нулевые остатки в кабинетах */
function archiveZeroCabinetRows() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  for (var i = 0; i < sheets.length; i++) {
    var name = sheets[i].getName();
    if (isCabinetSheet_(name) || isKitSheet_(name)) {
      var sh = sheets[i];
      var cols = getCabinetColumns(sh);
      if (!cols || !cols.NAME || !cols.FINAL_BALANCE) continue;
      var data = sh.getDataRange().getValues();
      var rowsToDelete = [];
      for (var r = 1; r < data.length; r++) {
        var bal = parseFloat(data[r][cols.FINAL_BALANCE-1]) || 0;
        if (bal === 0) {
          var drug = data[r][cols.NAME-1];
          var serial = data[r][cols.SERIAL-1] || '';
          var expiry = data[r][cols.EXPIRY-1] || '';
          archiveRow_({
            source: name,
            date: data[r][cols.DATE-1] || '',
            drug: drug,
            form: '',
            qty: parseFloat(data[r][cols.QTY-1]) || 0,
            serial: serial,
            exp: expiry,
            price: parseFloat(data[r][cols.PRICE-1]) || 0,
            group: '',
            status: 'списано',
            reason: 'Обнуление остатка в кабинете',
            cabinet: name
          });
          rowsToDelete.push(r+1);
        }
      }
      rowsToDelete.sort(function(a,b){return b-a;});
      for (var j = 0; j < rowsToDelete.length; j++) {
        sh.deleteRow(rowsToDelete[j]);
      }
    }
  }
   recalculateAllCabinets();
  safeAlert_('Архивация нулевых остатков в кабинетах завершена.');
}

/** Проверить сроки годности (для ручного вызова) */
function checkAllExpiryDates() {
  var stock = getSheet_(SHEET_STOCK_M);
  if (!stock) return;
  var data = stock.getDataRange().getValues();
  var expired = [], soon = [];
  var today = new Date(); today.setHours(0,0,0,0);
  for (var i = 1; i < data.length; i++) {
    var exp = data[i][COL_M.EXPIRY-1];
    if (!(exp instanceof Date)) continue;
    var days = Math.floor((exp - today) / (1000*60*60*24));
    if (days < 0) {
      expired.push({name: data[i][COL_M.NAME-1], serial: data[i][COL_M.SERIAL-1], exp: exp});
    } else if (days < 90) {
      soon.push({name: data[i][COL_M.NAME-1], serial: data[i][COL_M.SERIAL-1], exp: exp});
    }
  }
  var msg = '';
  if (expired.length) msg += 'Просрочено: ' + expired.length + ' позиций.\n';
  if (soon.length) msg += 'Осталось <90 дней: ' + soon.length + ' позиций.\n';
  if (!msg) msg = 'Все сроки в порядке.';
  safeAlert_(msg);
}

/** Очистить архив от дублей */
function cleanArchiveMemory() {
  var arch = getSheet_(SHEET_ARCHIVE);
  if (!arch) { safeAlert_('Лист "Архив" не найден!'); return; }
  var data = arch.getDataRange().getValues();
  var rowsToDelete = [];
  var seen = {};
  for (var i = 1; i < data.length; i++) {
    var key = data[i][3] + '|' + data[i][6] + '|' + data[i][10]; // name|serial|status
    if (seen[key]) rowsToDelete.push(i+1);
    else seen[key] = true;
  }
  rowsToDelete.sort(function(a,b){return b-a;});
  for (var j = 0; j < rowsToDelete.length; j++) {
    arch.deleteRow(rowsToDelete[j]);
  }
  safeAlert_('Архив очищен от дублей. Удалено записей: ' + rowsToDelete.length);
}

/** Полная очистка архива (оставить только заголовок) */
function clearArchive() {
  var ui = safeUi_();
