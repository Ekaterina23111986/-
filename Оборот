/** Вспомогательные функции для отчётов (получение цены, группы и т.д.) */
function priceFor_(name) {
  // Ищем цену на складах (среднюю)
  var sum=0, cnt=0;
  var m = readSheet_(SHEET_STOCK_M);
  for (var i=1; i<m.length; i++) {
    if (txt_(m[i][COL_M.NAME-1]) === name) {
      var p = num_(m[i][COL_M.PRICE-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  var n = readSheet_(SHEET_STOCK_N);
  for (var i=1; i<n.length; i++) {
    if (txt_(n[i][COL_N.NAME-1]) === name) {
      var p = num_(n[i][COL_N.PRICE-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  return cnt ? sum/cnt : 0;
}

function groupFor_(name) {
  var doc = readSheet_(SHEET_DOK);
  for (var i=1; i<doc.length; i++) {
    if (txt_(doc[i][0]) === name) return txt_(doc[i][4]);
  }
  return '';
}

function formFor_(name) {
  var doc = readSheet_(SHEET_DOK);
  for (var i=1; i<doc.length; i++) {
    if (txt_(doc[i][0]) === name) return txt_(doc[i][5]);
  }
  return '';
}

function avgIssuePrice_(name, d1, d2) {
  // Средняя цена выдачи из журналов за период
  var sum=0, cnt=0;
  var jm = readSheet_(SHEET_JOURNAL_M);
  for (var i=1; i<jm.length; i++) {
    if (inPeriod_(jm[i][COL_JM.DATE-1], d1, d2) && txt_(jm[i][COL_JM.NAME-1]) === name) {
      var p = num_(jm[i][COL_JM.PRICE-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  var jn = readSheet_(SHEET_JOURNAL_N);
  for (var i=1; i<jn.length; i++) {
    if (inPeriod_(jn[i][COL_JN.DATE-1], d1, d2) && txt_(jn[i][COL_JN.NAME-1]) === name) {
      var p = num_(jn[i][COL_JN.PRICE-1]);
      if (p>0) { sum += p; cnt++; }
    }
  }
  return cnt ? sum/cnt : 0;
}

/** Записать блок данных и обвести рамкой */
function writeBlock_(sheet, startRow, matrix) {
  if (!matrix || !matrix.length) return startRow;
  var rng = sheet.getRange(startRow, 1, matrix.length, matrix[0].length);
  rng.setValues(matrix);
  rng.setBorder(true, true, true, true, true, true);
  return startRow + matrix.length;
}

/** Построить столбчатую диаграмму */
function buildChart_(sheet, labelRange, valueRanges, title) {
  var builder = sheet.newChart().asColumnChart()
    .addRange(labelRange);
  valueRanges.forEach(function(r) { builder.addRange(r); });
  var chart = builder
    .setPosition(2, 10, 0, 0)
    .setOption('title', title)
    .setOption('legend', {position: 'top'})
    .setOption('width', 700)
    .setOption('height', 400)
    .build();
  sheet.insertChart(chart);
}

/**
 * Отчёт 1: Полный расход по наименованиям
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
function fullReportByName_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var dict = {};

  var ensure = function(name, form) {
    if (!dict[name]) {
      dict[name] = {
        form: form || formFor_(name) || '-',
        pQty: 0, pSum: 0,
        iQty: 0, iSum: 0,
        uQty: 0, uSum: 0
      };
    }
    return dict[name];
  };

  // Закупки со складов
  var stockM = readSheet_(SHEET_STOCK_M);
  for (var i = 1; i < stockM.length; i++) {
    var r = stockM[i];
    if (!inPeriod_(r[COL_M.DATE-1], d1, d2)) continue;
    var nm = txt_(r[COL_M.NAME-1]); if (!nm) continue;
    var q = num_(r[COL_M.QTY-1]), p = num_(r[COL_M.PRICE-1]);
    if (q <= 0 || p <= 0) continue;
    var d = ensure(nm, txt_(r[COL_M.FORM-1]));
    d.pQty += q; d.pSum += q * p;
  }
  var stockN = readSheet_(SHEET_STOCK_N);
  for (var i = 1; i < stockN.length; i++) {
    var r = stockN[i];
    if (!inPeriod_(r[COL_N.DATE-1], d1, d2)) continue;
    var nm = txt_(r[COL_N.NAME-1]); if (!nm) continue;
    var q = num_(r[COL_N.QTY-1]), p = num_(r[COL_N.PRICE-1]);
    if (q <= 0 || p <= 0) continue;
    var d = ensure(nm, txt_(r[COL_N.FORM-1]));
    d.pQty += q; d.pSum += q * p;
  }

  // Выдачи из журналов
  var addIssue = function(data, C) {
    for (var i = 1; i < data.length; i++) {
      var r = data[i];
      if (!inPeriod_(r[C.DATE-1], d1, d2)) continue;
      var nm = txt_(r[C.NAME-1]); if (!nm) continue;
      var q = num_(r[C.QTY-1]), p = num_(r[C.PRICE-1]);
      if (q <= 0 || p <= 0) continue;
      var d = ensure(nm);
      d.iQty += q; d.iSum += q * p;
    }
  };
  addIssue(readSheet_(SHEET_JOURNAL_M), COL_JM);
  addIssue(readSheet_(SHEET_JOURNAL_N), COL_JN);

  // Использование из листов «Расход ...»
  var sheets = SpreadsheetApp.getActiveSpreadsheet().getSheets();
  for (var s = 0; s < sheets.length; s++) {
    var ws = sheets[s];
    var name = ws.getName();
    if (name.indexOf('Расход ') !== 0) continue;
    var data = ws.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      var nm = txt_(data[i][1]); if (!nm) continue;
      var q = num_(data[i][4]); if (q <= 0) continue;
      var pr = avgIssuePrice_(nm, d1, d2) || priceFor_(nm);
      if (!pr) continue;
      var d = ensure(nm);
      d.uQty += q; d.uSum += q * pr;
    }
  }

  var names = Object.keys(dict).sort(function(a,b){ return a.localeCompare(b, 'ru'); });
  if (!names.length) { SpreadsheetApp.getUi().alert('Нет данных за период!'); return; }

  var R = FIRST_ROW;
  sh.getRange(R,1,2,1).merge().setValue('Наименование');
  sh.getRange(R,2,2,1).merge().setValue('Форма выпуска');
  sh.getRange(R,3,1,3).merge().setValue('Закуплено');
  sh.getRange(R,6,1,3).merge().setValue('Выдано');
  sh.getRange(R,9,1,3).merge().setValue('Использовано');
  var sub = ['','','Количество','Цена ср.','Сумма',
             'Количество','Цена ср.','Сумма',
             'Количество','Цена ср.','Сумма'];
  sh.getRange(R+1,1,1,sub.length).setValues([sub]);
  sh.getRange(R,1,2,11).setFontWeight('bold').setHorizontalAlignment('center');

  var rows = [];
  var tPq=0,tPs=0,tIq=0,tIs=0,tUq=0,tUs=0;
  for (var n = 0; n < names.length; n++) {
    var nm = names[n];
    var d = dict[nm];
    var avg = function(s,q){ return q > 0 ? s/q : 0; };
    rows.push([
      nm, d.form,
      d.pQty, avg(d.pSum, d.pQty), d.pSum,
      d.iQty, avg(d.iSum, d.iQty), d.iSum,
      d.uQty, avg(d.uSum, d.uQty), d.uSum
    ]);
    tPq += d.pQty; tPs += d.pSum;
    tIq += d.iQty; tIs += d.iSum;
    tUq += d.uQty; tUs += d.uSum;
  }
  rows.push(['ИТОГО','',tPq, tPq ? tPs/tPq : '', tPs,
             tIq, tIq ? tIs/tIq : '', tIs,
             tUq, tUq ? tUs/tUq : '', tUs]);

  var dataStart = R+2;
  var end = writeBlock_(sh, dataStart, rows);
  sh.getRange(end-1,1,1,11).setFontWeight('bold');

  var lastData = end-2;
  if (lastData >= dataStart) {
    buildChart_(sh,
      sh.getRange(dataStart,1,lastData-dataStart+1,1),
      [ sh.getRange(dataStart,5,lastData-dataStart+1,1),
        sh.getRange(dataStart,8,lastData-dataStart+1,1),
        sh.getRange(dataStart,11,lastData-dataStart+1,1) ],
      'Закупки / выдачи / использование');
  }
}

/**
 * Отчёт 2: Полный расход по группам
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
function fullReportByGroup_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var g = {};
  var nameGroup = {};

  var ens = function(name) {
    var grp = nameGroup[name] || groupFor_(name) || 'Без группы';
    nameGroup[name] = grp;
    if (!g[grp]) g[grp] = [0,0,0,0,0,0];
    return {grp: grp, arr: g[grp]};
  };

  var addPurch = function(data, C) {
    for (var i = 1; i < data.length; i++) {
      var r = data[i];
      if (!inPeriod_(r[C.DATE-1], d1, d2)) continue;
      var nm = txt_(r[C.NAME-1]); if (!nm) continue;
      var q = num_(r[C.QTY-1]), p = num_(r[C.PRICE-1]);
      if (q <= 0 || p <= 0) continue;
      var grp = txt_(r[C.GROUP-1]) || groupFor_(nm) || 'Без группы';
      nameGroup[nm] = grp;
      if (!g[grp]) g[grp] = [0,0,0,0,0,0];
      g[grp][0] += q; g[grp][1] += q * p;
    }
  };
  addPurch(readSheet_(SHEET_STOCK_M), COL_M);
  addPurch(readSheet_(SHEET_STOCK_N), COL_N);

  var addIssue = function(data, C) {
    for (var i = 1; i < data.length; i++) {
      var r = data[i];
      if (!inPeriod_(r[C.DATE-1], d1, d2)) continue;
      var nm = txt_(r[C.NAME-1]); if (!nm) continue;
      var q = num_(r[C.QTY-1]), p = num_(r[C.PRICE-1]);
      if (q <= 0 || p <= 0) continue;
      var obj = ens(nm);
      obj.arr[2] += q; obj.arr[3] += q * p;
    }
  };
  addIssue(readSheet_(SHEET_JOURNAL_M), COL_JM);
  addIssue(readSheet_(SHEET_JOURNAL_N), COL_JN);

  var sheets = SpreadsheetApp.getActiveSpreadsheet().getSheets();
  for (var s = 0; s < sheets.length; s++) {
    var ws = sheets[s];
    var name = ws.getName();
    if (name.indexOf('Расход ') !== 0) continue;
    var data = ws.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      var nm = txt_(data[i][1]); if (!nm) continue;
      var q = num_(data[i][4]); if (q <= 0) continue;
      var pr = avgIssuePrice_(nm, d1, d2) || priceFor_(nm);
      if (!pr) continue;
      var obj = ens(nm);
      obj.arr[4] += q; obj.arr[5] += q * pr;
    }
  }

  var keys = Object.keys(g).sort(function(a,b){ return a.localeCompare(b, 'ru'); });
  if (!keys.length) { SpreadsheetApp.getUi().alert('Нет данных за период!'); return; }

  var R = FIRST_ROW;
  sh.getRange(R,1,2,1).merge().setValue('Наименование группы');
  sh.getRange(R,2,1,2).merge().setValue('Закуплено');
  sh.getRange(R,4,1,2).merge().setValue('Выдано');
  sh.getRange(R,6,1,2).merge().setValue('Использовано');
  sh.getRange(R+1,2,1,6).setValues([
    ['Количество','Цена за группу общая',
     'Количество','Цена за группу общая',
     'Количество','Цена за группу общая']
  ]);
  sh.getRange(R,1,2,7).setFontWeight('bold').setHorizontalAlignment('center');

  var rows = [];
  var tot = [0,0,0,0,0,0];
  for (var k = 0; k < keys.length; k++) {
    var grp = keys[k];
    var a = g[grp];
    rows.push([grp, a[0], a[1], a[2], a[3], a[4], a[5]]);
    for (var j=0; j<6; j++) tot[j] += a[j];
  }
  rows.push(['ИТОГО'].concat(tot));
  var start = R+2;
  var end = writeBlock_(sh, start, rows);
  sh.getRange(end-1,1,1,7).setFontWeight('bold');

  var lastData = end-2;
  if (lastData >= start) {
    buildChart_(sh,
      sh.getRange(start,1,lastData-start+1,1),
      [ sh.getRange(start,3,lastData-start+1,1),
        sh.getRange(start,5,lastData-start+1,1),
        sh.getRange(start,7,lastData-start+1,1) ],
      'Закупки / выдачи / использование по группам');
  }
}


/**
 * Отчёт 3: Расход по кабинетам
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
function reportByCabinet_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var cab = {};

  var sheets = SpreadsheetApp.getActiveSpreadsheet().getSheets();
  for (var s = 0; s < sheets.length; s++) {
    var ws = sheets[s];
    var name = ws.getName();
    if (name.indexOf('Расход ') !== 0) continue;
    var cabName = name.slice(7) || 'Не указан';
    // Исключаем аптечки и служебные
    if (EXCLUDED_CABS.indexOf(cabName.toLowerCase()) >= 0) continue;
    var data = ws.getDataRange().getValues();
    var sum = 0;
    for (var i = 1; i < data.length; i++) {
      var nm = txt_(data[i][1]); if (!nm) continue;
      var q = num_(data[i][4]); if (q <= 0) continue;
      var pr = avgIssuePrice_(nm, d1, d2) || priceFor_(nm);
      if (!pr) continue;
      sum += q * pr;
    }
    if (sum > 0) cab[cabName] = (cab[cabName] || 0) + sum;
  }

  var keys = Object.keys(cab).filter(function(k){ return cab[k] > 0; })
                   .sort(function(a,b){ return cab[b] - cab[a]; });
  if (!keys.length) { SpreadsheetApp.getUi().alert('Нет данных за период!'); return; }

  var R = FIRST_ROW;
  sh.getRange(R,1,1,2).setValues([['Кабинет','Сумма, руб.']]).setFontWeight('bold');
  var rows = keys.map(function(k){ return [k, cab[k]]; });
  var end = writeBlock_(sh, R+1, rows);
  buildChart_(sh,
    sh.getRange(R+1,1,rows.length,1),
    [sh.getRange(R+1,2,rows.length,1)],
    'Расход по кабинетам');
}


/**
 * Отчёт 4: Расход на просроченные
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
function expiredExpenses_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var arch = readSheet_(SHEET_ARCHIVE);
  if (!arch.length) { SpreadsheetApp.getUi().alert('Лист «Архив» пуст или не найден!'); return; }

  var dict = {};
  for (var i = 1; i < arch.length; i++) {
    var r = arch[i];
    if (!inPeriod_(r[COL_ARCH.DATE-1], d1, d2)) continue;
    if (txt_(r[COL_ARCH.STATUS-1]).toLowerCase() !== 'просрочено') continue;
    var nm = txt_(r[COL_ARCH.NAME-1]); if (!nm) continue;
    var q = num_(r[COL_ARCH.QTY-1]); if (q <= 0) continue;
    var p = num_(r[COL_ARCH.PRICE-1]); if (p <= 0) continue;
    if (!dict[nm]) dict[nm] = [0,0];
    dict[nm][0] += q; dict[nm][1] += q * p;
  }

  var keys = Object.keys(dict).sort(function(a,b){ return dict[b][1] - dict[a][1]; });
  if (!keys.length) { SpreadsheetApp.getUi().alert('Нет просроченных за период!'); return; }

  var R = FIRST_ROW;
  sh.getRange(R,1,1,3).setValues([['Наименование','Количество','Сумма, руб.']]).setFontWeight('bold');
  var rows = keys.map(function(k){ return [k, dict[k][0], dict[k][1]]; });
  writeBlock_(sh, R+1, rows);
  buildChart_(sh,
    sh.getRange(R+1,1,rows.length,1),
    [sh.getRange(R+1,3,rows.length,1)],
    'Расход на просроченные');
}


/**
 * Отчёт 5: Текущие остатки по источникам
 */
function currentStockValues_() {
