/** Главная функция, вызываемая при редактировании ячейки */
// ========================= ОСНОВНОЙ ОБРАБОТЧИК onEdit =========================
function onEdit(e) {
  if (!e || !e.range) return;
  if (_skipNextOnEdit) { _skipNextOnEdit = false; return; }

  var range = e.range;
  var sheet = range.getSheet();
  var sheetName = sheet.getName();
  var row = range.getRow();
  var col = range.getColumn();
  var value = e.value;

  if (!sheet || !row || !col) {
    console.warn('onEdit: sheet, row или col равны null');
    return;
  }

  // Обработка вставки нескольких строк на складах
  if (range.getNumRows() > 1 || range.getNumColumns() > 1) {
    if ((sheetName === SHEET_STOCK_M || sheetName === SHEET_STOCK_N) && col === 2) {
      var vals = range.getValues();
      for (var i = 0; i < vals.length; i++) {
        if (vals[i][0]) updateDictionary_(vals[i][0]);
      }
      updateNameDropdownsM();
      updateNameDropdownsN();
    }
    return;
  }

  if (value === undefined || value === null) return;

  // ---- СКЛАД М ----
  if (sheetName === SHEET_STOCK_M) {
    if (col === COL_M.NAME) {
      updateDictionary_(value);
      autoFillGroup_(sheet, row, value, COL_M);
      autoFillForm_(sheet, row, value, COL_M);
      autoFillSupplier_(sheet, row, value, COL_M);
      updateNameDropdownsM();
      updateNameDropdownsN();
      recalculateStockM();
    } else if (col === COL_M.FORM) {
      saveFormMapping_(sheet, row, value, COL_M);
    } else if (col === COL_M.GROUP) {
      saveGroupMapping_(sheet, row, value, COL_M);
    } else if (col === COL_M.SUPPLIER) {
      saveSupplierMapping_(sheet, row, value, COL_M);
    } else if (col === COL_M.QTY) {
      recalculateStockM();
    }
    return;
  }

  // ---- СКЛАД Н ----
  if (sheetName === SHEET_STOCK_N) {
    if (col === COL_N.NAME) {
      updateDictionary_(value);
      autoFillGroup_(sheet, row, value, COL_N);
      autoFillForm_(sheet, row, value, COL_N);
      autoFillSupplier_(sheet, row, value, COL_N);
      updateNameDropdownsM();
      updateNameDropdownsN();
      recalculateStockN();
    } else if (col === COL_N.FORM) {
      saveFormMapping_(sheet, row, value, COL_N);
    } else if (col === COL_N.GROUP) {
      saveGroupMapping_(sheet, row, value, COL_N);
    } else if (col === COL_N.SUPPLIER) {
      saveSupplierMapping_(sheet, row, value, COL_N);
    } else if (col === COL_N.QTY) {
      recalculateStockN();
    }
    return;
  }

  // ---- ЖУРНАЛ М ----
  if (sheetName === SHEET_JOURNAL_M) {
    if (col === COL_JM.NAME) {
      fillJournalMData_(sheet, row, value);
      sheet.getRange(row, COL_JM.QUANTITY).clearContent();
      showInfoOnSheetM(sheet, row);
      recalculateStockM();
    } else if (col === COL_JM.SERIAL) {
      var drug = sheet.getRange(row, COL_JM.NAME).getValue();
      if (drug && value) {
        var batches = getBatchesM_(drug);
        if (batches.length) {
          processSerialChoice_(sheet, row, value, batches);
          sheet.getRange(row, COL_JM.QUANTITY).clearContent();
          showInfoOnSheetM(sheet, row);
        }
      } else {
        sheet.getRange(row, COL_JM.EXPIRY).clearContent();
        sheet.getRange(row, COL_JM.QUANTITY).clearContent();
        showInfoOnSheetM(sheet, row);
      }
      recalculateStockM();
    } else if (col === COL_JM.EXPIRY) {
      var drug = sheet.getRange(row, COL_JM.NAME).getValue();
      if (drug && value) {
        var batches = getBatchesM_(drug);
        if (batches.length) {
          processExpiryChoice_(sheet, row, value, batches);
          sheet.getRange(row, COL_JM.QUANTITY).clearContent();
          showInfoOnSheetM(sheet, row);
        }
      }
    } else if (col === COL_JM.QUANTITY) {
      var qty = parseFloat(value);
      if (!isNaN(qty) && qty > 0) {
        if (validateJournalMQty_(sheet, row)) {
          var cabinet = sheet.getRange(row, COL_JM.CABINET).getValue();
          if (cabinet) {
            _skipNextOnEdit = true;
            try {
              pushToCabinet_(sheet, row, 'M');
            } finally {
              _skipNextOnEdit = false;
            }
            SpreadsheetApp.flush();
            showInfoOnSheetM(sheet, row);
            recalculateStockM();
          } else {
            safeAlert_('Не указан кабинет!');
            sheet.getRange(row, COL_JM.QUANTITY).clearContent();
            showInfoOnSheetM(sheet, row);
          }
        } else {
          sheet.getRange(row, COL_JM.QUANTITY).clearContent();
        }
      }
    }
    return;
  }

  // ---- ЖУРНАЛ Н ----
  if (sheetName === SHEET_JOURNAL_N) {
    if (col === COL_JN.NAME) {
      fillJournalNData_(sheet, row, value);
      sheet.getRange(row, COL_JN.QUANTITY).clearContent();
      showInfoOnSheetN(sheet, row);
      recalculateStockN();
    } else if (col === COL_JN.ARRIVAL_DATE) {
      var drug = sheet.getRange(row, COL_JN.NAME).getValue();
      if (drug && value) {
        var dateValue = value;
        if (typeof value === 'string' && value.indexOf('|') !== -1) {
          var parts = value.split('|');
          var dateStr = parts[0].trim();
          var parsedDate = toDateSafe_(dateStr);
          if (parsedDate) {
            dateValue = parsedDate;
            sheet.getRange(row, COL_JN.ARRIVAL_DATE).setValue(dateValue);
            SpreadsheetApp.flush();
          } else {
            safeAlert_('Не удалось распознать дату из выбранного значения: ' + value);
            sheet.getRange(row, COL_JN.ARRIVAL_DATE).clearContent();
            return;
          }
        }
        var stock = getSheet_(SHEET_STOCK_N);
        if (stock) {
          var data = stock.getDataRange().getValues();
          var dateNorm = normalizeDate(dateValue);
          for (var i = 1; i < data.length; i++) {
            if (String(data[i][COL_N.NAME-1]).trim() === drug) {
              var d = data[i][COL_N.DATE-1];
              if (normalizeDate(d) === dateNorm) {
                var price = data[i][COL_N.PRICE-1] || 0;
                sheet.getRange(row, COL_JN.PRICE).setValue(price);
                break;
              }
            }
          }
        }
        sheet.getRange(row, COL_JN.QUANTITY).clearContent();
        updateAvailableN_(sheet, row);
        showInfoOnSheetN(sheet, row);
        recalculateStockN();
      }
    } else if (col === COL_JN.QUANTITY) {
      var qty = parseFloat(value);
      if (!isNaN(qty) && qty > 0) {
        if (validateJournalNQty_(sheet, row)) {
          var cabinet = sheet.getRange(row, COL_JN.CABINET).getValue();
          if (cabinet) {
            _skipNextOnEdit = true;
            try {
              pushToCabinet_(sheet, row, 'N');
            } finally {
              _skipNextOnEdit = false;
            }
            SpreadsheetApp.flush();
            updateAvailableN_(sheet, row);
            showInfoOnSheetN(sheet, row);
            recalculateStockN();
          } else {
            safeAlert_('Не указан кабинет!');
            sheet.getRange(row, COL_JN.QUANTITY).clearContent();
            showInfoOnSheetN(sheet, row);
          }
        } else {
          sheet.getRange(row, COL_JN.QUANTITY).clearContent();
        }
      }
    }
    return;
  }

  // ---- КАБИНЕТЫ И АПТЕЧКИ ----
  if (isCabinetSheet_(sheetName) || isKitSheet_(sheetName)) {
    var cols = getCabinetColumns(sheet);
    if (!cols) return;

    // Если изменили количество прихода – пересчёт остатков
    if (col === cols.QTY) {
      recalculateCabinet(sheetName);
      return;
    }

    // Если изменили "Списать" – обрабатываем списание
    if (col === cols.WRITE_OFF) {
      if (value !== undefined && value !== null && value !== '') {
        handleWriteOff_(sheet, row, value, sheetName);
      }
      return;
    }

    // Если изменили другие столбцы, которые влияют на остаток (наименование, серия, срок) – пересчёт
    if (col === cols.NAME || col === cols.SERIAL || col === cols.EXPIRY) {
      // При изменении этих полей пересчитываем остаток (например, если исправили серию)
      recalculateCabinet(sheetName);
      return;
    }
  }
}
