/** Сохранить форму в справочник (по наименованию) */
function saveFormMapping_(sheet, row, form, colObj) {
  if (!form) return;
  var name = sheet.getRange(row, colObj.NAME).getValue();
  if (!name) return;
  var doc = getSheet_(SHEET_DOK);
  if (!doc) return;
  var data = doc.getDataRange().getValues();
  for (var i = 1; i < data.length; i++) {
    if (data[i][0] && data[i][0].toString().toLowerCase().trim() === name.toLowerCase().trim()) {
      doc.getRange(i+1, 5).setValue(form);
      return;
    }
  }
  var last = doc.getLastRow() + 1;
  doc.getRange(last, 1).setValue(name);
  doc.getRange(last, 5).setValue(form);
}

