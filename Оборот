/** Архивировать строку со склада или кабинета в общий архив */
function archiveStockRow_(sheet, row, stockType) {
if (row <= 0 || (stockType !== 'M' && stockType !== 'N')) {
safeAlert_('Недопустимые параметры: row = ' + row + ', stockType = ' + stockType);
return;
}
  var cols = (stockType === 'M') ? COL_M : COL_N;
  var name = sheet.getRange(row, cols.NAME).getValue();
  var serial = (stockType === 'M') ? sheet.getRange(row, COL_M.SERIAL).getValue() || '' : '-';
  if (!name) return;
  var arch = getSheet_(SHEET_ARCHIVE);
  if (!arch) { safeAlert_('Лист "Архив" не найден!'); return; }
  // Проверка на дубликат
  var aData = arch.getDataRange().getValues();
  for (var i = 1; i < aData.length; i++) {
    if (aData[i][3] === name && aData[i][6] === serial && aData[i][10] === 'Обычный') return;
  }
  var last = arch.getLastRow() + 1;
  var now = new Date();
  arch.getRange(last, COL_ARCH.DATE).setValue(now);
  arch.getRange(last, COL_ARCH.SOURCE).setValue(stockType === 'M' ? 'Склад М' : 'Склад Н');
  arch.getRange(last, COL_ARCH.ARRIVE).setValue(sheet.getRange(row, cols.DATE).getValue());
  arch.getRange(last, COL_ARCH.NAME).setValue(name);
  arch.getRange(last, COL_ARCH.FORM).setValue(sheet.getRange(row, cols.FORM).getValue());
  arch.getRange(last, COL_ARCH.QTY).setValue(sheet.getRange(row, cols.QTY).getValue());
  arch.getRange(last, COL_ARCH.SERIAL).setValue(serial);
  if (stockType === 'M') {
    var exp = sheet.getRange(row, COL_M.EXPIRY).getValue();
    if (exp) arch.getRange(last, COL_ARCH.EXPIRY).setValue(exp);
  } else {
    arch.getRange(last, COL_ARCH.EXPIRY).setValue('-');
  }
  var price = sheet.getRange(row, cols.PRICE).getValue();
  if (price) arch.getRange(last, COL_ARCH.PRICE).setValue(price);
  arch.getRange(last, COL_ARCH.GROUP).setValue(sheet.getRange(row, cols.GROUP).getValue());
  arch.getRange(last, COL_ARCH.STATUS).setValue('Обычный');
  arch.getRange(last, COL_ARCH.REASON).setValue('Остаток = 0 или просрочен');
  arch.getRange(last, COL_ARCH.CABINET).setValue('-');
  arch.getRange(last, COL_ARCH.DOC_NO).setValue('-');
  arch.getRange(last, COL_ARCH.WRITE_OFF_DATE).setValue('-');
  arch.getRange(last, COL_ARCH.BASIS).setValue('-');
  arch.getRange(last, 1, 1, 16).setBackground('#DCFFDC');
}

