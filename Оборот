/** Получить лист по имени, выбросить ошибку если не найден */
function getSheet_(name) {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sh = ss.getSheetByName(name);
  if (!sh) throw new Error('Лист "' + name + '" не найден!');
  return sh;
}

/** Прочитать все данные листа в массив */
function readSheet_(name) {
  var sh = getSheet_(name);
  return sh.getDataRange().getValues();
}

/** Безопасный доступ к UI */
function safeUi_() {
  try { return SpreadsheetApp.getUi(); } catch(e) { return null; }
}

/** Показать всплывающее сообщение */
function safeAlert_(msg) {
  var ui = safeUi_();
  if (ui) ui.alert(msg);
  else console.log('Alert: ' + msg);
}

/** Преобразовать в число, NaN -> 0 */
function num_(v) { return (typeof v === 'number' && !isNaN(v)) ? v : 0; }

/** Преобразовать в строку с обрезкой */
function txt_(v) { return (v === null || v === undefined) ? '' : String(v).trim(); }

/** Проверить, попадает ли дата в диапазон */
function inPeriod_(d, d1, d2) {
  if (!(d instanceof Date)) return false;
  var t = d.getTime();
  return t >= d1.getTime() && t <= d2.getTime();
}

/** Форматировать дату в строку dd.MM.yyyy */
function formatDate_(date) {
  if (!date) return '—';
  if (date instanceof Date) {
    return Utilities.formatDate(date, Session.getScriptTimeZone(), 'dd.MM.yyyy');
  }
  return String(date);
}

/** Установить выпадающий список в ячейку (уникальные значения) */
function setDataValidationList(sheet, row, col, list) {
  if (!sheet || !row || !col) return;
  var cell = sheet.getRange(row, col);
  try { cell.setDataValidation(null); } catch(e) {}
  if (list && list.length > 0) {
    var unique = [];
    var seen = {};
    list.forEach(function(item) {
      var key = item.toString().trim();
      if (key && !seen[key]) { seen[key] = true; unique.push(key); }
    });
    if (unique.length) {
      var rule = SpreadsheetApp.newDataValidation()
  .requireValueInList(unique, true)
  .setAllowInvalid(true)
  .build();
      cell.setDataValidation(rule);
    }
  }
}

/** Очистить проверку данных в ячейке */
function clearDataValidation(sheet, row, col) {
  if (!sheet || !row || !col) return;
  try { sheet.getRange(row, col).setDataValidation(null); } catch(e) {}
}

/** Безопасное преобразование в дату (поддерживает разные форматы) */
function toDateSafe_(value) {
  if (!value) return null;
  if (value instanceof Date && !isNaN(value.getTime())) return value;
  if (typeof value === 'string') {
    var trimmed = value.trim();
    if (!trimmed) return null;
    var d = new Date(trimmed);
    if (!isNaN(d.getTime()) && d.getFullYear() >= 1900 && d.getFullYear() <= 2100) return d;
    var parts = trimmed.split('.');
    if (parts.length === 3) {
      var day = parseInt(parts[0], 10);
      var month = parseInt(parts[1], 10) - 1;
      var year = parseInt(parts[2], 10);
      if (!isNaN(day) && !isNaN(month) && !isNaN(year)) {
        if (year < 100) year += 2000;
        if (year >= 1900 && year <= 2100) {
          return new Date(Date.UTC(year, month, day));
        }
      }
    }
    var num = parseFloat(trimmed.replace(',', '.'));
    if (!isNaN(num) && num > 0 && num < 100000) {
      return new Date((num - 25569) * 86400 * 1000);
    }
    return null;
  }
  if (typeof value === 'number' && value > 0 && value < 100000) {
    return new Date((value - 25569) * 86400 * 1000);
  }
  return null;
}

/** Определить, является ли лист кабинетом (не служебным) */
function isCabinetSheet_(name) {
  if (!name) return false;
  var reserved = [SHEET_STOCK_M, SHEET_STOCK_N, SHEET_JOURNAL_M, SHEET_JOURNAL_N,
                  SHEET_DOK, SHEET_ARCHIVE, SHEET_ORDERS, SHEET_FINANCE];
  if (reserved.indexOf(name) !== -1) return false;
  if (name.indexOf("Расход ") === 0) return false;
  return true;
}

/** Является ли лист аптечкой */
function isKitSheet_(name) { return KIT_LIST.indexOf(name) >= 0; }

/** Определить столбцы в кабинете по заголовкам (гибкий поиск) */
function getCabinetColumns(sheet) {
  if (!sheet) return {};
  var lastCol = sheet.getLastColumn();
  if (lastCol === 0) return {};
  var headers = sheet.getRange(1, 1, 1, lastCol).getValues()[0];
  var cols = {};
  for (var i = 0; i < headers.length; i++) {
    var h = headers[i] ? headers[i].toString().trim().toLowerCase().replace(/\s+/g,' ') : "";
    if (h.indexOf("наименование") !== -1 || h.indexOf("название") !== -1 || h.indexOf("препарат") !== -1) {
      cols.NAME = i+1;
    } else if ((h.indexOf("количество") !== -1 || h.indexOf("кол-во") !== -1 || h.indexOf("колво") !== -1) && !cols.QTY) {
      cols.QTY = i+1;
    } else if (h.indexOf("серия") !== -1 || h.indexOf("партия") !== -1) {
      cols.SERIAL = i+1;
    } else if (h.indexOf("срок годности") !== -1 || h.indexOf("срок") !== -1 || h.indexOf("годен") !== -1) {
      cols.EXPIRY = i+1;
    } else if (h.indexOf("списать") !== -1 || h.indexOf("списание") !== -1) {
      cols.WRITE_OFF = i+1;
    } else if (h.indexOf("итоговый остаток") !== -1 || h.indexOf("остаток") !== -1) {
      if (!cols.FINAL_BALANCE) cols.FINAL_BALANCE = i+1;
    } else if (h.indexOf("дата") !== -1) {
      cols.DATE = i+1;
    } else if (h.indexOf("цена") !== -1 && !cols.PRICE) {
      cols.PRICE = i+1;
    }
  }
  console.log('getCabinetColumns: найдены столбцы', cols);
  return cols;
}

