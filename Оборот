/** Автозаполнить группу (столбец J/I) по наименованию */
function autoFillGroup_(sheet, row, name, colObj) {
  if (!name) return;
  var doc = getSheet_(SHEET_DOK);
  if (!doc) return;
  var data = doc.getDataRange().getValues();
  var groupCell = sheet.getRange(row, colObj.GROUP);
  if (groupCell.getValue()) return;
  for (var i = 1; i < data.length; i++) {
    if (data[i][0] && data[i][0].toString().toLowerCase().trim() === name.toLowerCase().trim()) {
      if (data[i][4]) { groupCell.setValue(data[i][4]); break; }
    }
  }
}

