/**
 * Отчёт 6: Прогноз расхода
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 * @param {number} horizon - горизонт прогноза в месяцах
 */
function forecast_(d1, d2, horizon) {
  var sh = getSheet_(SHEET_FINANCE);
  if (!horizon || horizon < 1) horizon = 1;
  if (horizon > 12) horizon = 12;

  var months = Math.max(1,
    (d2.getFullYear() - d1.getFullYear()) * 12 + (d2.getMonth() - d1.getMonth()) + 1);

  var issued = {}, spent = {};

  var addIssue = function(data, C) {
    for (var i = 1; i < data.length; i++) {
      var r = data[i];
      if (!inPeriod_(r[C.DATE-1], d1, d2)) continue;
      var nm = txt_(r[C.NAME-1]); if (!nm) continue;
      var q = num_(r[C.QTY-1]), p = num_(r[C.PRICE-1]);
      if (q <= 0 || p <= 0) continue;
      if (!issued[nm]) issued[nm] = [0,0];
      issued[nm][0] += q; issued[nm][1] += q * p;
    }
  };
  addIssue(readSheet_(SHEET_JOURNAL_M), COL_JM);
  addIssue(readSheet_(SHEET_JOURNAL_N), COL_JN);

  var sheets = SpreadsheetApp.getActiveSpreadsheet().getSheets();
  for (var s = 0; s < sheets.length; s++) {
    var ws = sheets[s];
    var name = ws.getName();
    if (name.indexOf('Расход ') !== 0) continue;
    var data = ws.getDataRange().getValues();
    for (var i = 1; i < data.length; i++) {
      var nm = txt_(data[i][1]); if (!nm) continue;
      var q = num_(data[i][4]); if (q <= 0) continue;
      var pr = avgIssuePrice_(nm, d1, d2) || priceFor_(nm);
      if (!pr) continue;
      if (!spent[nm]) spent[nm] = [0,0];
      spent[nm][0] += q; spent[nm][1] += q * pr;
    }
  }

  var namesSet = {};
  Object.keys(issued).forEach(function(k){ namesSet[k]=1; });
  Object.keys(spent).forEach(function(k){ namesSet[k]=1; });
  var list = Object.keys(namesSet).sort(function(a,b){ return a.localeCompare(b, 'ru'); });
  if (!list.length) { SpreadsheetApp.getUi().alert('Нет данных для прогноза!'); return; }

  var R = FIRST_ROW;
  sh.getRange(R,1,1,4).setValues([
    ['Наименование','Группа','Прогноз кол-во','Прогноз сумма']
  ]).setFontWeight('bold');

  var rows = [];
  var tQ = 0, tS = 0;
  for (var i = 0; i < list.length; i++) {
    var nm = list[i];
    var useSpent = spent[nm] && spent[nm][0] > 0;
    var src = useSpent ? spent[nm] : (issued[nm] || [0,0]);
    var fQ = src[0] / months * horizon;
    var fS = src[1] / months * horizon;
    tQ += fQ; tS += fS;
    rows.push([nm, groupFor_(nm) || 'Без группы', fQ, fS]);
  }
  rows.push(['ИТОГО','',tQ,tS]);
  var end = writeBlock_(sh, R+1, rows);
  sh.getRange(end-1,1,1,4).setFontWeight('bold');

  buildChart_(sh,
    sh.getRange(R+1,1,rows.length-1,1),
    [sh.getRange(R+1,4,rows.length-1,1)],
    'Прогноз расхода на ' + horizon + ' мес.');
}


/**
 * Отчёт 7: Сравнение цен внутри наименования
 * @param {string} target - наименование препарата
 */
/**
 * Отчёт 7: Сравнение цен внутри наименования за период
 * Показывает все наименования, у которых менялась цена
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
/**
 * Отчёт: Изменение цен за период
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
/**
 * Отчёт: Изменение цен за период (по всем препаратам)
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
function priceChangesReport_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var changes = {};

  var addPrice = function(name, date, price) {
    if (!name || price <= 0 || !date || !(date instanceof Date)) return;
    if (!changes[name]) changes[name] = { first: {date: null, price: 0}, last: {date: null, price: 0}, count: 0 };
    var item = changes[name];
    if (!item.first.date || date < item.first.date) {
      item.first.date = date;
      item.first.price = price;
    }
    if (!item.last.date || date > item.last.date) {
      item.last.date = date;
      item.last.price = price;
    }
    item.count++;
  };

  var stockM = readSheet_(SHEET_STOCK_M);
  for (var i = 1; i < stockM.length; i++) {
    var r = stockM[i];
    var d = r[COL_M.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_M.NAME-1]), d, num_(r[COL_M.PRICE-1]));
  }
  var stockN = readSheet_(SHEET_STOCK_N);
  for (var i = 1; i < stockN.length; i++) {
    var r = stockN[i];
    var d = r[COL_N.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_N.NAME-1]), d, num_(r[COL_N.PRICE-1]));
  }
  var jm = readSheet_(SHEET_JOURNAL_M);
  for (var i = 1; i < jm.length; i++) {
    var r = jm[i];
    var d = r[COL_JM.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_JM.NAME-1]), d, num_(r[COL_JM.PRICE-1]));
  }
  var jn = readSheet_(SHEET_JOURNAL_N);
  for (var i = 1; i < jn.length; i++) {
    var r = jn[i];
    var d = r[COL_JN.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_JN.NAME-1]), d, num_(r[COL_JN.PRICE-1]));
  }

  var filtered = {};
  for (var name in changes) {
    var item = changes[name];
    if (item.first.price !== item.last.price) {
      filtered[name] = item;
    }
  }

  var keys = Object.keys(filtered).sort(function(a,b){ return a.localeCompare(b, 'ru'); });
  if (!keys.length) {
    SpreadsheetApp.getUi().alert('За выбранный период изменений цен не было.');
    return;
  }

  var R = FIRST_ROW;
  sh.getRange(R,1,1,6).setValues([
    ['Наименование',
     'Цена на начало',
     'Дата начала',
     'Цена на конец',
     'Дата конца',
     'Изменение, %']
  ]).setFontWeight('bold');

  var rows = [];
  for (var i = 0; i < keys.length; i++) {
    var name = keys[i];
    var item = filtered[name];
    var changePercent = ((item.last.price - item.first.price) / item.first.price * 100);
    rows.push([
      name,
      item.first.price,
      formatDate_(item.first.date),
      item.last.price,
      formatDate_(item.last.date),
      changePercent.toFixed(2) + '%'
    ]);
  }
  writeBlock_(sh, R+1, rows);

  // Диаграмма: процент изменения
  if (rows.length > 0) {
    buildChart_(sh,
      sh.getRange(R+1,1,rows.length,1),
      [sh.getRange(R+1,6,rows.length,1)],
      'Изменение цен за период');
  }
}

/**
 * Отчёт: Изменение цен по группам за период
 * @param {Date} d1 - начало периода
 * @param {Date} d2 - конец периода
 */
function groupPriceChangesReport_(d1, d2) {
  var sh = getSheet_(SHEET_FINANCE);
  var groupChanges = {};

  // Функция добавления цены с группировкой по группе
  var addPrice = function(name, date, price) {
    if (!name || price <= 0 || !date || !(date instanceof Date)) return;
    var group = groupFor_(name) || 'Без группы';
    if (!groupChanges[group]) {
      groupChanges[group] = { first: {date: null, price: 0, names: []}, last: {date: null, price: 0, names: []}, count: 0 };
    }
    var item = groupChanges[group];
    // Сохраняем примеры наименований
    if (item.first.names.length < 3) item.first.names.push(name);
    if (item.last.names.length < 3) item.last.names.push(name);
    if (!item.first.date || date < item.first.date) {
      item.first.date = date;
      item.first.price = price;
      item.first.names = [name];
    }
    if (!item.last.date || date > item.last.date) {
      item.last.date = date;
      item.last.price = price;
      item.last.names = [name];
    }
    item.count++;
  };

  // Сбор данных из тех же источников
  var stockM = readSheet_(SHEET_STOCK_M);
  for (var i = 1; i < stockM.length; i++) {
    var r = stockM[i];
    var d = r[COL_M.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_M.NAME-1]), d, num_(r[COL_M.PRICE-1]));
  }
  var stockN = readSheet_(SHEET_STOCK_N);
  for (var i = 1; i < stockN.length; i++) {
    var r = stockN[i];
    var d = r[COL_N.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_N.NAME-1]), d, num_(r[COL_N.PRICE-1]));
  }
  var jm = readSheet_(SHEET_JOURNAL_M);
  for (var i = 1; i < jm.length; i++) {
    var r = jm[i];
    var d = r[COL_JM.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_JM.NAME-1]), d, num_(r[COL_JM.PRICE-1]));
  }
  var jn = readSheet_(SHEET_JOURNAL_N);
  for (var i = 1; i < jn.length; i++) {
    var r = jn[i];
    var d = r[COL_JN.DATE-1];
    if (!inPeriod_(d, d1, d2)) continue;
    addPrice(txt_(r[COL_JN.NAME-1]), d, num_(r[COL_JN.PRICE-1]));
  }

  // Фильтруем группы с изменениями
  var filtered = {};
  for (var group in groupChanges) {
    var item = groupChanges[group];
    if (item.first.price !== item.last.price) {
      filtered[group] = item;
    }
  }

  var keys = Object.keys(filtered).sort(function(a,b){ return a.localeCompare(b, 'ru'); });
  if (!keys.length) {
    SpreadsheetApp.getUi().alert('За выбранный период изменений цен по группам не было.');
    return;
  }

  var R = FIRST_ROW;
  sh.getRange(R,1,1,7).setValues([
    ['Группа',
     'Примеры препаратов',
     'Цена на начало',
     'Дата начала',
     'Цена на конец',
     'Дата конца',
     'Изменение, %']
  ]).setFontWeight('bold');

  var rows = [];
  for (var i = 0; i < keys.length; i++) {
    var group = keys[i];
    var item = filtered[group];
    var changePercent = ((item.last.price - item.first.price) / item.first.price * 100);
    var examples = item.first.names.concat(item.last.names).filter(function(v,i,a){ return a.indexOf(v)===i; }).slice(0,3).join(', ');
    rows.push([
      group,
      examples || '-',
      item.first.price,
      formatDate_(item.first.date),
      item.last.price,
      formatDate_(item.last.date),
      changePercent.toFixed(2) + '%'
    ]);
  }
  writeBlock_(sh, R+1, rows);

  // Диаграмма: средний процент изменения по группам
  if (rows.length > 0) {
    buildChart_(sh,
      sh.getRange(R+1,1,rows.length,1),
      [sh.getRange(R+1,7,rows.length,1)],
      'Изменение цен по группам');
  }
}
