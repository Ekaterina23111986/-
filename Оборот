    var sh = getSheet_(SHEET_STOCK_M);
    if (!sh) return names;
    var lastRow = sh.getLastRow();
    if (lastRow < 2) return names;
    var vals = sh.getRange(2, COL_M.NAME, lastRow-1, 1).getValues();
