/**
 * Запускает отчёт с параметрами из диалога.
 * @param {Object} params - { dateStart, dateEnd, reportType, horizon, itemName, groupName }
 */
function runReportFromDialog(params) {
  if (!params) { safeAlert_('Ошибка: параметры не переданы.'); return; }

  var type = params.reportType;

  // Для "Текущие остатки" даты не нужны
  if (type === 'Текущие остатки') {
    clearReportArea_();
    currentStockValues_();
    return;
  }

  // Для "Изменение цен" и "Изменение цен по группам" даты обязательны
  var dStart = new Date(params.dateStart);
  var dEnd = new Date(params.dateEnd);
  if (isNaN(dStart.getTime()) || isNaN(dEnd.getTime())) {
    safeAlert_('Некорректный формат даты.');
    return;
  }
  if (dStart > dEnd) {
    safeAlert_('Дата начала позже окончания!');
    return;
  }

  var sh = getSheet_(SHEET_FINANCE);
  clearReportArea_();

  switch (type) {
    case 'Полный расход по наименованиям':
      fullReportByName_(dStart, dEnd);
      break;
    case 'Полный расход по группам':
      fullReportByGroup_(dStart, dEnd);
      break;
    case 'Расход по кабинетам':
      reportByCabinet_(dStart, dEnd);
      break;
    case 'Расход на просроченные':
      expiredExpenses_(dStart, dEnd);
      break;
    case 'Прогноз расхода':
      forecast_(dStart, dEnd, params.horizon);
      break;
    case 'Изменение цен за период':
      priceChangesReport_(dStart, dEnd);
      break;
    case 'Изменение цен по группам':
      groupPriceChangesReport_(dStart, dEnd);
      break;
    default:
      safeAlert_('Неизвестный тип отчёта!');
  }
}
/**
 * Возвращает список уникальных наименований и групп из справочника «Док»
 * @returns {Object} { names: [ "Имя1", "Имя2", ... ], groups: [ "Группа1", ... ] }
 */
function getNamesAndGroups() {
  var dok = getSheet_(SHEET_DOK);
  if (!dok) return { names: [], groups: [] };
  var data = dok.getDataRange().getValues();
  var namesSet = {};
  var groupsSet = {};
  for (var i = 1; i < data.length; i++) {
    var name = txt_(data[i][0]);       // столбец A — наименование
    var group = txt_(data[i][4]);      // столбец E — группа
    if (name) namesSet[name] = true;
    if (group) groupsSet[group] = true;
  }
  // Дополнительно добавим наименования со складов (на случай, если в Доке нет)
  var stockM = readSheet_(SHEET_STOCK_M);
  for (var i = 1; i < stockM.length; i++) {
    var name = txt_(stockM[i][COL_M.NAME-1]);
    if (name) namesSet[name] = true;
  }
  var stockN = readSheet_(SHEET_STOCK_N);
  for (var i = 1; i < stockN.length; i++) {
    var name = txt_(stockN[i][COL_N.NAME-1]);
    if (name) namesSet[name] = true;
  }
  return {
    names: Object.keys(namesSet).sort(function(a,b){ return a.localeCompare(b, 'ru'); }),
    groups: Object.keys(groupsSet).sort(function(a,b){ return a.localeCompare(b, 'ru'); })
  };
}
