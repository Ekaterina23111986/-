/** Перестроить справочник (уникальные наименования, формы, группы, поставщики) */
function rebuildDictionaries() {
  try {
    removeStockValidations();
    var doc = getSheet_(SHEET_DOK);
    if (!doc) { safeAlert_('Лист "Док" не найден!'); return; }
    var lastRow = doc.getLastRow();
    if (lastRow >= 2) {
      doc.getRange(2, 6, lastRow - 1, 4).clear({contentsOnly: true});
    }
    buildUniqueColumn_(doc, 1, 6);   // уникальные наименования
    buildUniqueColumn_(doc, 5, 7);   // уникальные группы (столбец E)
    buildUniqueColumn_(doc, 6, 8);   // уникальные формы (столбец F)
    buildUniqueColumn_(doc, 7, 9);   // уникальные поставщики (столбец G)
    var ss = SpreadsheetApp.getActiveSpreadsheet();
    setNamedRange_(ss, 'СПР_Наименования', doc, 6);
    setNamedRange_(ss, 'СПР_Группы', doc, 7);
    setNamedRange_(ss, 'СПР_Формы', doc, 8);
    setNamedRange_(ss, 'СПР_Поставщики', doc, 9);
    updateNameDropdownsM();
    updateNameDropdownsN();
    updateCabinetList();
    safeAlert_('Справочник и списки обновлены.');
  } catch (e) {
    console.error('❌ Ошибка в rebuildDictionaries: ' + e.message);
    safeAlert_('Ошибка: ' + e.message);
  }
}

/** Построить уникальный столбец на основе исходного */
function buildUniqueColumn_(sh, srcCol, dstCol) {
  var last = sh.getLastRow();
  var seen = {};
  var out = [];
  if (last >= 2) {
    var vals = sh.getRange(2, srcCol, last - 1, 1).getValues();
    for (var i = 0; i < vals.length; i++) {
      var v = String(vals[i][0]).trim();
      if (v && !seen[v]) { seen[v] = true; out.push([v]); }
    }
  }
  sh.getRange(2, dstCol, Math.max(sh.getMaxRows()-1,1), 1).clearContent();
  if (out.length) sh.getRange(2, dstCol, out.length, 1).setValues(out);
  sh.getRange(1, dstCol).setValue('Справочник');
}

/** Создать именованный диапазон для выпадающих списков */
function setNamedRange_(ss, name, sh, col) {
  var last = Math.max(sh.getLastRow(), 2);
  var range = sh.getRange(2, col, last - 1, 1);
  var existing = ss.getRangeByName(name);
  if (existing) ss.removeNamedRange(name);
  ss.setNamedRange(name, range);
}

/** Добавить новое наименование в справочник (если отсутствует) */
function updateDictionary_(name) {
  if (!name) return;
  var doc = getSheet_(SHEET_DOK);
  if (!doc) return;
  var data = doc.getDataRange().getValues();
  for (var i = 1; i < data.length; i++) {
    if (data[i][0] === name) return;
  }
  var last = doc.getLastRow() + 1;
  doc.getRange(last, 1).setValue(name);
  doc.getRange(last, 2).setValue('Новая запись');
  doc.getRange(last, 3).setValue(new Date());
  updateNameDropdownsM();
  updateNameDropdownsN();
}

