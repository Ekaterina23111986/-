 * @param {string} cabinetName - имя листа кабинета (например, "Процедурный")
 */
function recalculateCabinet(cabinetName) {
  // Если имя не передано, пытаемся определить активный лист
  if (!cabinetName || cabinetName.trim() === '') {
    var activeSheet = SpreadsheetApp.getActiveSheet();
    if (activeSheet && isCabinetSheet_(activeSheet.getName())) {
      cabinetName = activeSheet.getName();
      console.log('recalculateCabinet: имя кабинета не указано, берём активный лист: ' + cabinetName);
    } else {
      console.error('recalculateCabinet: имя кабинета не указано и активный лист не является кабинетом');
      return;
    }
  }
  cabinetName = cabinetName.trim();

  var cabinetSheet = getSheet_(cabinetName);
  var historySheetName = "Расход " + cabinetName;
  var historySheet = getSheet_(historySheetName);

  if (!historySheet) {
    console.log('recalculateCabinet: лист расхода "' + historySheetName + '" не найден, остатки не пересчитываем');
    return;
  }

  var cabinetData = cabinetSheet.getDataRange().getValues();
  var historyData = historySheet.getDataRange().getValues();

  var writeOffMap = {};
  for (var i = 1; i < historyData.length; i++) {
    var name = normalizeStr(historyData[i][1]);
    var serial = normalizeStr(historyData[i][2]);
    var expiry = normalizeDate(historyData[i][3]);
    var qty = parseFloat(historyData[i][4]) || 0;
    if (qty <= 0) continue;
    var key = name + '|' + serial + '|' + expiry;
    writeOffMap[key] = (writeOffMap[key] || 0) + qty;
  }

  var cols = getCabinetColumns(cabinetSheet);
  if (!cols || !cols.NAME || !cols.QTY || !cols.FINAL_BALANCE) {
    console.error('recalculateCabinet: не удалось определить структуру кабинета "' + cabinetName + '"');
    return;
  }

  for (var i = 1; i < cabinetData.length; i++) {
    var name = normalizeStr(cabinetData[i][cols.NAME - 1]);
    var serial = normalizeStr(cabinetData[i][cols.SERIAL - 1] || '');
    var expiry = normalizeDate(cabinetData[i][cols.EXPIRY - 1] || '');
    var initialQty = parseFloat(cabinetData[i][cols.QTY - 1]) || 0;

    var key = name + '|' + serial + '|' + expiry;
    var writtenOff = writeOffMap[key] || 0;
    var balance = Math.max(0, initialQty - writtenOff);

    cabinetSheet.getRange(i + 1, cols.FINAL_BALANCE).setValue(balance);
  }

  console.log('recalculateCabinet: пересчёт для "' + cabinetName + '" завершён');
}
function recalculateAllCabinets() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheets = ss.getSheets();
  var count = 0;
  for (var i = 0; i < sheets.length; i++) {
    var name = sheets[i].getName();
    if (isCabinetSheet_(name) || isKitSheet_(name)) {
      recalculateCabinet(name);
      count++;
    }
  }
  SpreadsheetApp.getActiveSpreadsheet().toast('Обновлено ' + count + ' кабинетов.', 'Готово', 3);
  console.log('recalculateAllCabinets: обновлено ' + count + ' кабинетов');
}
/** Пересчитать текущий кабинет (активный лист) */
function recalculateCurrentCabinet() {
  var sheet = SpreadsheetApp.getActiveSheet();
  var name = sheet.getName();
  if (!isCabinetSheet_(name) && !isKitSheet_(name)) {
    SpreadsheetApp.getUi().alert('Это не лист кабинета или аптечки.');
    return;
  }
  recalculateCabinet(name);
  SpreadsheetApp.getActiveSpreadsheet().toast('Кабинет "' + name + '" пересчитан.', 'Готово', 3);
}
function createDailyRecalcTrigger() {
  try {
    // Проверяем, есть ли уже такой триггер
    var triggers = ScriptApp.getProjectTriggers();
    for (var i = 0; i < triggers.length; i++) {
      if (triggers[i].getHandlerFunction() === 'recalculateAllCabinets' &&
          triggers[i].getEventType() === ScriptApp.EventType.CLOCK) {
        SpreadsheetApp.getUi().alert('Триггер для ежедневного пересчёта уже существует.');
        return;
      }
    }

    // Создаём новый триггер
    ScriptApp.newTrigger('recalculateAllCabinets')
      .timeBased()
      .everyDays(1)
      .atHour(3) // в 3 часа ночи
      .create();

    SpreadsheetApp.getUi().alert('✅ Ежедневный триггер создан (в 3:00).');
    console.log('✅ Ежедневный триггер для recalculateAllCabinets создан.');
  } catch(e) {
    SpreadsheetApp.getUi().alert('❌ Ошибка создания триггера: ' + e.message + '\n\nДобавьте разрешение https://www.googleapis.com/auth/script.scriptapp в appsscript.json или создайте триггер вручную (Редактор → Триггеры).');
    console.error('Ошибка создания триггера: ' + e.message);
  }
}
/**
 * Безопасная очистка всех данных (без удаления форматирования, заголовков, формул)
 * Используется для повторного использования таблицы разными отделами.
 */
function clearAllData() {
  var ui = SpreadsheetApp.getUi();
  var response = ui.alert(
    '🧹 Очистка данных',
    'Будут удалены ВСЕ данные со складов, журналов, кабинетов, архива и заказов.\n' +
    'Форматирование, заголовки и формулы останутся нетронутыми.\n\n' +
    'Продолжить?',
    ui.ButtonSet.YES_NO
  );
  if (response !== ui.Button.YES) return;

  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheetsToClean = [
    SHEET_STOCK_M, SHEET_STOCK_N,
    SHEET_JOURNAL_M, SHEET_JOURNAL_N,
    SHEET_ARCHIVE, SHEET_ORDERS
  ];

  sheetsToClean.forEach(function(sheetName) {
    var sheet = ss.getSheetByName(sheetName);
    if (!sheet) return;
    var lastRow = sheet.getLastRow();
    if (lastRow >= 2) {
      // Удаляем только данные, оставляя форматирование, заголовки и формулы
      sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn())
        .clear({contentsOnly: true});
    }
  });

  // Очищаем все кабинеты (листы, которые не служебные)
  var allSheets = ss.getSheets();
  allSheets.forEach(function(sheet) {
    var name = sheet.getName();
    if (isCabinetSheet_(name) || isKitSheet_(name)) {
      var lastRow = sheet.getLastRow();
      if (lastRow >= 2) {
        sheet.getRange(2, 1, lastRow - 1, sheet.getLastColumn())
          .clear({contentsOnly: true});
      }
    }
  });

  // Пересчитываем остатки после очистки (они станут нулевыми)
  recalculateStockM();
  recalculateStockN();
  recalculateAllCabinets();

  ui.alert('✅ Очистка завершена. Все данные удалены, структура сохранена.');
}
