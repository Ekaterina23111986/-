  console.log('recalculateStockN: пересчёт завершён');
}
function getBalanceForBatchM(drug, serial, expiry) {
  var stock = getSheet_(SHEET_STOCK_M);
  if (!stock) return 0;
  var data = stock.getDataRange().getValues();
  var drugNorm = normalizeStr(drug);
  var serialNorm = normalizeStr(serial);
  var expiryNorm = normalizeDate(expiry);
  var totalBalance = 0;
  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][COL_M.NAME-1]);
    if (name !== drugNorm) continue;
    var s = normalizeStr(data[i][COL_M.SERIAL-1]);
    if (s !== serialNorm) continue;
    // Если срок указан, проверяем
    if (expiryNorm) {
      var e = normalizeDate(data[i][COL_M.EXPIRY-1]);
      if (e !== expiryNorm) continue;
    }
    totalBalance += parseFloat(data[i][COL_M.BALANCE-1]) || 0;
  }
  return totalBalance;
}
function getBalanceForBatchN(drug, arrivalDate) {
  var stock = getSheet_(SHEET_STOCK_N);
  if (!stock) return 0;
  var data = stock.getDataRange().getValues();
  var drugNorm = normalizeStr(drug);
  var dateNorm = normalizeDate(arrivalDate);
  var totalBalance = 0;
  for (var i = 1; i < data.length; i++) {
    var name = normalizeStr(data[i][COL_N.NAME-1]);
    if (name !== drugNorm) continue;
    var d = normalizeDate(data[i][COL_N.DATE-1]);
    if (d !== dateNorm) continue;
    totalBalance += parseFloat(data[i][COL_N.BALANCE-1]) || 0;
  }
  return totalBalance;
}

function handleWriteOff_(sheet, row, value, cabinetName) {
  // Если cabinetName не передан, берём имя листа
  if (!cabinetName || cabinetName.trim() === '') {
    cabinetName = sheet.getName();
    console.warn('handleWriteOff_: cabinetName не передан, берём из sheet: ' + cabinetName);
  }

  var qty = parseFloat(value.toString().replace(',', '.').replace(/\s/g, ''));
  if (isNaN(qty) || qty <= 0) {
    safeAlert_('Введите положительное число.');
    sheet.getRange(row, sheet.getActiveCell().getColumn()).clearContent();
    return;
  }

  var cols = getCabinetColumns(sheet);
  if (!cols || !cols.NAME || !cols.QTY || !cols.FINAL_BALANCE) {
    safeAlert_('Не удалось определить структуру кабинета.');
    sheet.getRange(row, sheet.getActiveCell().getColumn()).clearContent();
    return;
  }

  var name = sheet.getRange(row, cols.NAME).getValue();
  if (!name) {
    safeAlert_('Нет наименования.');
    sheet.getRange(row, sheet.getActiveCell().getColumn()).clearContent();
    return;
  }

  var finalBalance = parseFloat(sheet.getRange(row, cols.FINAL_BALANCE).getValue()) || 0;
  if (qty > finalBalance) {
    safeAlert_('Недостаточно остатка! Доступно: ' + finalBalance);
    sheet.getRange(row, sheet.getActiveCell().getColumn()).clearContent();
    return;
  }

  var serial = String(sheet.getRange(row, cols.SERIAL).getValue() || '').trim();
  var expiry = sheet.getRange(row, cols.EXPIRY).getValue();
  if (typeof expiry === 'string') expiry = expiry.trim();
  var dateVal = sheet.getRange(row, cols.DATE).getValue();
  if (!(dateVal instanceof Date)) dateVal = new Date();

  var historyName = "Расход " + cabinetName;
  var historySheet = getSheet_(historyName);
  if (!historySheet) {
    historySheet = SpreadsheetApp.getActiveSpreadsheet().insertSheet(historyName);
    historySheet.getRange(1,1,1,5).setValues([['Дата','Наименование','Серия','Срок','Количество']]);
    historySheet.getRange(1,1,1,5).setFontWeight('bold');
  }

  historySheet.appendRow([dateVal, name.trim(), serial, expiry, qty]);

  sheet.getRange(row, sheet.getActiveCell().getColumn()).clearContent();

  // Пересчёт через скрипт
  recalculateCabinet(cabinetName);

  if (finalBalance - qty === 0) {
    addToOrders_(cabinetName, name, 0);
  }

  SpreadsheetApp.flush();
  SpreadsheetApp.getActiveSpreadsheet().toast('Списано ' + qty + ' ед. "' + name + '"', 'Готово', 3);
}
