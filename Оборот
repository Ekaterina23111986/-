/**
 * Внутренняя функция отмены выдачи.
 * @param {string} type - 'M' или 'N'
 */
function undoIssue_(type) {
  var sheetName = (type === 'M') ? SHEET_JOURNAL_M : SHEET_JOURNAL_N;
  var sheet = SpreadsheetApp.getActiveSheet();
  if (sheet.getName() !== sheetName) {
    SpreadsheetApp.getUi().alert('Выберите строку на листе "' + sheetName + '"!');
    return;
  }
  var row = sheet.getActiveCell().getRow();
  if (row < 2) {
    SpreadsheetApp.getUi().alert('Выберите строку с данными (не заголовок)!');
    return;
  }

  var ui = SpreadsheetApp.getUi();
  var response = ui.alert(
    '↩️ Отменить выдачу',
    'Вы действительно хотите отменить выдачу в строке ' + row + '?\n' +
    'Эта строка будет удалена из журнала, а остаток на складе будет восстановлен.',
    ui.ButtonSet.YES_NO
  );
  if (response !== ui.Button.YES) return;

  // Удаляем строку
  sheet.deleteRow(row);

  // Пересчитываем остатки на соответствующем складе
  if (type === 'M') {
    recalculateStockM();
    // Также обновить информационную панель (если открыта)
    // Но это не обязательно
  } else {
    recalculateStockN();
  }

  ui.alert('✅ Выдача отменена. Остаток на складе пересчитан.');
}
