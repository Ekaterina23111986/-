function createTriggers() {
  try {
    var triggers = ScriptApp.getProjectTriggers();
  } catch(e) {
    console.warn('⚠️ Нет прав на управление триггерами. Функции onEdit и onSelectionChange будут работать, но автоматическая архивация не будет создана.');
    return;
  }

  var hasEdit = false, hasSelect = false, hasDaily = false;
  for (var i = 0; i < triggers.length; i++) {
    if (triggers[i].getHandlerFunction() === 'onEdit') hasEdit = true;
    if (triggers[i].getHandlerFunction() === 'onSelectionChange') hasSelect = true;
    if (triggers[i].getHandlerFunction() === 'dailyArchive' && triggers[i].getEventType() === ScriptApp.EventType.CLOCK) hasDaily = true;
  }

  if (!hasEdit) {
    try {
      ScriptApp.newTrigger('onEdit')
        .forSpreadsheet(SpreadsheetApp.getActiveSpreadsheet())
        .onEdit()
        .create();
      console.log('✅ Триггер onEdit создан.');
    } catch(e) {
      console.warn('⚠️ Не удалось создать триггер onEdit: ' + e.message);
    }
  }

  if (!hasSelect) {
    try {
      ScriptApp.newTrigger('onSelectionChange')
        .forSpreadsheet(SpreadsheetApp.getActiveSpreadsheet())
        .onSelectionChange()
        .create();
      console.log('✅ Триггер onSelectionChange создан.');
    } catch(e) {
      console.warn('⚠️ Не удалось создать триггер onSelectionChange: ' + e.message);
    }
  }

  if (!hasDaily) {
    try {
      ScriptApp.newTrigger('dailyArchive')
        .timeBased()
        .everyDays(1)
        .atHour(2)
        .create();
      console.log('✅ Триггер dailyArchive создан (ежедневно в 2:00).');
    } catch(e) {
      console.warn('⚠️ Не удалось создать триггер dailyArchive: ' + e.message + '. Возможно, не хватает прав.');
    }
  }
}
