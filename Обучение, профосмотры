function runFormulasOnly() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) return;

  // 1. Загружаем данные из справочника
  loadRefData(ss);

  // 2. Строим выпадающие списки по разделам
  var lists = buildListsBySection();
  var allSections = Object.keys(lists);

  // 3. Обновляем формулы во всех листах
  ss.getSheets().forEach(function(sh) {
    var nm = sh.getName();
    if (nm.indexOf("\u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435") !== -1) {
      setTrainFormulas(sh);
    }
    if (nm.indexOf("\u043f\u0440\u043e\u0444 \u043e\u0441\u043c\u043e\u0442\u0440") !== -1) {
      setExamFormulas(sh);
      updateExamDropdowns(sh, lists, allSections);
    }
  });

  SpreadsheetApp.getUi().alert("\u2705 \u0424\u043e\u0440\u043c\u0443\u043b\u044b \u043f\u0435\u0440\u0435\u0441\u0447\u0438\u0442\u0430\u043d\u044b \u0438\u0437 \u0441\u043f\u0440\u0430\u0432\u043e\u0447\u043d\u0438\u043a\u0430!");
}

