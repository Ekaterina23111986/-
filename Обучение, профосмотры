// =====================================================
// ФОРМУЛЫ ОБУЧЕНИЯ
//
// Раскладка колонок (индексы):
//  A=1  B=2  C=3  D=4  E=5  F=6  G=7  H=8  I=9  J=10
//  K=11  L=12  M=13  N=14  O=15  P=16  Q=17  R=18  S=19
//
//  K = След. аккр. (авто) = дата I + 5 лет
//  L = Ост. до аккр. (без изменений!)
//  M = Уведомление
//  N = План. дата обуч. (ручной ввод)
//  O = Коридор обучения = "ДД.ММ.ГГГГ - ДД.ММ.ГГГГ" (из I и K)
//  P = Доп. сведения (ручной ввод)
//  Q = Обуч. мед. отходы (ручной ввод)
//  R = Обуч. охрана труда (ручной ввод)
//  S = Обуч. пожарн. безопасность (ручной ввод)
// =====================================================
function setTrainFormulas(sh) {
  for (var r = 2; r <= 51; r++) {

    // K (11): Следующая аккредитация = дата аккредитации + 5 лет
    putFormula(sh.getRange(r, 11),
      "=IF(I" + r + "=\"\";\"\";DATE(YEAR(I" + r + ")+5;MONTH(I" + r + ");DAY(I" + r + ")))");

    // L (12): Ост. до аккр. — БЕЗ ИЗМЕНЕНИЙ (как в оригинале)
    putFormula(sh.getRange(r, 12),
      "=IF(K" + r + "=\"\";\"\";IF(K" + r + "<TODAY();" +
      q() + "\u041f\u0420\u041e\u0421\u0420\u041e\u0427\u0415\u041d\u043e" + q() +
      ";CONCATENATE(" + q() + "\u041e\u0441\u0442\u0430\u043b\u043e\u0441\u044c " + q() +
      ";DATEDIF(TODAY();K" + r + ";" + q() + "Y" + q() +
      ");" + q() + " \u043b\u0435\u0442 " + q() +
      ";DATEDIF(TODAY();K" + r + ";" + q() + "YM" + q() +
      ");" + q() + " \u043c\u0435\u0441 " + q() +
      ";DATEDIF(TODAY();K" + r + ";" + q() + "MD" + q() +
      ");" + q() + " \u0434\u043d." + q() + ")))");

    // M (13): Уведомление — БЕЗ ИЗМЕНЕНИЙ
    putFormula(sh.getRange(r, 13),
      "=IF(AND(K" + r + "<>\"\";K" + r + "<=TODAY()+2);" +
      "CONCATENATE(\"\u0421 \";TEXT(K" + r + ";\"DD.MM.YYYY\");\" \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e \u043e\u0442\u043f\u0440\u0430\u0432\u0438\u0442\u044c \u0432 \u043e\u0442\u043f\u0443\u0441\u043a\");\"\")");

    // N (14): План. дата обуч. — ручной ввод, формат даты
    sh.getRange(r, 14).setNumberFormat("DD.MM.YYYY");

    // O (15): КОРИДОР ОБУЧЕНИЯ — "ДД.ММ.ГГГГ - ДД.ММ.ГГГГ"
    // Берём дату аккредитации (I) и следующую аккредитацию (K)
    putFormula(sh.getRange(r, 15),
      "=IF(OR(I" + r + "=\"\";K" + r + "=\"\");\"\";" +
      "TEXT(I" + r + ";\"DD.MM.YYYY\")&\" - \"&TEXT(K" + r + ";\"DD.MM.YYYY\"))");

    // Форматы дат
    sh.getRange(r, 6).setNumberFormat("DD.MM.YYYY");   // F: Дата обуч.
    sh.getRange(r, 9).setNumberFormat("DD.MM.YYYY");   // I: Дата аккр.
    sh.getRange(r, 11).setNumberFormat("DD.MM.YYYY");  // K: След. аккр.

    // Q, R, S — формат дат для ручного ввода
    sh.getRange(r, 17).setNumberFormat("DD.MM.YYYY");  // Q: Обуч. мед. отходы
    sh.getRange(r, 18).setNumberFormat("DD.MM.YYYY");  // R: Обуч. охрана труда
    sh.getRange(r, 19).setNumberFormat("DD.MM.YYYY");  // S: Обуч. пожарн. безопасность
  }
}

// =====================================================
// УСЛОВНОЕ ФОРМАТИРОВАНИЕ ОБУЧЕНИЯ
// =====================================================
function setTrainCondFmt(sh) {
  try {
    var rules = [];

    // === Колонка K (11) — След. аккр. (3 уровня) ===
    // K1: Просрочено — красный жирный
    rules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=AND($K2<>\"\";$K2<TODAY())")
      .setFontColor("#CC0000").setBold(true)
      .setRanges([sh.getRange("K2:K51")]).build());

    // K2: До окончания < 122 дней (~4 мес) — красный фон
    rules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=AND($K2<>\"\";$K2>=TODAY();$K2<=TODAY()+122)")
      .setBackground("#F4CCCC").setFontColor("#CC0000")
      .setRanges([sh.getRange("K2:K51")]).build());

    // K3: До окончания < 365 дней (~1 год) — жёлтый фон
    rules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=AND($K2<>\"\";$K2>TODAY()+122;$K2<=TODAY()+365)")
      .setBackground("#FFF2CC")
      .setRanges([sh.getRange("K2:K51")]).build());

    // === Колонка O (15) — КОРИДОР ОБУЧЕНИЯ (2 уровня) ===
    // Формулы проверяют колонку K (дата окончания коридора),
    // но условное форматирование применяется к диапазону O2:O51
    //
    // O1: До окончания коридора < 6 месяцев → красный фон + красный текст
    rules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=AND($K2<>\"\";$K2<=EDATE(TODAY();6))")
      .setBackground("#F4CCCC").setFontColor("#CC0000")
      .setRanges([sh.getRange("O2:O51")]).build());

    // O2: До окончания коридора < 1 года → жёлтый фон
    rules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=AND($K2<>\"\";$K2>EDATE(TODAY();6);$K2<=EDATE(TODAY();12))")
      .setBackground("#FFF2CC")
      .setRanges([sh.getRange("O2:O51")]).build());

    // === Колонка M (13) — Уведомление ===
    // M1: Если уведомление заполнено → жёлтый фон + красный текст
    rules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=LEN($M2)>0")
      .setBackground("#FFF2CC").setFontColor("#CC0000")
      .setRanges([sh.getRange("M2:M51")]).build());

    sh.setConditionalFormatRules(rules);
  } catch(e) {}
}

