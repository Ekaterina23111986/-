  sh.getRange("H2:H51").setDataValidation(SpreadsheetApp.newDataValidation().requireValueInList(["\u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0435 \u043c\u0435\u0441\u0442\u043e \u0440\u0430\u0431\u043e\u0442\u044b", "\u0421\u043e\u0432\u043c\u0435\u0441\u0442\u0438\u0442\u0435\u043b\u044c"]).setAllowInvalid(false).build());

  sh.getRange(1, vS + 2).setNote("\u041a\u0440\u0430\u0441\u043d\u0443\u0445\u0430: \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0436\u0435\u043d\u0449. \u0434\u043e 35 \u043b\u0435\u0442.");
  sh.getRange(1, kS).setNote("1-\u0439 \u0441\u043f\u0438\u0441\u043e\u043a: \u0412\u044b\u043f. \u0440\u0430\u0431\u043e\u0442\u044b. 2-\u0439: \u0425\u0438\u043c. \u0444\u0430\u043a\u0442\u043e\u0440\u044b. 3-\u0439: \u0411\u0438\u043e\u043b. \u0444\u0430\u043a\u0442\u043e\u0440\u044b. 4-\u0439: \u0424\u0438\u0437.+\u0422\u0440\u0443\u0434.");

  setExamFormulas(sh);
  setExamCondFmt(sh);
  sh.setFrozenRows(1); sh.setFrozenColumns(2);
}

// =====================================================
// ФОРМУЛЫ ПРОФОСМОТРА — dS = pL+vL+1 = 18
// =====================================================
function setExamFormulas(sh) {
  var pL = EH.length, vL = EV.length;
  var dS = pL + vL + 1; // = 18
  for (var r = 2; r <= 51; r++) {
    putFormula(sh.getRange(r, 3), "=IF(B" + r + "=\"\";\"\";DATEDIF(B" + r + ";TODAY();" + q() + "Y" + q() + "))");
    putFormula(sh.getRange(r, dS + 1), "=IF(R" + r + "=\"\";\"\";DATE(YEAR(R" + r + ")+1;MONTH(R" + r + ");DAY(R" + r + ")))");
    sh.getRange(r, dS + 1).setNumberFormat("DD.MM.YYYY");
    putFormula(sh.getRange(r, dS + 2), "=IF(S" + r + "=\"\";\"\";IF(S" + r + "<TODAY();" + q() + "\u041f\u0420\u041e\u0421\u0420\u041e\u0427\u0415\u041d\u043e" + q() + ";CONCATENATE(" + q() + "\u041e\u0441\u0442\u0430\u043b\u043e\u0441\u044c " + q() + ";DATEDIF(TODAY();S" + r + ";" + q() + "Y" + q() + ");" + q() + " \u043b\u0435\u0442 " + q() + ";DATEDIF(TODAY();S" + r + ";" + q() + "YM" + q() + ");" + q() + " \u043c\u0435\u0441 " + q() + ";DATEDIF(TODAY();S" + r + ";" + q() + "MD" + q() + ");" + q() + " \u0434\u043d." + q() + ")))");
    sh.getRange(r, 2).setNumberFormat("DD.MM.YYYY");
    for (var v = 0; v < vL; v++) sh.getRange(r, 9 + v).setNumberFormat("DD.MM.YYYY");
    sh.getRange(r, 18).setNumberFormat("DD.MM.YYYY");
  }
}

function setExamCondFmt(sh) {
  try {
    var rules = [];
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($S2<>\"\";$S2<TODAY())").setFontColor("#CC0000").setBold(true).setRanges([sh.getRange("S2:S51")]).build());
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($S2<>\"\";$S2>=TODAY();$S2<=TODAY()+122)").setBackground("#F4CCCC").setFontColor("#CC0000").setRanges([sh.getRange("S2:S51")]).build());
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($S2<>\"\";$S2>TODAY()+122;$S2<=TODAY()+244)").setBackground("#FFF2CC").setRanges([sh.getRange("S2:S51")]).build());
    sh.setConditionalFormatRules(rules);
  } catch(e) {}
}

// =====================================================
// ОБНОВЛЕНИЕ ВЫПАДАЮЩИХ СПИСКОВ (из справочника)
// =====================================================
function updateExamDropdowns(sh, lists, sections) {
  var pL = EH.length, vL = EV.length, dL = ED.length;
  var kS = pL + vL + dL + 1; // = 21

  // Собираем все значения из всех разделов для combined списка
  var allItems = [];
  sections.forEach(function(sec) {
    if (lists[sec]) {
      lists[sec].forEach(function(item) { allItems.push(item); });
    }
  });

  // Устанавливаем выпадающие списки для каждой колонки
  for (var p = 0; p < 4; p++) {
    // Используем общий список для всех колонок, но с приоритетом раздела
    sh.getRange(2, kS + p, 50, 1).setDataValidation(
      SpreadsheetApp.newDataValidation().requireValueInList(allItems).setAllowInvalid(true).build()
    );
  }
}

// =====================================================
// ТРИГГЕР + ONEDIT
// =====================================================
function addTriggerSafe(ss) {
  try {
    ScriptApp.getProjectTriggers().forEach(function(t) {
      if (t.getHandlerFunction() === "onEditHook") {
        try { ScriptApp.deleteTrigger(t); } catch(e2) {}
      }
    });
    ScriptApp.newTrigger("onEditHook").forSpreadsheet(ss).onEdit().create();
  } catch(e) { Logger.log("Trigger: " + e); }
}

function onEditHook(e) {
  try {
    if (!e || !e.range) return;
    var sh = e.source.getActiveSheet();
    if (!sh) return;
    var nm = sh.getName(), row = e.range.getRow(), col = e.range.getColumn();
    if (nm.indexOf("\u043f\u0440\u043e\u0444 \u043e\u0441\u043c\u043e\u0442\u0440") !== -1) {
      if ((col >= 21 && col <= 24) || col === 6 || col === 2) doRefresh(sh, row, 21, 25);
    }
    if (nm.indexOf("\u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435") !== -1 && col === 6) {
      sh.getRange(row, 14).setValue("");
    }
  } catch(e) {}
}

// =====================================================
// ОБНОВЛЕНИЕ СПЕЦИАЛИСТОВ И ИССЛЕДОВАНИЙ (из справочника)
// =====================================================
function doRefresh(sh, row, pktS, resS) {
  try {
    var age = sh.getRange(row, 3).getValue();
    var gender = sh.getRange(row, 6).getValue();
    var hasAge = (age !== "" && age !== null && !isNaN(age));
    var specs = [], tests = [];

    // Читаем пункты из 4 колонок
    for (var p = 0; p < 4; p++) {
      var val = sh.getRange(row, pktS + p).getValue();
      if (!val || val === "") continue;

      // Ищем в _pktCache (загружен из справочника)
      var pk = _pktCache.find(function(x) { return (x.code + " " + x.name) === val; });
      if (!pk) continue;

      if (pk.spec) pk.spec.split(", ").forEach(function(s) { if (specs.indexOf(s) === -1) specs.push(s); });
      if (pk.tests) pk.tests.split("; ").forEach(function(t) {
        var tr = t.replace(/^\s+|\s+$/g, "");
        if (tr && tests.indexOf(tr) === -1) tests.push(tr);
      });
    }

    // Базовые исследования (неизменяемые)
    BASE.forEach(function(item) {
      if (hasAge) {
        if (item[4] > 0 && age < item[4]) return;
        if (item[5] > 0 && age > item[5]) return;
      }
      if (item[6] !== "\u0412\u0441\u0435" && gender !== item[6]) return;
      if (item[1] && specs.indexOf(item[1]) === -1) specs.push(item[1]);
      if (item[2]) item[2].split(", ").forEach(function(t) {
        var tr = t.replace(/^\s+|\s+$/g, "");
        if (tr && tests.indexOf(tr) === -1) tests.push(tr);
      });
    });

    sh.getRange(row, resS).setValue(specs.join("\n"));
    sh.getRange(row, resS + 1).setValue(tests.join("\n"));
  } catch(e) { Logger.log("doRefresh: " + e); }
}

