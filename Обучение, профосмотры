function setExamFormulas(sh) {
  var pL = EH.length, vL = EV.length;
  var dS = pL + vL + 1;
  for (var r = 2; r <= 51; r++) {
    putFormula(sh.getRange(r, 3), "=IF(B" + r + "=\"\";\"\";DATEDIF(B" + r + ";TODAY();" + q() + "Y" + q() + "))");
    putFormula(sh.getRange(r, dS + 1), "=IF(R" + r + "=\"\";\"\";DATE(YEAR(R" + r + ")+1;MONTH(R" + r + ");DAY(R" + r + ")))");
    sh.getRange(r, dS + 1).setNumberFormat("DD.MM.YYYY");
    putFormula(sh.getRange(r, dS + 2), "=IF(S" + r + "=\"\";\"\";IF(S" + r + "<TODAY();" + q() + "\u041f\u0420\u041e\u0421\u0420\u041e\u0427\u0415\u041d\u043e" + q() + ";CONCATENATE(" + q() + "\u041e\u0441\u0442\u0430\u043b\u043e\u0441\u044c " + q() + ";DATEDIF(TODAY();S" + r + ";" + q() + "Y" + q() + ");" + q() + " \u043b\u0435\u0442 " + q() + ";DATEDIF(TODAY();S" + r + ";" + q() + "YM" + q() + ");" + q() + " \u043c\u0435\u0441 " + q() + ";DATEDIF(TODAY();S" + r + ";" + q() + "MD" + q() + ");" + q() + " \u0434\u043d." + q() + ")))");
    sh.getRange(r, 2).setNumberFormat("DD.MM.YYYY");
    for (var v = 0; v < vL; v++) sh.getRange(r, 9 + v).setNumberFormat("DD.MM.YYYY");
    sh.getRange(r, 18).setNumberFormat("DD.MM.YYYY");
  }
}

function setExamCondFmt(sh) {
  try {
    var rules = [];
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($S2<>\"\";$S2<TODAY())").setFontColor("#CC0000").setBold(true).setRanges([sh.getRange("S2:S51")]).build());
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($S2<>\"\";$S2>=TODAY();$S2<=TODAY()+122)").setBackground("#F4CCCC").setFontColor("#CC0000").setRanges([sh.getRange("S2:S51")]).build());
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($S2<>\"\";$S2>TODAY()+122;$S2<=TODAY()+244)").setBackground("#FFF2CC").setRanges([sh.getRange("S2:S51")]).build());
    sh.setConditionalFormatRules(rules);
  } catch(e) {}
}

