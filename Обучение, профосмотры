function updateExamDropdowns(sh, lists, sections) {
  var pL = EH.length, vL = EV.length, dL = ED.length;
  var kS = pL + vL + dL + 1;
  var allItems = [];
  sections.forEach(function(sec) {
    if (lists[sec]) {
      lists[sec].forEach(function(item) { allItems.push(item); });
