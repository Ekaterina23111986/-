function createTrain(ss, loc) {
  var sh = ensureSheet(ss, loc + " \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435");
  sh.setTabColor("#4285F4");

  var isNew = sh.getRange(1, 1).getValue() === "";
  if (isNew) {
    ensureHeaders(sh, TH);
  } else {
    var lastCol = sh.getLastColumn();
    if (lastCol < TH.length) {
      sh.getRange(1, lastCol + 1, 1, TH.length - lastCol).setValues([TH.slice(lastCol)]);
      sh.getRange(1, lastCol + 1, 1, TH.length - lastCol)
        .setFontWeight("bold").setBackground("#4285F4").setFontColor("#fff")
        .setWrap(true).setHorizontalAlignment("center").setVerticalAlignment("middle");
    }
  }

  COL_WIDTHS.forEach(function(v, i) { sh.setColumnWidth(i + 1, v); });

  sh.getRange("D2:D51").setDataValidation(SpreadsheetApp.newDataValidation().requireValueInList(["0.25","0.5","0.75","1.0"]).setAllowInvalid(false).build());
  sh.getRange("C2:C51").setDataValidation(SpreadsheetApp.newDataValidation().requireValueInList(["\u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0435 \u043c\u0435\u0441\u0442\u043e \u0440\u0430\u0431\u043e\u0442\u044b","\u0421\u043e\u0432\u043c\u0435\u0441\u0442\u0438\u0442\u0435\u043b\u044c"]).setAllowInvalid(false).build());
  sh.getRange("J2:J51").setDataValidation(SpreadsheetApp.newDataValidation().requireValueInList(["\u041f\u0435\u0440\u0432\u0438\u0447\u043d\u0430\u044f","\u041f\u0435\u0440\u0438\u043e\u0434\u0438\u0447\u0435\u0441\u043a\u0430\u044f"]).setAllowInvalid(false).build());

  setTrainFormulas(sh);
  setTrainCondFmt(sh);
  sh.setFrozenRows(1);
  sh.setFrozenColumns(2);

  sh.getRange(1, 17).setNote("\u0414\u0430\u0442\u0430 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f \u043f\u043e \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0435 \u043c\u0435\u0434. \u043e\u0442\u0445\u043e\u0434\u043e\u0432 (DD.MM.YYYY)");
  sh.getRange(1, 18).setNote("\u0414\u0430\u0442\u0430 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f \u043f\u043e \u043e\u0445\u0440\u0430\u043d\u0435 \u0442\u0440\u0443\u0434\u0430 (DD.MM.YYYY)");
  sh.getRange(1, 19).setNote("\u0414\u0430\u0442\u0430 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f \u043f\u043e \u043f\u043e\u0436\u0430\u0440\u043d. \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0441\u0442\u0438 (DD.MM.YYYY)");
