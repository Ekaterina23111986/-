function createTrain(ss, loc) {
  var sh = ensureSheet(ss, loc + " \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435");
  sh.setTabColor("#4285F4");
  ensureHeaders(sh, TH);
  [200,150,120,60,150,120,150,200,120,110,130,170,320,130,280].forEach(function(v,i){sh.setColumnWidth(i+1,v);});
  sh.getRange("D2:D51").setDataValidation(SpreadsheetApp.newDataValidation().requireValueInList(["0.25","0.5","0.75","1.0"]).setAllowInvalid(false).build());
  sh.getRange("C2:C51").setDataValidation(SpreadsheetApp.newDataValidation().requireValueInList(["\u041e\u0441\u043d\u043e\u0432\u043d\u043e\u0435 \u043c\u0435\u0441\u0442\u043e \u0440\u0430\u0431\u043e\u0442\u044b","\u0421\u043e\u0432\u043c\u0435\u0441\u0442\u0438\u0442\u0435\u043b\u044c"]).setAllowInvalid(false).build());
  sh.getRange("J2:J51").setDataValidation(SpreadsheetApp.newDataValidation().requireValueInList(["\u041f\u0435\u0440\u0432\u0438\u0447\u043d\u0430\u044f","\u041f\u0435\u0440\u0438\u043e\u0434\u0438\u0447\u0435\u0441\u043a\u0430\u044f"]).setAllowInvalid(false).build());
  setTrainFormulas(sh);
  setTrainCondFmt(sh);
  sh.setFrozenRows(1); sh.setFrozenColumns(2);
}

function setTrainFormulas(sh) {
  for (var r = 2; r <= 51; r++) {
    putFormula(sh.getRange(r, 11), "=IF(I" + r + "=\"\";\"\";DATE(YEAR(I" + r + ")+5;MONTH(I" + r + ");DAY(I" + r + ")))");
    putFormula(sh.getRange(r, 12), "=IF(K" + r + "=\"\";\"\";IF(K" + r + "<TODAY();" + q() + "\u041f\u0420\u041e\u0421\u0420\u041e\u0427\u0415\u041d\u043e" + q() + ";CONCATENATE(" + q() + "\u041e\u0441\u0442\u0430\u043b\u043e\u0441\u044c " + q() + ";DATEDIF(TODAY();K" + r + ";" + q() + "Y" + q() + ");" + q() + " \u043b\u0435\u0442 " + q() + ";DATEDIF(TODAY();K" + r + ";" + q() + "YM" + q() + ");" + q() + " \u043c\u0435\u0441 " + q() + ";DATEDIF(TODAY();K" + r + ";" + q() + "MD" + q() + ");" + q() + " \u0434\u043d." + q() + ")))");
    putFormula(sh.getRange(r,13),"=IF(AND(K"+r+"<>\"\";K"+r+"<=TODAY()+2);CONCATENATE(\"С \";TEXT(K"+r+";\"ДД.ММ.ГГГГ\");\" необходимо отправить в отпуск\");\"\")");
    putFormula(sh.getRange(r, 15), "=IF(N" + r + "<>" + q() + q() + ";IF(N" + r + "<TODAY();CONCATENATE(" + q() + "\u041f\u0420\u041e\u0421\u0420\u041e\u0427\u0415\u041d\u043e: " + q() + ";TEXT(N" + r + ";" + q() + "DD.MM.YYYY" + q() + "));CONCATENATE(" + q() + "\u041f\u043b\u0430\u043d: " + q() + ";TEXT(N" + r + ";" + q() + "DD.MM.YYYY" + q() + ");" + q() + " (\u043e\u0441\u0442\u0430\u043b\u043e\u0441\u044c " + q() + ";DATEDIF(TODAY();N" + r + ";" + q() + "Y" + q() + ");" + q() + " \u043b\u0435\u0442 " + q() + ";DATEDIF(TODAY();N" + r + ";" + q() + "YM" + q() + ");" + q() + " \u043c\u0435\u0441)" + q() + "));IF(F" + r + "=" + q() + q() + ";" + q() + q() + ";CONCATENATE(" + q() + "\u041d\u0435 \u0437\u0430\u043f\u043b\u0430\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u043e. \u041f\u0440\u043e\u0448\u043b\u043e " + q() + ";DATEDIF(F" + r + ";TODAY();" + q() + "Y" + q() + ");" + q() + " \u043b\u0435\u0442 " + q() + ";DATEDIF(F" + r + ";TODAY();" + q() + "YM" + q() + ");" + q() + " \u043c\u0435\u0441 \u0438\u0437 5." + q() + ")))");
    sh.getRange(r, 6).setNumberFormat("DD.MM.YYYY");
    sh.getRange(r, 9).setNumberFormat("DD.MM.YYYY");
    sh.getRange(r, 14).setNumberFormat("DD.MM.YYYY");
  }
}

function setTrainCondFmt(sh) {
  try {
    var rules = [];
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($K2<>\"\";$K2<TODAY())").setFontColor("#CC0000").setBold(true).setRanges([sh.getRange("K2:K51")]).build());
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($K2<>\"\";$K2>=TODAY();$K2<=TODAY()+122)").setBackground("#F4CCCC").setFontColor("#CC0000").setRanges([sh.getRange("K2:K51")]).build());
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=AND($K2<>\"\";$K2>TODAY()+122;$K2<=TODAY()+365)").setBackground("#FFF2CC").setRanges([sh.getRange("K2:K51")]).build());
    rules.push(SpreadsheetApp.newConditionalFormatRule().whenFormulaSatisfied("=LEN($M2)>0").setBackground("#FFF2CC").setFontColor("#CC0000").setRanges([sh.getRange("M2:M51")]).build());
    sh.setConditionalFormatRules(rules);
  } catch(e) {}
}

