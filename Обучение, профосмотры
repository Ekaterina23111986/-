}

// =====================================================
// ТРИГГЕР + ONEDIT
// =====================================================
function addTriggerSafe(ss) {
  try {
    ScriptApp.getProjectTriggers().forEach(function(t) {
      if (t.getHandlerFunction() === "onEditHook") {
        try { ScriptApp.deleteTrigger(t); } catch(e2) {}
      }
    });
    ScriptApp.newTrigger("onEditHook").forSpreadsheet(ss).onEdit().create();
  } catch(e) { Logger.log("Trigger: " + e); }
}

function onEditHook(e) {
  try {
    if (!e || !e.range) return;
    var sh = e.source.getActiveSheet();
    if (!sh) return;
    var nm = sh.getName(), row = e.range.getRow(), col = e.range.getColumn();
    if (nm.indexOf("\u043f\u0440\u043e\u0444 \u043e\u0441\u043c\u043e\u0442\u0440") !== -1) {
      if ((col >= 21 && col <= 24) || col === 6 || col === 2) doRefresh(sh, row, 21, 25);
    }
    if (nm.indexOf("\u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435") !== -1 && col === 6) {
      sh.getRange(row, 14).setValue("");
    }
  } catch(e) {}
}

// =====================================================
// ОБНОВЛЕНИЕ СПЕЦИАЛИСТОВ И ИССЛЕДОВАНИЙ
// =====================================================
function doRefresh(sh, row, pktS, resS) {
  try {
    var age = sh.getRange(row, 3).getValue();
    var gender = sh.getRange(row, 6).getValue();
    var hasAge = (age !== "" && age !== null && !isNaN(age));
    var specs = [], tests = [];
    for (var p = 0; p < 4; p++) {
      var val = sh.getRange(row, pktS + p).getValue();
      if (!val || val === "") continue;
      var pk = _pktCache.find(function(x) { return (x.code + " " + x.name) === val; });
      if (!pk) continue;
      if (pk.spec) pk.spec.split(", ").forEach(function(s) { if (specs.indexOf(s) === -1) specs.push(s); });
      if (pk.tests) pk.tests.split("; ").forEach(function(t) {
        var tr = t.replace(/^\s+|\s+$/g, "");
        if (tr && tests.indexOf(tr) === -1) tests.push(tr);
      });
    }
    BASE.forEach(function(item) {
      if (hasAge) {
        if (item[4] > 0 && age < item[4]) return;
        if (item[5] > 0 && age > item[5]) return;
      }
      if (item[6] !== "\u0412\u0441\u0435" && gender !== item[6]) return;
      if (item[1] && specs.indexOf(item[1]) === -1) specs.push(item[1]);
      if (item[2]) item[2].split(", ").forEach(function(t) {
        var tr = t.replace(/^\s+|\s+$/g, "");
        if (tr && tests.indexOf(tr) === -1) tests.push(tr);
      });
    });
    sh.getRange(row, resS).setValue(specs.join("\n"));
    sh.getRange(row, resS + 1).setValue(tests.join("\n"));
  } catch(e) { Logger.log("doRefresh: " + e); }
}

