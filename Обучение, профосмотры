function loadRefData(ss) {
  _pktCache = [];
  var sh = ss.getSheetByName(NM_REF);
  if (!sh) return;
  var last = sh.getLastRow();
  if (last < 2) return;
  var data = sh.getRange(1, 1, last, 5).getValues();
  // data[0] = заголовки
  // data[1..] = строки: [Код, Раздел, Наименование, Специалисты, Исследования]
  for (var i = 1; i < data.length; i++) {
    var code = data[i][0];
    var section = data[i][1];
    var name = data[i][2];
    var spec = data[i][3];
    var tests = data[i][4];
    // Пропускаем пустые строки и заголовки разделов (начинаются с "▶")
    if (!code || code === "" || (typeof code === "string" && code.indexOf("\u25B6") === 0)) continue;
    if (!section || section === "") continue;
    _pktCache.push({
      code: String(code).trim(),
      section: String(section).trim(),
      name: String(name || "").trim(),
      spec: String(spec || "").trim(),
      tests: String(tests || "").trim()
    });
  }
}

// Строим выпадающие списки по разделам
function buildListsBySection() {
  var result = {};
  _pktCache.forEach(function(item) {
    var sec = item.section;
    if (!result[sec]) result[sec] = [];
    result[sec].push(item.code + " " + item.name);
  });
  return result;
}

