function q() { return String.fromCharCode(34); }

function toggleRef() {
  try {
    var sh = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(NM_REF);
    if (sh) sh.isSheetHidden() ? sh.showSheet() : sh.hideSheet();
  } catch(e) {}
}
// =====================================================
// ДОСТРОЙКА НОВЫХ СТОЛБЦОВ O-S К СУЩЕСТВУЮЩИМ ЛИСТАМ
// Не трогает данные в колонках A-N. Только добавляет/обновляет O-S.
// =====================================================
function addNewColumns() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  if (!ss) return;
  var sheets = ss.getSheets();
  var count = 0;
  sheets.forEach(function(sh) {
    var nm = sh.getName();
    if (nm.indexOf("\u043e\u0431\u0443\u0447\u0435\u043d\u0438\u0435") === -1) return;
    // --- Шаг 1: Переименовать заголовок O (15) ---
    // Было: "Ост. до обуч." → Стало: "Коридор обучения"
    var oldO = sh.getRange(1, 15).getValue();
    if (oldO !== "\u041a\u043e\u0440\u0438\u0434\u043e\u0440 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f") {
      sh.getRange(1, 15).setValue("\u041a\u043e\u0440\u0438\u0434\u043e\u0440 \u043e\u0431\u0443\u0447\u0435\u043d\u0438\u044f");
    }
    // --- Шаг 2: Формула коридора в O (15) для всех строк ---
    for (var r = 2; r <= 51; r++) {
      var cellVal = sh.getRange(r, 1).getValue();
      if (cellVal === "" || cellVal === null) continue;
      putFormula(sh.getRange(r, 15),
        "=IF(OR(I" + r + "=\"\";K" + r + "=\"\");\"\";" +
        "TEXT(I" + r + ";\"DD.MM.YYYY\")&\" - \"&TEXT(K" + r + ";\"DD.MM.YYYY\"))");
    }
    // --- Шаг 3: Добавить заголовки P-S (16-19) если их нет ---
    var lastCol = sh.getLastColumn();
    var newHeaders = [
      "\u0414\u043e\u043f. \u0441\u0432\u0435\u0434.",                           // P: Доп. сведения
      "\u041e\u0431\u0443\u0447. \u043c\u0435\u0434. \u043e\u0442\u0445\u043e\u0434\u044b", // Q: Обуч. мед. отходы
      "\u041e\u0431\u0443\u0447. \u043e\u0445\u0440\u0430\u043d\u0430 \u0442\u0440\u0443\u0434\u0430", // R: Обуч. охрана труда
      "\u041e\u0431\u0443\u0447. \u043f\u043e\u0436\u0430\u0440\u043d. \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d."  // S: Обуч. пожарн. безопасность
    ];
    // Если колонок меньше 19 — дописываем заголовки
    if (lastCol < 19) {
      var startCol = lastCol + 1;
      var howMany = 19 - lastCol;
      // Берём только те, которых ещё нет
      var headersToAdd = newHeaders.slice(startCol - 16); // 16 = P
      if (headersToAdd.length > 0) {
        sh.getRange(1, startCol, 1, headersToAdd.length).setValues([headersToAdd]);
        sh.getRange(1, startCol, 1, headersToAdd.length)
          .setFontWeight("bold")
          .setBackground("#4285F4")
          .setFontColor("#fff")
          .setWrap(true)
          .setHorizontalAlignment("center")
          .setVerticalAlignment("middle");
      }
    }
    // --- Шаг 4: Ширины колонок O-S ---
    sh.setColumnWidth(15, 200);  // O: Коридор обучения
    sh.setColumnWidth(16, 200);  // P: Доп. сведения
    sh.setColumnWidth(17, 130);  // Q: Обуч. мед. отходы
    sh.setColumnWidth(18, 130);  // R: Обуч. охрана труда
    sh.setColumnWidth(19, 130);  // S: Обуч. пожарн. безопасность
    // --- Шаг 5: Формат дат для Q, R, S ---
    for (var r = 2; r <= 51; r++) {
      sh.getRange(r, 17).setNumberFormat("DD.MM.YYYY"); // Q
      sh.getRange(r, 18).setNumberFormat("DD.MM.YYYY"); // R
      sh.getRange(r, 19).setNumberFormat("DD.MM.YYYY"); // S
    }
    // --- Шаг 6: Условное форматирование для O (коридор) ---
    // Удаляем старые правила для O, если есть, и ставим новые
    var rules = sh.getConditionalFormatRules();
    var newRules = [];
    for (var i = 0; i < rules.length; i++) {
      var rng = rules[i].getRanges();
      var isOldO = false;
      for (var j = 0; j < rng.length; j++) {
        var rA1 = rng[j].getA1Notation();
        if (rA1.indexOf("O2:O") === 0 || rA1 === "O2:O51") {
          isOldO = true;
          break;
        }
      }
      if (!isOldO) newRules.push(rules[i]);
    }
    // Красный: до окончания коридора < 6 мес
    newRules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=AND($K2<>\"\";$K2<=EDATE(TODAY();6))")
      .setBackground("#F4CCCC").setFontColor("#CC0000")
      .setRanges([sh.getRange("O2:O51")]).build());
    // Жёлтый: до окончания коридора < 1 года
    newRules.push(SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=AND($K2<>\"\";$K2>EDATE(TODAY();6);$K2<=EDATE(TODAY();12))")
      .setBackground("#FFF2CC")
      .setRanges([sh.getRange("O2:O51")]).build());
    sh.setConditionalFormatRules(newRules);
    count++;
  });
  SpreadsheetApp.getUi().alert("\u2705 \u0413\u043e\u0442\u043e\u0432\u043e! \u0414\u043e\u0441\u0442\u0440\u043e\u0435\u043d\u043e " + count + " \u043b\u0438\u0441\u0442(\u043e\u0432).");
}
